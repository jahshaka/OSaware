304 REM ============================================================
304 REM  InitMinimap - Draw static maze into pixel buffer once
304 REM ============================================================
305 SUB InitMinimap STATIC
306 SHARED MAP, MZ, MSCL, MMX, MMY, MAPVIS
307 MSCL=8 : MAPVIS=1
310 MMX=WIDTH-MZ*MSCL-6 : MMY=HEIGHT-MZ*MSCL-6
312 DELAY 0
313 FOR MR=0 TO MZ-1
314 FOR MC=0 TO MZ-1
315 IF MAP(MR,MC)=1 THEN MC2=7 ELSE MC2=15
317 FOR PR=0 TO MSCL-1
318 FOR PC=0 TO MSCL-1
319 PSET MMX+MC*MSCL+PC, MMY+MR*MSCL+PR, MC2
320 NEXT PC : NEXT PR
322 NEXT MC : NEXT MR
325 GDX=MMX+14*MSCL+INT(MSCL/2) : GDY=MMY+14*MSCL+INT(MSCL/2)
326 PSET GDX,GDY,2 : PSET GDX+1,GDY,2 : PSET GDX,GDY+1,2 : PSET GDX+1,GDY+1,2
332 PSET MMX+3*MSCL+INT(MSCL/2),  MMY+1*MSCL+INT(MSCL/2),  6
333 PSET MMX+7*MSCL+INT(MSCL/2),  MMY+1*MSCL+INT(MSCL/2),  6
334 PSET MMX+13*MSCL+INT(MSCL/2), MMY+1*MSCL+INT(MSCL/2),  6
335 PSET MMX+3*MSCL+INT(MSCL/2),  MMY+3*MSCL+INT(MSCL/2),  6
336 PSET MMX+9*MSCL+INT(MSCL/2),  MMY+3*MSCL+INT(MSCL/2),  6
337 PSET MMX+5*MSCL+INT(MSCL/2),  MMY+5*MSCL+INT(MSCL/2),  6
338 PSET MMX+11*MSCL+INT(MSCL/2), MMY+5*MSCL+INT(MSCL/2),  6
339 PSET MMX+3*MSCL+INT(MSCL/2),  MMY+7*MSCL+INT(MSCL/2),  6
340 PSET MMX+9*MSCL+INT(MSCL/2),  MMY+9*MSCL+INT(MSCL/2),  6
341 PSET MMX+5*MSCL+INT(MSCL/2),  MMY+13*MSCL+INT(MSCL/2), 6
342 END SUB
354 REM ============================================================
354 REM  DrawMinimap - Move player dot on minimap each frame
354 REM ============================================================
355 SUB DrawMinimap STATIC
356 SHARED PX, PZ, CELL, MSCL, MMX, MMY, MAP, MZ, MAPVIS
357 IF MAPVIS=0 THEN EXIT SUB
358 IF INITED=1 THEN GOTO CheckErase
359 OLDMR=-1 : OLDMC=-1 : INITED=1
360 CheckErase:
361 IF OLDMR<0 THEN GOTO DrawDot
362 IF MAP(OLDMR,OLDMC)=1 THEN OC=7 ELSE OC=15
363 FOR PR=0 TO MSCL-1
364 FOR PC=0 TO MSCL-1
365 PSET MMX+OLDMC*MSCL+PC, MMY+OLDMR*MSCL+PR, OC
366 NEXT PC : NEXT PR
367 DrawDot:
368 MR=INT(PZ/CELL) : MC=INT(PX/CELL)
369 OLDMR=MR : OLDMC=MC
370 PDX=MMX+MC*MSCL+INT(MSCL/2) : PDY=MMY+MR*MSCL+INT(MSCL/2)
372 PSET PDX,PDY,14 : PSET PDX+1,PDY,14 : PSET PDX,PDY+1,14 : PSET PDX+1,PDY+1,14
376 END SUB
382 REM ============================================================
382 REM  ToggleMap - Show / hide minimap overlay
382 REM ============================================================
383 SUB ToggleMap STATIC
384 SHARED MAPVIS, MZ, MSCL, MMX, MMY
385 MAPVIS=1-MAPVIS
386 IF MAPVIS=1 THEN CALL InitMinimap : EXIT SUB
388 FOR CR=0 TO MZ*MSCL-1
389 FOR CC=0 TO MZ*MSCL-1
390 PSET MMX+CC, MMY+CR, 16
391 NEXT CC : NEXT CR
393 END SUB
502 REM ============================================================
502 REM  BuildScene - GL init, floor, ceiling, walls, goal orb
502 REM ============================================================
503 SUB BuildScene STATIC
504 GL.INIT : GL.PERSPECTIVE 72 : GL.AMBIENT 0.06
505 GL.FOG 4,3,4,6,32
512 FL=16*5.0
513 GL.SOLID : GL.COLOUR 255,255,255 : GL.SHINE 2 : GL.ALPHA 1.0
514 GL.BEGIN
515 GL.VERTEX 0,0,0 : GL.VERTEX FL,0,0 : GL.VERTEX FL,0,FL : GL.VERTEX 0,0,FL
516 GL.FACE 1,2,3,4
517 GL.END
518 SHARED FLOORID
519 FLOORID=GL.MESHID : GL.TRANSLATE FLOORID,0,-1.4,0
520 GL.TEXTURE     FLOORID,"LAVA/BASE.JPG",56
521 GL.NORMALMAP   FLOORID,"LAVA/NORMAL.JPG"
522 GL.ROUGHMAP    FLOORID,"LAVA/ROUGH.JPG"
523 GL.AOMAP       FLOORID,"LAVA/AO.JPG"
524 GL.EMISSIVEMAP FLOORID,"LAVA/EMISSIVE.JPG"
526 GL.SOLID : GL.COLOUR 255,255,255 : GL.SHINE 1 : GL.ALPHA 1.0
527 GL.BEGIN
528 GL.VERTEX 0,0,0 : GL.VERTEX FL,0,0 : GL.VERTEX FL,0,FL : GL.VERTEX 0,0,FL
529 GL.FACE 4,3,2,1
530 GL.END
531 SHARED CEILID
532 CEILID=GL.MESHID : GL.TRANSLATE CEILID,0,1.4,0
533 GL.TEXTURE   CEILID,"PLASTER/BASE.JPG",48
534 GL.NORMALMAP CEILID,"PLASTER/NORMAL.JPG"
535 GL.ROUGHMAP  CEILID,"PLASTER/ROUGH.JPG"
536 GL.AOMAP     CEILID,"PLASTER/AO.JPG"
537 SHARED MAP, MZ, CELL
538 FOR WR=0 TO MZ-1
539 FOR WC=0 TO MZ-1
540 IF MAP(WR,WC)=0 THEN GOTO NextWall
541 WX1=WC*CELL : WX2=WX1+CELL : WZ1=WR*CELL : WZ2=WZ1+CELL
543 GL.SOLID : GL.COLOUR 255,255,255 : GL.SHINE 6 : GL.ALPHA 1.0
544 GL.BEGIN
545 GL.VERTEX WX1,-1.4,WZ1 : GL.VERTEX WX2,-1.4,WZ1
546 GL.VERTEX WX2, 1.4,WZ1 : GL.VERTEX WX1, 1.4,WZ1
547 GL.VERTEX WX1,-1.4,WZ2 : GL.VERTEX WX2,-1.4,WZ2
548 GL.VERTEX WX2, 1.4,WZ2 : GL.VERTEX WX1, 1.4,WZ2
549 GL.FACE 1,2,3,4 : GL.FACE 8,7,6,5
550 GL.FACE 5,1,4,8 : GL.FACE 2,6,7,3
551 GL.FACE 5,6,2,1 : GL.FACE 4,3,7,8
552 GL.END
553 WID=GL.MESHID
554 GL.TEXTURE   WID,"STONE2/BASE.JPG",2
555 GL.NORMALMAP WID,"STONE2/NORMAL.JPG"
556 GL.ROUGHMAP  WID,"STONE2/ROUGH.PNG"
557 GL.AOMAP     WID,"STONE2/AO.PNG"
558 NextWall:
559 NEXT WC : NEXT WR
561 GL.SOLID : GL.COLOUR 255,210,0 : GL.SHINE 180 : GL.EMISSIVE 140,110,0 : GL.ALPHA 1.0
562 GL.SPHERE 0.45,16,10
563 SHARED GOALID
564 GOALID=GL.MESHID
565 END SUB
602 REM ============================================================
602 REM  Move - Collision-checked player movement
602 REM ============================================================
603 SUB Move
604 SHARED PX, PZ, DX, DZ, MZ, CELL, MAP
605 M=0.35 : NX=PX+DX : NZ=PZ+DZ
606 R1=INT((NZ-M)/CELL) : R2=INT((NZ+M)/CELL)
607 C1=INT((NX-M)/CELL) : C2=INT((NX+M)/CELL)
608 IF R1<0 OR R2>=MZ OR C1<0 OR C2>=MZ THEN GOTO SlideX
609 IF MAP(R1,C1)<>0 OR MAP(R1,C2)<>0 OR MAP(R2,C1)<>0 OR MAP(R2,C2)<>0 THEN GOTO SlideX
610 PX=NX : PZ=NZ : EXIT SUB
611 SlideX:
612 NX=PX+DX : NZ=PZ
613 R1=INT((NZ-M)/CELL) : R2=INT((NZ+M)/CELL)
614 C1=INT((NX-M)/CELL) : C2=INT((NX+M)/CELL)
615 IF R1<0 OR R2>=MZ OR C1<0 OR C2>=MZ THEN GOTO SlideZ
616 IF MAP(R1,C1)<>0 OR MAP(R1,C2)<>0 OR MAP(R2,C1)<>0 OR MAP(R2,C2)<>0 THEN GOTO SlideZ
617 PX=NX : EXIT SUB
618 SlideZ:
619 NX=PX : NZ=PZ+DZ
620 R1=INT((NZ-M)/CELL) : R2=INT((NZ+M)/CELL)
621 C1=INT((NX-M)/CELL) : C2=INT((NX+M)/CELL)
622 IF R1<0 OR R2>=MZ OR C1<0 OR C2>=MZ THEN EXIT SUB
623 IF MAP(R1,C1)<>0 OR MAP(R1,C2)<>0 OR MAP(R2,C1)<>0 OR MAP(R2,C2)<>0 THEN EXIT SUB
624 PZ=NZ
625 END SUB
2299 REM ============================================================
2299 REM  BuildPrizes - Create 10 prize spheres in the GL scene
2299 REM ============================================================
2300 SUB BuildPrizes
2301 SHARED PRC(), PRZ(), PRID(), PRHIT(), PRZDONE
2302 PRZDONE=1
2303 FOR I=1 TO 10
2304 GL.SOLID : GL.COLOUR 40,120,255 : GL.SHINE 60 : GL.EMISSIVE 0,0,0 : GL.ALPHA 1.0
2305 GL.BOX 0.45,0.45,0.45
2306 PRID(I)=GL.MESHID : GL.TRANSLATE PRID(I),PRC(I),0,PRZ(I)
2307 NEXT I
2308 GL.COLOUR 255,255,255 : GL.EMISSIVE 0,0,0 : GL.SHINE 30 : GL.ALPHA 1.0
2309 END SUB
5999 REM ============================================================
