6014 PRINT "  Total score: "+STR$(SCORE)+" points"
6015 PRINT ""
6016 PRINT "  Press any key..."
6017 SLEEP 400
6018 DUMMY=GETKEY()
6019 CLS
6020 END
6021 END SUB
