84 MOUSE ON : LASTMX=MOUSE(1)
90 REM === Main loop ===
91 MainLoop:
92 K=INKEY
93 REM --- Keyboard: Q/ESC=quit  M=map  via SWITCH ---
94 SWITCH(K)
95 CASE 81:
96 CASE 113:
97 CASE 27:
98 CALL Quit
99 BREAK
100 CASE 77:
101 CASE 109:
102 CALL ToggleMap
103 BREAK
104 END SWITCH
110 REM --- Turn via mouse ---
111 MX=MOUSE(1) : PYAW=PYAW+(MX-LASTMX)*TSPD : LASTMX=MX
115 REM --- Move + Head Bob ---
116 DX=0 : DZ=0
117 IF KEYDOWN(87) OR KEYDOWN(38) THEN DX=COS(PYAW)*SPEED : DZ=SIN(PYAW)*SPEED
118 IF KEYDOWN(83) OR KEYDOWN(40) THEN DX=-COS(PYAW)*SPEED : DZ=-SIN(PYAW)*SPEED
119 IF DX<>0 OR DZ<>0 THEN CALL Move
120 IF DX<>0 OR DZ<>0 THEN MOVING=1 ELSE MOVING=0
122 IF MOVING=1 THEN BOBPHASE=BOBPHASE+0.18 : IF BOBPHASE>=6.2832 THEN BOBPHASE=BOBPHASE-6.2832
124 IF MOVING=1 THEN BOBBY=SIN(BOBPHASE)*0.06 ELSE BOBBY=BOBBY*0.8
126 REM --- Camera + torch ---
127 GL.CAMERA PX,BOBBY,PZ : GL.LOOKAT PX+COS(PYAW),0,PZ+SIN(PYAW)
128 GL.LIGHTSOFF : GL.POINTLIGHT PX,0.2+BOBBY,PZ,255,190,100,3.5,18
129 REM --- Goal orb spin ---
130 GSPIN=GSPIN+2 : IF GSPIN>=3600 THEN GSPIN=0
131 GL.TRANSLATE GOALID,GX,SIN(GSPIN*0.05)*0.35,GZ
132 CALL DrawMinimap
133 GL.CLS 4,3,4 : GL.DRAWALL
134 IF PBRINIT=0 THEN CALL SetupPBR
135 IF PBRINIT=1 AND PRZDONE=0 THEN CALL BuildPrizes
136 IF INT(PX/CELL)=14 AND INT(PZ/CELL)=14 THEN CALL Win
137 REM --- Prize collection using SWITCH on cell coords ---
138 CX=INT(PX/CELL) : CZ=INT(PZ/CELL)
139 FOR I=1 TO 10
140 IF PRHIT(I)=0 AND INT(PRC(I)/CELL)=CX AND INT(PRZ(I)/CELL)=CZ THEN PRHIT(I)=1 : SCORE=SCORE+10
141 IF PRHIT(I)=1 AND PRHID(I)=0 THEN GL.HIDE PRID(I) : PRHID(I)=1
142 NEXT I
143 SLEEP 16 : GOTO MainLoop
200 END
