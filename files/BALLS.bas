0 REM *****************************************************
1 REM ** BALLS v1.0 — OBJECT system demo                 **
2 REM ** Three coloured squares bounce around the screen **
3 REM *****************************************************
10 CLS : COLOUR 3
20 PRINT "BALLS DEMO"
30 PRINT "Three coloured squares bounce around the screen."
40 PRINT "Press any key to start, Q to quit."
50 DUMMY=GETKEY()
60 CLS : DELAY 0
70 GOSUB 100
80 GOSUB 1000
100 REM == BUILD 12x12 SHAPE STRINGS ==
110 S1$="12,12," : S2$="12,12," : S3$="12,12,"
120 FOR RR=1 TO 12
130   FOR CC=1 TO 12
140     S1$=S1$+"FF3333"
150     S2$=S2$+"33FF33"
160     S3$=S3$+"3399FF"
170   NEXT CC
180 NEXT RR
190 RETURN
500 REM == MAIN LOOP ==
510 K=INKEY
520 IF K=81 OR K=113 OR K=27 THEN GOTO 900
525 GOSUB 2000
530 SLEEP 30
540 GOTO 510
900 OBJECT.CLOSE
910 COLOUR 3 : CLS : PRINT "Done."
920 END
1000 REM == CREATE AND START BALLS ==
1005 RANDOMIZE TIMER
1010 OBJECT.SHAPE 1, S1$
1020 OBJECT.X 1, 50  : OBJECT.Y 1, 50
1030 OBJECT.VX 1, 80 : OBJECT.VY 1, 60
1040 OBJECT.SHAPE 2, S2$
1050 OBJECT.X 2, 200 : OBJECT.Y 2, 120
1060 OBJECT.VX 2, -70 : OBJECT.VY 2, 90
1070 OBJECT.SHAPE 3, S3$
1080 OBJECT.X 3, 350 : OBJECT.Y 3, 80
1090 OBJECT.VX 3, 100 : OBJECT.VY 3, -80
1100 OBJECT.ON 1 : OBJECT.ON 2 : OBJECT.ON 3
1110 OBJECT.START
1120 RETURN
2000 REM == BOUNCE CHECK ==
2005 W=WIDTH : H=HEIGHT : SZ=12
2010 REM -- Border bounce
2020 FOR BID=1 TO 3
2030   BX=OBJECT.X(BID) : BY=OBJECT.Y(BID)
2040   BVX=OBJECT.VX(BID) : BVY=OBJECT.VY(BID)
2050   IF BX<=0 AND BVX<0 THEN OBJECT.VX BID,-BVX
2060   IF BX>=W-SZ AND BVX>0 THEN OBJECT.VX BID,-BVX
2070   IF BY<=0 AND BVY<0 THEN OBJECT.VY BID,-BVY
2080   IF BY>=H-SZ AND BVY>0 THEN OBJECT.VY BID,-BVY
2090 NEXT BID
2100 REM -- Ball vs ball bounce (check each pair once)
2110 FOR A=1 TO 2
2120   FOR B=A+1 TO 3
2130     AX=OBJECT.X(A) : AY=OBJECT.Y(A)
2140     BX=OBJECT.X(B) : BY=OBJECT.Y(B)
2150     REM -- Bounding box overlap?
2160     IF AX+SZ<=BX OR BX+SZ<=AX THEN GOTO 2240
2170     IF AY+SZ<=BY OR BY+SZ<=AY THEN GOTO 2240
2180     REM -- Overlapping - swap velocities (elastic collision)
2190     AVX=OBJECT.VX(A) : AVY=OBJECT.VY(A)
2200     BVX=OBJECT.VX(B) : BVY=OBJECT.VY(B)
2210     OBJECT.VX A,BVX : OBJECT.VY A,BVY
2220     OBJECT.VX B,AVX : OBJECT.VY B,AVY
2230     REM -- Nudge apart so they don't stick together
2235     OBJECT.X A,AX-AVX*0.05 : OBJECT.Y A,AY-AVY*0.05
2236     OBJECT.X B,BX-BVX*0.05 : OBJECT.Y B,BY-BVY*0.05
2240   NEXT B
2250 NEXT A
