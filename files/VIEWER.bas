10 REM *** FILE VIEWER - text and images ***
20 CLS
30 COLOUR 3 : PRINT "=== FILE VIEWER ===" : COLOUR 7
40 PRINT ""
50 PRINT "  Text:   OSAWARE.TXT"
60 PRINT "  Image:  DEMO/SMILEY.PNG"
70 PRINT "  QUIT to exit"
80 PRINT ""
90 INPUT "> "; F$
100 IF F$ = "" THEN GOTO 90
110 IF UPPER$(F$) = "QUIT" THEN END
115 E$ = UPPER$(RIGHT$(F$, 4))
120 IF E$ = ".PNG" OR E$ = ".JPG" THEN GOTO 500
125 IF E$ = ".GIF" OR E$ = ".BMP" THEN GOTO 500
130 IF UPPER$(RIGHT$(F$, 5)) = ".JPEG" THEN GOTO 500
140 READTEXT F$
150 IF TXT_COUNT > 0 THEN GOTO 300
160 COLOUR 4 : PRINT "Not found: ";F$ : COLOUR 7
170 PRINT "" : GOTO 90
300 REM -- TEXT --
310 PRINT ""
320 COLOUR 2 : PRINT "--- ";F$;" ---" : COLOUR 7
330 PRINT ""
340 FOR I=1 TO TXT_COUNT
350 PRINT TXT$(I)
360 NEXT I
370 PRINT ""
380 COLOUR 3 : PRINT TXT_COUNT;" lines --- press ENTER ---" : COLOUR 7
390 INPUT ""; D$
400 GOTO 20
500 REM -- IMAGE --
510 IMAGE F$
520 SLEEP 2
530 COLOUR 3 : PRINT F$;" --- press ENTER ---" : COLOUR 7
540 INPUT ""; D$
550 GOTO 20
