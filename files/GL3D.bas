0 REM *****************************************************
1 REM ** GL3D — Solid+Wire 3D Demo: Pyramid + Cube      **
2 REM *****************************************************
10 CLS : COLOUR 3
20 PRINT "GL 3D SOLID DEMO"
30 PRINT "Rotating pyramid and cube with visible edges"
40 PRINT "Press Q to quit."
50 SLEEP 1500
60 GL.INIT
70 GL.PERSPECTIVE 55
80 GL.CAMERA 0, 1, -6
90 GL.LOOKAT 0, 0, 0
100 GL.SOLIDWIRE
110 REM === Cube (left) ===
120 GL.COLOUR 80,120,255
130 GL.BEGIN
140 GL.VERTEX -1,-1,-1 : GL.VERTEX 1,-1,-1
150 GL.VERTEX 1,1,-1   : GL.VERTEX -1,1,-1
160 GL.VERTEX -1,-1,1  : GL.VERTEX 1,-1,1
170 GL.VERTEX 1,1,1    : GL.VERTEX -1,1,1
180 GL.FACE 1,2,3,4 : GL.FACE 8,7,6,5
190 GL.FACE 1,4,8,5 : GL.FACE 2,3,7,6
200 GL.FACE 4,3,7,8 : GL.FACE 1,2,6,5
210 GL.END
220 CUBE=GL.MESHID
230 GL.TRANSLATE CUBE,-2,0,0
240 REM === Pyramid (right) ===
250 GL.COLOUR 255,100,80
260 GL.BEGIN
270 GL.VERTEX -1,-1,-1 : GL.VERTEX 1,-1,-1
280 GL.VERTEX 1,-1,1   : GL.VERTEX -1,-1,1
290 GL.VERTEX 0,1.5,0
300 GL.FACE 1,2,3,4
310 GL.FACE 1,2,5 : GL.FACE 2,3,5
320 GL.FACE 3,4,5 : GL.FACE 4,1,5
330 GL.END
340 PYR=GL.MESHID
350 GL.TRANSLATE PYR,2,0,0
360 REM === Spin loop ===
370 ANG=0
380 K=INKEY
390 IF K=81 OR K=113 OR K=27 THEN GOTO 900
400 GL.CLS 10,10,10
410 GL.ROTATE CUBE, ANG*0.7, ANG, 0
420 GL.ROTATE PYR, 0, -ANG, ANG*0.5
430 GL.DRAWALL
440 ANG=ANG+1.2
450 IF ANG>=360 THEN ANG=ANG-360
460 SLEEP 16
470 GOTO 380
900 COLOUR 3 : CLS : PRINT "GL demo ended."
