0 REM *** AUDIOTEST — Sound & Wave synthesis demo ***
5 CLS : COLOUR 3
10 PRINT "AUDIO TEST"
11 PRINT "=========="
12 PRINT ""
20 PRINT "1. Scale (sine wave)"
21 PRINT "2. Scale (sawtooth wave)"
22 PRINT "3. Scale (square wave)"
23 PRINT "4. Scale (custom organ)"
24 PRINT "5. Chord (3 voices)"
25 PRINT "6. Arpeggio"
26 PRINT "7. SOUND WAIT demo"
27 PRINT "8. All waveforms comparison"
30 PRINT ""
35 INPUT "Select (1-8, Q=quit): ";S$
40 IF UPPER$(S$) = "Q" THEN GOTO 999
45 S = VAL(S$)
50 IF S = 1 THEN GOSUB PlaySine
55 IF S = 2 THEN GOSUB PlaySaw
60 IF S = 3 THEN GOSUB PlaySquare
65 IF S = 4 THEN GOSUB PlayOrgan
70 IF S = 5 THEN GOSUB PlayChord
75 IF S = 6 THEN GOSUB PlayArp
80 IF S = 7 THEN GOSUB PlayWait
85 IF S = 8 THEN GOSUB PlayAll
90 GOTO 5
100 PlaySine:
110 COLOUR 7 : PRINT "Playing scale — sine wave..." : COLOUR 3
115 WAVE 0, SIN
120 FOR N = 0 TO 7
125   FREQ = 261 * 2^(N/12*2)
130   SOUND FREQ, 15, 180, 0
135   SLEEP 270
140 NEXT N
145 RETURN
200 PlaySaw:
210 COLOUR 7 : PRINT "Playing scale — sawtooth wave..." : COLOUR 3
215 DIM SW(255)
220 FOR I = 0 TO 255
225   SW(I) = I - 128
230 NEXT I
235 WAVE 0, SW
240 FOR N = 0 TO 7
245   FREQ = 261 * 2^(N/12*2)
250   SOUND FREQ, 15, 150, 0
255   SLEEP 270
260 NEXT N
265 WAVE 0, SIN
270 RETURN
300 PlaySquare:
310 COLOUR 7 : PRINT "Playing scale — square wave..." : COLOUR 3
315 DIM QW(255)
320 FOR I = 0 TO 255
325   IF I < 128 THEN QW(I) = 100 ELSE QW(I) = -100
330 NEXT I
335 WAVE 0, QW
340 FOR N = 0 TO 7
345   FREQ = 261 * 2^(N/12*2)
350   SOUND FREQ, 15, 130, 0
355   SLEEP 270
360 NEXT N
365 WAVE 0, SIN
370 RETURN
400 PlayOrgan:
410 COLOUR 7 : PRINT "Playing scale — organ (harmonics)..." : COLOUR 3
415 DIM OW(255)
420 FOR I = 0 TO 255
425   A = I * 6.2832 / 256
430   OW(I) = INT(60*SIN(A) + 30*SIN(2*A) + 20*SIN(3*A) + 10*SIN(4*A))
435 NEXT I
440 WAVE 0, OW
445 FOR N = 0 TO 7
450   FREQ = 261 * 2^(N/12*2)
455   SOUND FREQ, 18, 160, 0
460   SLEEP 330
465 NEXT N
470 WAVE 0, SIN
475 RETURN
500 PlayChord:
510 COLOUR 7 : PRINT "Playing C major chord (3 voices)..." : COLOUR 3
515 WAVE 0, SIN : WAVE 1, SIN : WAVE 2, SIN
520 SOUND WAIT
525 SOUND 261, 90, 160, 0
530 SOUND 329, 90, 140, 1
535 SOUND 392, 90, 140, 2
540 SOUND RESUME
545 SLEEP 1600
550 PRINT "G major chord..."
555 SOUND WAIT
560 SOUND 392, 90, 160, 0
565 SOUND 494, 90, 140, 1
570 SOUND 587, 90, 140, 2
575 SOUND RESUME
580 SLEEP 1600
585 RETURN
600 PlayArp:
610 COLOUR 7 : PRINT "Playing arpeggio..." : COLOUR 3
615 DIM AW(255)
620 FOR I = 0 TO 255
625   AW(I) = INT(80*SIN(I*6.2832/256) + 40*SIN(I*6.2832/128))
630 NEXT I
635 WAVE 0, AW
640 NOTES = 16
645 FOR N = 0 TO NOTES-1
650   IDX = N MOD 8
655   IF IDX = 0 THEN F = 261
660   IF IDX = 1 THEN F = 293
665   IF IDX = 2 THEN F = 329
670   IF IDX = 3 THEN F = 349
675   IF IDX = 4 THEN F = 392
680   IF IDX = 5 THEN F = 440
685   IF IDX = 6 THEN F = 494
690   IF IDX = 7 THEN F = 523
695   SOUND F, 8, 170, 0
700   SLEEP 140
705 NEXT N
710 WAVE 0, SIN
715 RETURN
800 PlayWait:
810 COLOUR 7 : PRINT "SOUND WAIT — synced voices..." : COLOUR 3
815 WAVE 0, SIN : WAVE 1, SIN : WAVE 2, SIN : WAVE 3, SIN
820 FOR REP = 1 TO 4
825   SOUND WAIT
830   SOUND 261, 20, 180, 0
835   SOUND 523, 20, 120, 1
840   SOUND 784, 20, 100, 2
845   SOUND 1046, 20, 80, 3
850   SOUND RESUME
855   SLEEP 380
860 NEXT REP
865 RETURN
900 PlayAll:
910 COLOUR 7 : PRINT "All 4 waveforms in sequence..." : COLOUR 3
915 PRINT "Sine..."
920 WAVE 0, SIN
925 SOUND 440, 45, 160, 0 : SLEEP 800
930 PRINT "Sawtooth..."
935 DIM BW(255)
940 FOR I = 0 TO 255 : BW(I) = I - 128 : NEXT I
945 WAVE 0, BW
950 SOUND 440, 45, 140, 0 : SLEEP 800
955 PRINT "Square..."
960 DIM CW(255)
965 FOR I = 0 TO 255
970   IF I < 128 THEN CW(I) = 110 ELSE CW(I) = -110
975 NEXT I
980 WAVE 0, CW
985 SOUND 440, 45, 120, 0 : SLEEP 800
990 PRINT "Organ..."
992 DIM DW(255)
993 FOR I = 0 TO 255
994   A = I * 6.2832 / 256
995   DW(I) = INT(60*SIN(A) + 30*SIN(2*A) + 20*SIN(3*A) + 10*SIN(4*A))
996 NEXT I
997 WAVE 0, DW
998 SOUND 440, 45, 160, 0 : SLEEP 800
