0 REM *****************************************************
1 REM ** GLSHADE — Flat Shading Demo                    **
2 REM ** Directional light with ambient + diffuse       **
3 REM *****************************************************
10 CLS : COLOUR 3
20 PRINT "GL SHADING DEMO"
30 PRINT "Flat shading with directional light"
40 PRINT "Press Q to quit."
50 SLEEP 1500
60 GL.INIT
70 GL.PERSPECTIVE 50
80 GL.CAMERA 0, 2, -7
90 GL.LOOKAT 0, 0, 0
100 GL.SOLID
110 REM === Light from upper-right-front ===
120 GL.LIGHT 1, 1.5, -1
130 GL.AMBIENT 0.15
140 REM === Cube ===
150 GL.COLOUR 60,140,255
160 GL.BEGIN
170 GL.VERTEX -1,-1,-1 : GL.VERTEX 1,-1,-1
180 GL.VERTEX 1,1,-1   : GL.VERTEX -1,1,-1
190 GL.VERTEX -1,-1,1  : GL.VERTEX 1,-1,1
200 GL.VERTEX 1,1,1    : GL.VERTEX -1,1,1
210 GL.FACE 1,2,3,4 : GL.FACE 8,7,6,5
220 GL.FACE 1,4,8,5 : GL.FACE 2,3,7,6
230 GL.FACE 4,3,7,8 : GL.FACE 1,2,6,5
240 GL.END
250 CUBE=GL.MESHID
260 GL.TRANSLATE CUBE,-2.2,0,0
270 REM === Pyramid ===
280 GL.COLOUR 255,160,40
290 GL.BEGIN
300 GL.VERTEX -1,-1,-1 : GL.VERTEX 1,-1,-1
310 GL.VERTEX 1,-1,1   : GL.VERTEX -1,-1,1
320 GL.VERTEX 0,1.8,0
330 GL.FACE 1,2,3,4
340 GL.FACE 1,2,5 : GL.FACE 2,3,5
350 GL.FACE 3,4,5 : GL.FACE 4,1,5
360 GL.END
370 PYR=GL.MESHID
380 GL.TRANSLATE PYR,0,-0.2,0
390 REM === Octahedron (diamond shape) ===
400 GL.COLOUR 80,220,120
410 GL.BEGIN
420 GL.VERTEX  0, 1.5, 0
430 GL.VERTEX  1, 0,   0
440 GL.VERTEX  0, 0,   1
450 GL.VERTEX -1, 0,   0
460 GL.VERTEX  0, 0,  -1
470 GL.VERTEX  0,-1.5, 0
480 GL.FACE 1,2,3 : GL.FACE 1,3,4
490 GL.FACE 1,4,5 : GL.FACE 1,5,2
500 GL.FACE 6,3,2 : GL.FACE 6,4,3
510 GL.FACE 6,5,4 : GL.FACE 6,2,5
520 GL.END
530 OCT=GL.MESHID
540 GL.TRANSLATE OCT,2.2,0,0
550 REM === Spin loop ===
560 ANG=0
570 K=INKEY
580 IF K=81 OR K=113 OR K=27 THEN GOTO 900
590 GL.CLS 5,5,15
600 GL.ROTATE CUBE, ANG*0.5, ANG, 0
610 GL.ROTATE PYR, 0, ANG*1.2, 0
620 GL.ROTATE OCT, ANG*0.8, 0, ANG*0.6
630 GL.DRAWALL
640 ANG=ANG+1
650 IF ANG>=360 THEN ANG=ANG-360
660 SLEEP 16
670 GOTO 570
900 COLOUR 3 : CLS : PRINT "GL demo ended."
