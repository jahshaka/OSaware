1 REM *** MANDELBROT SET v5 - SWITCH edition ***
2 REM *** (c) 2026 Exedos      ***
5 CLS
10 COLOUR 3
20 PRINT "MANDELBROT SET GENERATOR"
30 PRINT "========================"
40 PRINT ""
50 PRINT "Mode: 1=Text  2=Graphics"
60 INPUT "Select: ";MODE
70 PRINT "Speed: 1=slow 2=med 3=fast 4=max"
80 INPUT "Select: ";SPD
90 IF SPD<1 THEN SPD=2
91 IF SPD>4 THEN SPD=2
92 COLOUR 7 : PRINT "" : PRINT "Press Q or ESC to stop rendering."
100 XMN=-2.5 : XMX=1.0 : YMN=-1.25 : YMX=1.25
110 MAXI=32
120 SWITCH(MODE)
121 CASE 1:
122 GOTO 1000
123 CASE 2:
124 GOTO 2000
125 END SWITCH
140 END
1000 REM === TEXT MODE ===
1010 NC=60
1011 NR=22
1012 SX=(XMX-XMN)/NC
1013 SY=(YMX-YMN)/NR
1020 SWITCH(SPD)
1021 CASE 1:
1022 SYLD=200 : BREAK
1023 CASE 2:
1024 SYLD=80 : BREAK
1025 CASE 3:
1026 SYLD=20 : BREAK
1027 CASE 4:
1028 SYLD=0 : BREAK
1029 END SWITCH
1030 CLS
1040 FOR RW=0 TO NR-1
1041   CI=YMN+RW*SY
1042   L$=""
1050   FOR CL=0 TO NC-1
1051     CR=XMN+CL*SX
1052     ZR=0 : ZI=0 : IT=0
1060     WHILE IT<MAXI AND ZR*ZR+ZI*ZI<4
1061       TMP=ZR*ZR-ZI*ZI+CR
1062       ZI=2*ZR*ZI+CI
1063       ZR=TMP
1064       IT=IT+1
1065     WEND
1070     C$=" " : DN=0
1071     IF IT>=MAXI THEN C$="*" ELSE DN=INT(IT*7/MAXI)
1072     SWITCH(DN)
1073     CASE 1:
1074     C$="." : BREAK
1075     CASE 2:
1076     C$=":" : BREAK
1077     CASE 3:
1078     C$="+" : BREAK
1079     CASE 4:
1080     C$="o" : BREAK
1081     CASE 5:
1082     C$="O" : BREAK
1083     CASE 6:
1084     C$="@" : BREAK
1085     END SWITCH
1090     L$=L$+C$
1091   NEXT CL
1092   PRINT L$
1093   SLEEP SYLD
1094   K=INKEY
1095   IF K=81 OR K=113 OR K=27 THEN GOTO 1098
1096 NEXT RW
1097 COLOUR 3 : PRINT ""
1098 IF RW>=NR THEN PRINT "TEXT DONE" ELSE PRINT "Stopped at row ";RW;"/";NR
1099 END
2000 REM === GRAPHICS MODE ===
2010 SWITCH(SPD)
2011 CASE 1:
2012 BSTEP=1 : SYLD=32 : BREAK
2013 CASE 2:
2014 BSTEP=4 : SYLD=20 : BREAK
2015 CASE 3:
2016 BSTEP=16 : SYLD=16 : BREAK
2017 CASE 4:
2018 BSTEP=999 : SYLD=0 : BREAK
2019 END SWITCH
2050 PW=WIDTH
2051 PH=HEIGHT
2060 IF PW=0 THEN PW=780
2061 IF PH=0 THEN PH=540
2070 SX=(XMX-XMN)/PW
2071 SY=(YMX-YMN)/PH
2080 CLS : DELAY 0
2090 FOR PY=0 TO PH-1
2091   FOR PX=0 TO PW-1
2092     CR=XMN+PX*SX
2093     CI=YMN+PY*SY
2094     ZR=0 : ZI=0 : IT=0
2095     WHILE IT<MAXI AND ZR*ZR+ZI*ZI<4
2096       TMP=ZR*ZR-ZI*ZI+CR
2097       ZI=2*ZR*ZI+CI
2098       ZR=TMP
2099       IT=IT+1
2100     WEND
2101     IF IT<MAXI THEN PSET PX,PY,INT(IT*15/MAXI)+1
2102   NEXT PX
2103   IF SYLD>0 THEN SLEEP SYLD
2104   K=INKEY
2105   IF K=81 OR K=113 OR K=27 THEN GOTO 2200
2106 NEXT PY
2200 COLOUR 3
2210 PRINT ""
2211 IF PY>=PH THEN PRINT "DONE - ";PW;"x";PH ELSE PRINT "Stopped at row ";PY;"/";PH
2220 END