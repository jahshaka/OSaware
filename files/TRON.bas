444 DT=1
445 LX=PX+COS(CUBEYAW)*8 : LZ=PZ+SIN(CUBEYAW)*8 : NEARW=0
446 IF LX<5 OR LX>75 OR LZ<5 OR LZ>75 THEN NEARW=1
447 FLX=PX+COS(CUBEYAW-0.6)*7 : FLZ=PZ+SIN(CUBEYAW-0.6)*7
448 IF FLX<5 OR FLX>75 OR FLZ<5 OR FLZ>75 THEN NEARW=1
449 FRX=PX+COS(CUBEYAW+0.6)*7 : FRZ=PZ+SIN(CUBEYAW+0.6)*7
450 IF FRX<5 OR FRX>75 OR FRZ<5 OR FRZ>75 THEN NEARW=1
451 LRX=PX+COS(CUBEYAW)*6 : LRZ=PZ+SIN(CUBEYAW)*6 : NEARR=0
452 RCX=INT(LRX/CELL) : RCZ=INT(LRZ/CELL)
453 IF RCX<0 OR RCX>=MZ OR RCZ<0 OR RCZ>=MZ THEN GOTO DLNoR
454 IF TRAIL(RCZ,RCX)<>0 THEN NEARR=1
455 DLNoR:
456 MCX=INT(PX/CELL) : MCZ=INT(PZ/CELL)
457 IF MCX>=0 AND MCX<MZ AND MCZ>=0 AND MCZ<MZ THEN TRAIL(MCZ,MCX)=1
458 IF WALLCD>0 THEN WALLCD=WALLCD-1
459 IF RIBCD>0 THEN RIBCD=RIBCD-1
460 DTMR=DTMR-1
461 IF NEARW=1 AND WALLCD<=0 THEN GOTO DLWall
462 IF NEARR=1 AND RIBCD<=0 THEN GOTO DLRib
463 IF DTMR>0 THEN GOTO DLGO
464 RR=INT(RND(1)*3) : TANG=0.2618 : TRATE=0.005 : IF RR=1 THEN TANG=0.7854
465 IF RR=1 THEN TRATE=0.025
466 IF RR=2 THEN TANG=1.5708
467 IF RR=2 THEN TRATE=0.08
468 IF RND(1)>0.5 THEN PYAW=CUBEYAW+TANG ELSE PYAW=CUBEYAW-TANG
469 DTMR=45+INT(RND(1)*90)
470 GOTO DLGO
471 DLWall:
472 TRATE=0.12 : WALLCD=28 : DTMR=45+INT(RND(1)*90)
473 HLX=PX+COS(CUBEYAW-2.5)*9 : HLZ=PZ+SIN(CUBEYAW-2.5)*9 : LCLR=1
474 IF HLX<5 OR HLX>75 OR HLZ<5 OR HLZ>75 THEN LCLR=0
475 HRX=PX+COS(CUBEYAW+2.5)*9 : HRZ=PZ+SIN(CUBEYAW+2.5)*9 : RCLR=1
476 IF HRX<5 OR HRX>75 OR HRZ<5 OR HRZ>75 THEN RCLR=0
477 WS=1
478 IF LCLR=1 THEN WS=-1
479 IF LCLR=1 AND RCLR=1 AND RND(1)>0.5 THEN WS=1
480 IF LCLR=0 AND RCLR=0 THEN WS=0
481 PYAW=CUBEYAW+WS*2.5
482 IF WS=0 THEN PYAW=CUBEYAW+3.14159
483 GOTO DLGO
484 DLRib:
485 RIBCD=20
486 LJX=PX+COS(CUBEYAW)*3 : LJZ=PZ+SIN(CUBEYAW)*3
487 JRX=INT(LJX/CELL) : JRZ=INT(LJZ/CELL)
488 IF JRX<0 OR JRX>=MZ OR JRZ<0 OR JRZ>=MZ THEN GOTO DLRibTurn
489 IF JRX=MCX AND JRZ=MCZ THEN GOTO DLRibTurn
490 IF TRAIL(JRZ,JRX)=0 THEN GOTO DLRibTurn
491 IF JUMPY<>0 OR JUMPV<>0 THEN GOTO DLRibTurn
492 JUMPV=JUMPV0 : RIBCD=25
493 GOTO DLGO
494 DLRibTurn:
495 TRATE=0.10 : IF RND(1)>0.5 THEN PYAW=CUBEYAW+1.5708 ELSE PYAW=CUBEYAW-1.5708
496 DTMR=45+INT(RND(1)*90)
497 GOTO DLGO
498 DLGO:
499 GAP=PYAW-CUBEYAW : IF ABS(GAP)<=TRATE THEN CUBEYAW=PYAW ELSE CUBEYAW=CUBEYAW+SGN(GAP)*TRATE
500 DX=COS(CUBEYAW)*DSPD : DZ=SIN(CUBEYAW)*DSPD
501 CALL Move
502 JUMPY=JUMPY+JUMPV : JUMPV=JUMPV-GRAV
503 IF JUMPY<0 THEN JUMPY=0
504 IF JUMPY=0 THEN JUMPV=0
505 TRLTICK=TRLTICK+1
506 IF TRLTICK>=1.5 THEN TRLTICK=TRLTICK-1.5 : CALL DropTrail
507 CAMX=PX-COS(CUBEYAW)*CAMDIST : CAMZ=PZ-SIN(CUBEYAW)*CAMDIST
508 GL.CAMERA CAMX,CAMHT,CAMZ : GL.LOOKAT PX,0.6,PZ
509 GL.LIGHTSOFF : GL.RECTLIGHT PX,2.5,PZ, 8,8, 200,215,255, 30
510 GL.TRANSLATE CUBEID, PX, JUMPY-1.1, PZ
511 GL.ROTATE CUBEID, 0, -CUBEYAW*180/PI+CYCOFF, 0
512 CALL DrawMinimap
513 LOCATE 1,1 : PRINT "DEMO   px=" ; INT(PX*10) ; " pz=" ; INT(PZ*10) ; " yaw=" ; INT(CUBEYAW*100) ; " trl=" ; TRLCOUNT ; "    "
514 GL.CLS 2,2,8 : GL.DRAWALL
515 SLEEP 16 : GOTO DemoLoop
