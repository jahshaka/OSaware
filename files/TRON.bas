405 REM ============================================================
406 REM DoTurn - turn handling. TURNMODE 0 = 3-gate mouse chase; 1 = discrete 45/90 deg turns swept fast
407 REM ============================================================
408 SUB DoTurn
409 SHARED PYAW, CUBEYAW, TURNMODE, TURNTGT, D10, D20, TSLOW, TQUICK, DT
410 PI=4*ATN(1) : PI2=PI/2 : PI4=PI/4 : TR=PI*15/180
411 GAP=PYAW-CUBEYAW : G=ABS(GAP)
412 IF TURNMODE=1 THEN GOTO DTTurn
413 TSTEP=TQUICK : IF G<D10 THEN TSTEP=0
414 IF G>=D10 AND G<D20 THEN TSTEP=TSLOW
415 CUBEYAW=CUBEYAW+SGN(GAP)*TSTEP*DT
416 EXIT SUB
417 DTTurn:
418 IF CUBEYAW=TURNTGT AND G>=D20 THEN TURNTGT=CUBEYAW+SGN(GAP)*PI2 : PYAW=TURNTGT
419 IF CUBEYAW=TURNTGT AND G>=D10 AND G<D20 THEN TURNTGT=CUBEYAW+SGN(GAP)*PI4 : PYAW=TURNTGT
420 GAP2=TURNTGT-CUBEYAW : G2=ABS(GAP2)
421 IF G2>TR*DT THEN CUBEYAW=CUBEYAW+SGN(GAP2)*TR*DT ELSE CUBEYAW=TURNTGT
422 END SUB
