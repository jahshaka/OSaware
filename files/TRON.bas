90 REM === Main loop ===
91 MainLoop:
92 K=INKEY
93 REM --- Keyboard: Q/ESC=back to menu  M=map  via SWITCH ---
94 SWITCH(K)
95 CASE 81:
96 CASE 113:
97 CASE 27:
98 GOTO GameOver
99 BREAK
100 CASE 77:
101 CASE 109:
102 CALL ToggleMap
103 BREAK
105 CASE 70:
106 CASE 102:
107 CALL ToggleFog
108 BREAK
109 END SWITCH
110 NOW=TIMER : DT=(NOW-LASTT)/16 : DT=(4+DT-ABS(4-DT))/2 : LASTT=NOW : LASTYAW=CUBEYAW : IF K=84 OR K=116 THEN TURNMODE=1-TURNMODE : TURNTGT=CUBEYAW : PYAW=CUBEYAW
111 MX=MOUSE(1) : DMX=MX-LASTMX : LASTMX=MX : MY=MOUSE(2) : DMY=MY-LASTMY : LASTMY=MY : IF MOUSE(0)<0 AND ABS(DMX)<MAXD THEN PYAW=PYAW+DMX*TSPD : IF MOUSE(0)<0 AND ABS(DMY)<MAXD THEN CAMPITCH=CAMPITCH-DMY*TSPD : IF ABS(CAMPITCH)>PMAX THEN CAMPITCH=SGN(CAMPITCH)*PMAX
112 CALL DoTurn
113 IF K=71 OR K=103 THEN AAON=1-AAON : GL.AA AAON
114 IF ABS(PYAW-CUBEYAW)>D10 THEN SPDCUR=SPEED
115 SPDCUR=SPDCUR+0.0015*DT : IF SPDCUR>0.3 THEN SPDCUR=0.3
116 DX=0 : DZ=0 : IF K=83 OR K=115 THEN FPSON=1-FPSON : GL.FPS FPSON
117 IF KEYDOWN(87) OR KEYDOWN(38) OR AUTORUN=1 THEN DX=COS(CUBEYAW)*SPDCUR*DT : DZ=SIN(CUBEYAW)*SPDCUR*DT
118 IF K=65 OR K=97 THEN AUTORUN=1-AUTORUN
119 IF DX<>0 OR DZ<>0 THEN CALL Move
120 IF DX<>0 OR DZ<>0 THEN MOVING=1 ELSE MOVING=0
121 TRLTICK=TRLTICK+DT
122 IF TRLTICK>=1.5 THEN TRLTICK=TRLTICK-1.5 : CALL DropTrail
123 IF K=67 OR K=99 THEN CAMMODE=CAMMODE+1
124 IF CAMMODE>2 THEN CAMMODE=0
125 CAMX=PX-COS(PYAW)*CAMDIST : CAMZ=PZ-SIN(PYAW)*CAMDIST
126 IF CAMMODE=0 THEN GL.CAMERA CAMX,CAMHT,CAMZ : GL.LOOKAT PX,CAMDIST*CAMPITCH+0.6,PZ
127 IF CAMMODE=1 THEN GL.CAMERA PX-COS(PYAW)*CAMDIST2,CAMHT2,PZ-SIN(PYAW)*CAMDIST2 : GL.LOOKAT PX,CAMDIST2*CAMPITCH+0.1,PZ
128 IF CAMMODE=2 THEN GL.CAMERA PX-COS(CUBEYAW)*0.2,JUMPY-0.6,PZ-SIN(CUBEYAW)*0.2 : GL.LOOKAT PX+COS(CUBEYAW)*10,JUMPY-1.1+10*CAMPITCH,PZ+SIN(CUBEYAW)*10
129 GL.LIGHTSOFF : IF LIGHTON=1 AND WIREMODE=0 THEN GL.RECTLIGHT PX,2.5,PZ, 8,8, 200,215,255, 30
130 IF K=66 OR K=98 THEN BLOOMON=1-BLOOMON : IF BLOOMON=1 THEN GL.BLOOM 0.6 ELSE GL.BLOOM 0
131 GL.TRANSLATE CUBEID, PX, JUMPY-1.1, PZ
132 GL.ROTATE CUBEID, 0, -CUBEYAW*180/PI+CYCOFF, 0
133 CALL DrawMinimap
134 LOCATE 1,1 : PRINT "Speed: " ; INT(SPDCUR*1000) ; "      " : GL.CLS 2,2,8 : GL.DRAWALL
135 REM --- Jump (SPACE): rise to ~2x bike height, then fall back to ground ---
136 IF K=32 AND JUMPV=0 AND JUMPY=0 THEN JUMPV=JUMPV0
137 JUMPY=JUMPY+JUMPV*DT
138 JUMPV=JUMPV-GRAV*DT
139 IF JUMPY<0 THEN JUMPY=0
140 IF JUMPY=0 THEN JUMPV=0
141 IF K=76 OR K=108 THEN LIGHTON=1-LIGHTON
142 IF K=90 OR K=122 THEN WIREMODE=1-WIREMODE : GL.WIREALL WIREMODE
143 SLEEP 16 : GOTO MainLoop
200 END
305 REM InitMinimap - Draw arena borders into pixel buffer once
306 SUB InitMinimap STATIC
307 SHARED MAP, MZ, MSCL, MMX, MMY, MAPVIS
308 MSCL=8 : MAPVIS=1
310 MMX=WIDTH-MZ*MSCL-6 : MMY=HEIGHT-MZ*MSCL-6
312 DELAY 0
313 FOR MR=0 TO MZ-1
314 FOR MC=0 TO MZ-1
315 IF MAP(MR,MC)=1 THEN MC2=7 ELSE MC2=15
317 FOR PR=0 TO MSCL-1
318 FOR PC=0 TO MSCL-1
319 PSET MMX+MC*MSCL+PC, MMY+MR*MSCL+PR, MC2
320 NEXT PC : NEXT PR
322 NEXT MC : NEXT MR
342 END SUB
354 REM DrawMinimap - Move player dot on minimap each frame
355 SUB DrawMinimap STATIC
356 SHARED PX, PZ, CELL, MSCL, MMX, MMY, MAP, MZ, MAPVIS
357 IF MAPVIS=0 THEN EXIT SUB
358 IF INITED=1 THEN GOTO CheckErase
359 OLDMR=-1 : OLDMC=-1 : INITED=1
360 CheckErase:
361 IF OLDMR<0 THEN GOTO DrawDot
362 IF MAP(OLDMR,OLDMC)=1 THEN OC=7 ELSE OC=15
363 FOR PR=0 TO MSCL-1
364 FOR PC=0 TO MSCL-1
365 PSET MMX+OLDMC*MSCL+PC, MMY+OLDMR*MSCL+PR, OC
366 NEXT PC : NEXT PR
367 DrawDot:
368 MR=INT(PZ/CELL) : MC=INT(PX/CELL)
369 OLDMR=MR : OLDMC=MC
370 PDX=MMX+MC*MSCL+INT(MSCL/2) : PDY=MMY+MR*MSCL+INT(MSCL/2)
372 PSET PDX,PDY,14 : PSET PDX+1,PDY,14 : PSET PDX,PDY+1,14 : PSET PDX+1,PDY+1,14
376 END SUB
382 REM ToggleMap - Show / hide minimap overlay
383 SUB ToggleMap STATIC
384 SHARED MAPVIS, MZ, MSCL, MMX, MMY
385 MAPVIS=1-MAPVIS
386 IF MAPVIS=1 THEN CALL InitMinimap : EXIT SUB
388 FOR CR=0 TO MZ*MSCL-1
389 FOR CC=0 TO MZ*MSCL-1
390 PSET MMX+CC, MMY+CR, 16
391 NEXT CC : NEXT CR
393 END SUB
395 REM ToggleFog - Toggle fog on/off
396 SUB ToggleFog STATIC
397 SHARED FOGON
398 FOGON=1-FOGON
399 IF FOGON=1 THEN GL.FOG 2,2,8,15,70
400 IF FOGON=0 THEN GL.FOGOFF
401 END SUB
410 REM UpdateCubeYaw - Cube facing snaps 90 deg once the mouse-look aim (PYAW) crosses 45 deg from it
411 SUB UpdateCubeYaw STATIC
412 SHARED PYAW, CUBEYAW, PI, PX, PZ, TRLID(), TRLCOUNT, TRLPCX, TRLPCZ, TRLTICK
413 DIFF=PYAW-CUBEYAW : TURNED=0
414 IF DIFF>PI*0.25 THEN TURNED=1
415 IF DIFF<0-PI*0.25 THEN TURNED=2
416 IF TURNED=0 THEN EXIT SUB
417 IF TURNED=1 THEN CUBEYAW=CUBEYAW+PI*0.5
418 IF TURNED=2 THEN CUBEYAW=CUBEYAW-PI*0.5
419 TRLTICK=0 : PYAW=CUBEYAW
420 IF ABS(PX-TRLPCX)<0.01 AND ABS(PZ-TRLPCZ)<0.01 THEN EXIT SUB
421 IF TRLCOUNT>=2000 THEN EXIT SUB
422 TRLCOUNT=TRLCOUNT+1
423 GL.SOLID : GL.COLOUR 0,200,255 : GL.SHINE 80 : GL.EMISSIVE 0,80,120 : GL.ALPHA 1.0
424 GL.BEGIN
425 GL.VERTEX TRLPCX,-0.85,TRLPCZ : GL.VERTEX TRLPCX,-1.35,TRLPCZ
426 GL.VERTEX PX,-1.35,PZ : GL.VERTEX PX,-0.85,PZ
427 GL.FACE 1,2,3,4 : GL.FACE 4,3,2,1
428 GL.END
429 TRLID(TRLCOUNT)=GL.MESHID
430 TRLPCX=PX : TRLPCZ=PZ
431 END SUB
502 REM BuildScene - GL init, floor, walls (no ceiling), player cube
503 SUB BuildScene STATIC
504 GL.INIT : GL.PERSPECTIVE 72 : GL.AMBIENT 0.5 : GL.FOG 2,2,8,15,70
510 REM --- Floor: dark blue-black ---
511 FL=16*5.0
512 GL.SOLID : GL.COLOUR 0,0,0 : GL.SHINE 200 : GL.EMISSIVE 0,0,0 : GL.ALPHA 1.0
513 GL.BEGIN
514 GL.VERTEX 0,0,0 : GL.VERTEX FL,0,0 : GL.VERTEX FL,0,FL : GL.VERTEX 0,0,FL
515 GL.FACE 1,2,3,4
516 GL.END
517 SHARED FLOORID
518 FLOORID=GL.MESHID : GL.TRANSLATE FLOORID,0,-1.4,0
519 REM Floor: untextured - plain black for the TRON grid look
520 REM --- Floor grid lines: grey, one per arena cell ---
521 GL.SOLID : GL.COLOUR 120,190,255 : GL.SHINE 10 : GL.EMISSIVE 40,100,200 : GL.ALPHA 1.0
522 GL.BEGIN
523 GLW=0.08 : GCELL=FL/16 : GVN=0
524 FOR GI=0 TO 16
525 GLP=GI*GCELL : GL.VERTEX GLP-GLW,0,0 : GL.VERTEX GLP+GLW,0,0 : GL.VERTEX GLP+GLW,0,FL : GL.VERTEX GLP-GLW,0,FL : GL.FACE GVN+1,GVN+2,GVN+3,GVN+4 : GVN=GVN+4
526 GL.VERTEX 0,0,GLP-GLW : GL.VERTEX FL,0,GLP-GLW : GL.VERTEX FL,0,GLP+GLW : GL.VERTEX 0,0,GLP+GLW : GL.FACE GVN+1,GVN+2,GVN+3,GVN+4 : GVN=GVN+4
527 NEXT GI
528 GL.END
529 GRIDID=GL.MESHID : GL.TRANSLATE GRIDID,0,-1.38,0
530 REM --- Walls: glowing blue TRON look (3x tall) ---
531 SHARED MAP, MZ, CELL
532 FOR WR=0 TO MZ-1
533 FOR WC=0 TO MZ-1
534 IF MAP(WR,WC)=0 THEN GOTO NextWall
535 WX1=WC*CELL : WX2=WX1+CELL : WZ1=WR*CELL : WZ2=WZ1+CELL
537 GL.SOLID : GL.COLOUR 0,80,255 : GL.EMISSIVE 0,50,180 : GL.SHINE 60 : GL.ALPHA 1.0
538 GL.BEGIN
539 GL.VERTEX WX1,-1.4,WZ1 : GL.VERTEX WX2,-1.4,WZ1
540 GL.VERTEX WX2, 7.0,WZ1 : GL.VERTEX WX1, 7.0,WZ1
541 GL.VERTEX WX1,-1.4,WZ2 : GL.VERTEX WX2,-1.4,WZ2
542 GL.VERTEX WX2, 7.0,WZ2 : GL.VERTEX WX1, 7.0,WZ2
543 GL.FACE 1,2,3,4 : GL.FACE 8,7,6,5
544 GL.FACE 5,1,4,8 : GL.FACE 2,6,7,3
545 GL.FACE 5,6,2,1 : GL.FACE 4,3,7,8
546 GL.END
547 NextWall:
548 NEXT WC : NEXT WR
560 REM --- Player: load the Tron lightcycle model (sized to match the old cube) ---
561 GL.LOAD "files/models/LIGHTCYCLE.glb"
562 SHARED CUBEID, TWOP, CUBEID2
563 CUBEID=GL.MESHID
564 GL.SCALE CUBEID, 0.275, 0.275, 0.55
565 IF TWOP=0 THEN GOTO BSNoP2
566 GL.LOAD "files/models/LIGHTCYCLE.glb"
567 CUBEID2=GL.MESHID
568 GL.SCALE CUBEID2, 0.275, 0.275, 0.55
569 BSNoP2:
570 GL.BLOOM 0.6
571 GL.FPS 1 : GL.AA 1
572 END SUB
602 REM Move - Collision-checked player movement
603 SUB Move
604 SHARED PX, PZ, DX, DZ, MZ, CELL, MAP
605 M=0.35 : NX=PX+DX : NZ=PZ+DZ
606 R1=INT((NZ-M)/CELL) : R2=INT((NZ+M)/CELL)
607 C1=INT((NX-M)/CELL) : C2=INT((NX+M)/CELL)
608 IF R1<0 OR R2>=MZ OR C1<0 OR C2>=MZ THEN GOTO SlideX
609 IF MAP(R1,C1)<>0 OR MAP(R1,C2)<>0 OR MAP(R2,C1)<>0 OR MAP(R2,C2)<>0 THEN GOTO SlideX
610 PX=NX : PZ=NZ : EXIT SUB
611 SlideX:
612 NX=PX+DX : NZ=PZ
613 R1=INT((NZ-M)/CELL) : R2=INT((NZ+M)/CELL)
614 C1=INT((NX-M)/CELL) : C2=INT((NX+M)/CELL)
615 IF R1<0 OR R2>=MZ OR C1<0 OR C2>=MZ THEN GOTO SlideZ
616 IF MAP(R1,C1)<>0 OR MAP(R1,C2)<>0 OR MAP(R2,C1)<>0 OR MAP(R2,C2)<>0 THEN GOTO SlideZ
617 PX=NX : EXIT SUB
618 SlideZ:
619 NX=PX : NZ=PZ+DZ
620 R1=INT((NZ-M)/CELL) : R2=INT((NZ+M)/CELL)
621 C1=INT((NX-M)/CELL) : C2=INT((NX+M)/CELL)
622 IF R1<0 OR R2>=MZ OR C1<0 OR C2>=MZ THEN EXIT SUB
623 IF MAP(R1,C1)<>0 OR MAP(R1,C2)<>0 OR MAP(R2,C1)<>0 OR MAP(R2,C2)<>0 THEN EXIT SUB
624 PZ=NZ
625 END SUB
700 REM DropTrail - one ribbon segment as two instanced strips (rails + centre)
701 SUB DropTrail STATIC
702 SHARED PX, PZ, CUBEYAW, TRLCOUNT, TRLPCX, TRLPCZ, JUMPY, TRLPCY, RAILID, CTRID
703 BCX=PX-COS(CUBEYAW)*0.4 : BCZ=PZ-SIN(CUBEYAW)*0.4
704 DOT=(BCX-TRLPCX)*COS(CUBEYAW)+(BCZ-TRLPCZ)*SIN(CUBEYAW)
705 IF DOT<=0 THEN EXIT SUB
707 SDX=BCX-TRLPCX : SDZ=BCZ-TRLPCZ : DY=JUMPY-TRLPCY
708 TRLCOUNT=TRLCOUNT+1
709 GL.INSTANCE RAILID, TRLPCX, TRLPCY-1.10, TRLPCZ, SDX, DY, SDZ
710 GL.INSTANCE CTRID, TRLPCX, TRLPCY-1.10, TRLPCZ, SDX, DY, SDZ
711 TRLPCX=BCX : TRLPCZ=BCZ : TRLPCY=JUMPY
712 END SUB
730 REM BuildWallGrids - white grid on each border wall; columns align to the floor grid
731 SUB BuildWallGrids STATIC
732 SHARED CELL
733 FL=16*CELL : GW=0.08 : YB=-1.4 : YT=7.0
734 GL.SOLID : GL.COLOUR 255,255,255 : GL.SHINE 10 : GL.EMISSIVE 120,120,120 : GL.ALPHA 1.0
735 REM --- North wall: Z=CELL+.05, runs along X ---
736 ZN=CELL+0.05 : GL.BEGIN : VN=0
737 FOR I=0 TO 16
738 XP=I*CELL : GL.VERTEX XP-GW,YB,ZN : GL.VERTEX XP+GW,YB,ZN : GL.VERTEX XP+GW,YT,ZN : GL.VERTEX XP-GW,YT,ZN : GL.FACE VN+1,VN+2,VN+3,VN+4 : VN=VN+4
739 NEXT I
740 FOR J=0 TO 2
741 YP=YB+J*CELL : IF J=2 THEN YP=YT
742 GL.VERTEX 0,YP-GW,ZN : GL.VERTEX FL,YP-GW,ZN : GL.VERTEX FL,YP+GW,ZN : GL.VERTEX 0,YP+GW,ZN : GL.FACE VN+1,VN+2,VN+3,VN+4 : VN=VN+4
743 NEXT J
744 GL.END
745 REM --- South wall: Z=15*CELL-.05 ---
746 ZN=15*CELL-0.05 : GL.BEGIN : VN=0
747 FOR I=0 TO 16
748 XP=I*CELL : GL.VERTEX XP-GW,YB,ZN : GL.VERTEX XP+GW,YB,ZN : GL.VERTEX XP+GW,YT,ZN : GL.VERTEX XP-GW,YT,ZN : GL.FACE VN+1,VN+2,VN+3,VN+4 : VN=VN+4
749 NEXT I
