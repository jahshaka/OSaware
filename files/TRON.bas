71 DIM TRAIL(15,15)
72 DIM RIBWAL(79,79)
73 REM ============================================================
74 REM RIBWAL = 1-unit grid marking cells where P1 has laid blue ribbon. In 2-player mode P2 feels ahead with AvoidRibbon and steers around marked cells (it does not collide). Re-DIMed each run = cleared.
75 REM Build the 3D scene, then branch into the right loop for the chosen mode.
76 REM ============================================================
77 CLS : UI ON : DELAY 0
78 CALL BuildScene
79 CALL BuildWallGrids
80 CALL InitMinimap
81 MAPVIS=1
82 CALL BuildCeiling
83 CALL BuildRibbonTemplates
84 IF TWOP=1 THEN CALL BuildRedRibbon
85 MOUSE ON : LASTMX=MOUSE(1) : LASTT=TIMER : RIB0=GL.MESHID
86 IF DEMO=1 THEN MOUSE OFF : GOTO DemoLoop
87 IF TWOP=1 THEN GOTO TwoPlayerInit
88 REM ============================================================
89 REM  MAIN LOOP  --  single-player gameplay (mouse-steered lightcycle)
90 REM ============================================================
91 MainLoop:
92 K=INKEY
93 REM ============================================================
94 REM Keyboard: Q/ESC=back to menu  M=map  via SWITCH
95 REM ============================================================
96 SWITCH(K)
97 CASE 81:
98 CASE 113:
99 CASE 27:
100 GOTO GameOver
101 BREAK
102 CASE 77:
103 CASE 109:
104 CALL ToggleMap
105 BREAK
106 CASE 70:
107 CASE 102:
108 CALL ToggleFog
109 BREAK
110 END SWITCH
111 NOW=TIMER : DT=(NOW-LASTT)/16 : DT=(4+DT-ABS(4-DT))/2 : LASTT=NOW : LASTYAW=CUBEYAW : IF K=84 OR K=116 THEN TURNMODE=1-TURNMODE : TURNTGT=CUBEYAW : PYAW=CUBEYAW
112 MX=MOUSE(1) : DMX=MX-LASTMX : LASTMX=MX : MY=MOUSE(2) : DMY=MY-LASTMY : LASTMY=MY : IF MOUSE(0)<0 AND ABS(DMX)<MAXD THEN PYAW=PYAW+DMX*TSPD : IF MOUSE(0)<0 AND ABS(DMY)<MAXD THEN CAMPITCH=CAMPITCH-DMY*TSPD : IF ABS(CAMPITCH)>PMAX THEN CAMPITCH=SGN(CAMPITCH)*PMAX
113 CALL DoTurn
114 IF K=71 OR K=103 THEN AAON=1-AAON : GL.AA AAON
115 IF ABS(PYAW-CUBEYAW)>D10 THEN SPDCUR=SPEED
116 SPDCUR=SPDCUR+0.0015*DT : IF SPDCUR>0.3 THEN SPDCUR=0.3
117 DX=0 : DZ=0 : IF K=83 OR K=115 THEN FPSON=1-FPSON : GL.FPS FPSON
118 IF KEYDOWN(87) OR KEYDOWN(38) OR AUTORUN=1 THEN DX=COS(CUBEYAW)*SPDCUR*DT : DZ=SIN(CUBEYAW)*SPDCUR*DT
119 IF K=65 OR K=97 THEN AUTORUN=1-AUTORUN
120 IF DX<>0 OR DZ<>0 THEN CALL Move
121 IF DX<>0 OR DZ<>0 THEN MOVING=1 ELSE MOVING=0
122 TRLTICK=TRLTICK+DT
123 IF TRLTICK>=1.5 THEN TRLTICK=TRLTICK-1.5 : CALL DropTrail
124 IF K=67 OR K=99 THEN CAMMODE=CAMMODE+1
125 IF CAMMODE>2 THEN CAMMODE=0
126 CAMX=PX-COS(PYAW)*CAMDIST : CAMZ=PZ-SIN(PYAW)*CAMDIST
127 IF CAMMODE=0 THEN GL.CAMERA CAMX,CAMHT,CAMZ : GL.LOOKAT PX,CAMDIST*CAMPITCH+0.6,PZ
128 IF CAMMODE=1 THEN GL.CAMERA PX-COS(PYAW)*CAMDIST2,CAMHT2,PZ-SIN(PYAW)*CAMDIST2 : GL.LOOKAT PX,CAMDIST2*CAMPITCH+0.1,PZ
129 IF CAMMODE=2 THEN GL.CAMERA PX-COS(CUBEYAW)*0.2,JUMPY-0.6,PZ-SIN(CUBEYAW)*0.2 : GL.LOOKAT PX+COS(CUBEYAW)*10,JUMPY-1.1+10*CAMPITCH,PZ+SIN(CUBEYAW)*10
130 GL.LIGHTSOFF : IF LIGHTON=1 AND WIREMODE=0 THEN GL.RECTLIGHT PX,2.5,PZ, 8,8, 200,215,255, 30
131 IF K=66 OR K=98 THEN BLOOMON=1-BLOOMON : IF BLOOMON=1 THEN GL.BLOOM 0.6 ELSE GL.BLOOM 0
132 GL.TRANSLATE CUBEID, PX, JUMPY-1.1, PZ
133 GL.ROTATE CUBEID, 0, -CUBEYAW*180/PI+CYCOFF, 0
134 CALL DrawMinimap
135 LOCATE 1,1 : PRINT "Speed: " ; INT(SPDCUR*1000) ; "      " : GL.CLS 2,2,8 : GL.DRAWALL
136 REM ============================================================
137 REM Jump (SPACE): rise to ~2x bike height, then fall back to ground
138 REM ============================================================
139 IF K=32 AND JUMPV=0 AND JUMPY=0 THEN JUMPV=JUMPV0
140 JUMPY=JUMPY+JUMPV*DT
141 JUMPV=JUMPV-GRAV*DT
142 IF JUMPY<0 THEN JUMPY=0
143 IF JUMPY=0 THEN JUMPV=0
144 IF K=76 OR K=108 THEN LIGHTON=1-LIGHTON
145 IF K=90 OR K=122 THEN WIREMODE=1-WIREMODE : GL.WIREALL WIREMODE
146 SLEEP 16 : GOTO MainLoop
147 REM ============================================================
148 REM Fall-through guard: nothing below this line is reached except via GOTO/GOSUB/CALL.
149 REM ============================================================
150 END
151 REM ============================================================
152 REM  SUBROUTINES  --  shared by MAIN LOOP, DEMO LOOP and 2-PLAYER LOOP
153 REM InitMinimap - Draw arena borders into pixel buffer once
154 REM ============================================================
155 SUB InitMinimap STATIC
156 SHARED MAP, MZ, MSCL, MMX, MMY, MAPVIS
157 MSCL=8 : MAPVIS=1
158 MMX=WIDTH-MZ*MSCL-6 : MMY=HEIGHT-MZ*MSCL-6
159 DELAY 0
160 FOR MR=0 TO MZ-1
161 FOR MC=0 TO MZ-1
162 IF MAP(MR,MC)=1 THEN MC2=7 ELSE MC2=15
163 FOR PR=0 TO MSCL-1
164 FOR PC=0 TO MSCL-1
165 PSET MMX+MC*MSCL+PC, MMY+MR*MSCL+PR, MC2
166 NEXT PC : NEXT PR
167 NEXT MC : NEXT MR
168 END SUB
169 REM ============================================================
170 REM DrawMinimap - Move player dot on minimap each frame
171 REM ============================================================
172 SUB DrawMinimap STATIC
173 SHARED PX, PZ, CELL, MSCL, MMX, MMY, MAP, MZ, MAPVIS
174 IF MAPVIS=0 THEN EXIT SUB
175 IF INITED=1 THEN GOTO CheckErase
176 OLDMR=-1 : OLDMC=-1 : INITED=1
177 CheckErase:
178 IF OLDMR<0 THEN GOTO DrawDot
179 IF MAP(OLDMR,OLDMC)=1 THEN OC=7 ELSE OC=15
180 FOR PR=0 TO MSCL-1
181 FOR PC=0 TO MSCL-1
182 PSET MMX+OLDMC*MSCL+PC, MMY+OLDMR*MSCL+PR, OC
183 NEXT PC : NEXT PR
184 DrawDot:
185 MR=INT(PZ/CELL) : MC=INT(PX/CELL)
186 OLDMR=MR : OLDMC=MC
187 PDX=MMX+MC*MSCL+INT(MSCL/2) : PDY=MMY+MR*MSCL+INT(MSCL/2)
188 PSET PDX,PDY,14 : PSET PDX+1,PDY,14 : PSET PDX,PDY+1,14 : PSET PDX+1,PDY+1,14
189 END SUB
190 REM ============================================================
191 REM ToggleMap - Show / hide minimap overlay
192 REM ============================================================
193 SUB ToggleMap STATIC
194 SHARED MAPVIS, MZ, MSCL, MMX, MMY
195 MAPVIS=1-MAPVIS
196 IF MAPVIS=1 THEN CALL InitMinimap : EXIT SUB
197 FOR CR=0 TO MZ*MSCL-1
198 FOR CC=0 TO MZ*MSCL-1
199 PSET MMX+CC, MMY+CR, 16
200 NEXT CC : NEXT CR
201 END SUB
202 REM ============================================================
203 REM ToggleFog - Toggle fog on/off
204 REM ============================================================
205 SUB ToggleFog STATIC
206 SHARED FOGON
207 FOGON=1-FOGON
208 IF FOGON=1 THEN GL.FOG 2,2,8,15,70
209 IF FOGON=0 THEN GL.FOGOFF
210 END SUB
211 REM ============================================================
212 REM UpdateCubeYaw - Cube facing snaps 90 deg once the mouse-look aim (PYAW) crosses 45 deg from it
213 REM ============================================================
214 SUB UpdateCubeYaw STATIC
215 SHARED PYAW, CUBEYAW, PI, PX, PZ, TRLID(), TRLCOUNT, TRLPCX, TRLPCZ, TRLTICK
216 DIFF=PYAW-CUBEYAW : TURNED=0
217 IF DIFF>PI*0.25 THEN TURNED=1
218 IF DIFF<0-PI*0.25 THEN TURNED=2
219 IF TURNED=0 THEN EXIT SUB
220 IF TURNED=1 THEN CUBEYAW=CUBEYAW+PI*0.5
221 IF TURNED=2 THEN CUBEYAW=CUBEYAW-PI*0.5
222 TRLTICK=0 : PYAW=CUBEYAW
223 IF ABS(PX-TRLPCX)<0.01 AND ABS(PZ-TRLPCZ)<0.01 THEN EXIT SUB
224 IF TRLCOUNT>=2000 THEN EXIT SUB
225 TRLCOUNT=TRLCOUNT+1
226 GL.SOLID : GL.COLOUR 0,200,255 : GL.SHINE 80 : GL.EMISSIVE 0,80,120 : GL.ALPHA 1.0
227 GL.BEGIN
228 GL.VERTEX TRLPCX,-0.85,TRLPCZ : GL.VERTEX TRLPCX,-1.35,TRLPCZ
229 GL.VERTEX PX,-1.35,PZ : GL.VERTEX PX,-0.85,PZ
230 GL.FACE 1,2,3,4 : GL.FACE 4,3,2,1
231 GL.END
232 TRLID(TRLCOUNT)=GL.MESHID
233 TRLPCX=PX : TRLPCZ=PZ
234 END SUB
235 REM ============================================================
236 REM BuildScene - GL init, floor, walls (no ceiling), player cube
237 REM ============================================================
238 SUB BuildScene STATIC
239 GL.INIT : GL.PERSPECTIVE 72 : GL.AMBIENT 0.5 : GL.FOG 2,2,8,15,70
240 REM ============================================================
241 REM Floor: dark blue-black
242 REM ============================================================
243 FL=16*5.0
244 GL.SOLID : GL.COLOUR 0,0,0 : GL.SHINE 200 : GL.EMISSIVE 0,0,0 : GL.ALPHA 1.0
245 GL.BEGIN
246 GL.VERTEX 0,0,0 : GL.VERTEX FL,0,0 : GL.VERTEX FL,0,FL : GL.VERTEX 0,0,FL
247 GL.FACE 1,2,3,4
248 GL.END
249 SHARED FLOORID
250 FLOORID=GL.MESHID : GL.TRANSLATE FLOORID,0,-1.4,0
251 REM ============================================================
252 REM Floor: untextured - plain black for the TRON grid look
253 REM Floor grid lines: grey, one per arena cell
254 REM ============================================================
255 GL.SOLID : GL.COLOUR 120,190,255 : GL.SHINE 10 : GL.EMISSIVE 40,100,200 : GL.ALPHA 1.0
256 GL.BEGIN
257 GLW=0.08 : GCELL=FL/16 : GVN=0
258 FOR GI=0 TO 16
259 GLP=GI*GCELL : GL.VERTEX GLP-GLW,0,0 : GL.VERTEX GLP+GLW,0,0 : GL.VERTEX GLP+GLW,0,FL : GL.VERTEX GLP-GLW,0,FL : GL.FACE GVN+1,GVN+2,GVN+3,GVN+4 : GVN=GVN+4
260 GL.VERTEX 0,0,GLP-GLW : GL.VERTEX FL,0,GLP-GLW : GL.VERTEX FL,0,GLP+GLW : GL.VERTEX 0,0,GLP+GLW : GL.FACE GVN+1,GVN+2,GVN+3,GVN+4 : GVN=GVN+4
261 NEXT GI
262 GL.END
263 GRIDID=GL.MESHID : GL.TRANSLATE GRIDID,0,-1.38,0
264 REM ============================================================
265 REM Walls: glowing blue TRON look (3x tall)
266 REM ============================================================
267 SHARED MAP, MZ, CELL
268 FOR WR=0 TO MZ-1
269 FOR WC=0 TO MZ-1
270 IF MAP(WR,WC)=0 THEN GOTO NextWall
271 WX1=WC*CELL : WX2=WX1+CELL : WZ1=WR*CELL : WZ2=WZ1+CELL
272 GL.SOLID : GL.COLOUR 0,80,255 : GL.EMISSIVE 0,50,180 : GL.SHINE 60 : GL.ALPHA 1.0
273 GL.BEGIN
274 GL.VERTEX WX1,-1.4,WZ1 : GL.VERTEX WX2,-1.4,WZ1
275 GL.VERTEX WX2, 7.0,WZ1 : GL.VERTEX WX1, 7.0,WZ1
276 GL.VERTEX WX1,-1.4,WZ2 : GL.VERTEX WX2,-1.4,WZ2
277 GL.VERTEX WX2, 7.0,WZ2 : GL.VERTEX WX1, 7.0,WZ2
278 GL.FACE 1,2,3,4 : GL.FACE 8,7,6,5
279 GL.FACE 5,1,4,8 : GL.FACE 2,6,7,3
280 GL.FACE 5,6,2,1 : GL.FACE 4,3,7,8
281 GL.END
282 NextWall:
283 NEXT WC : NEXT WR
284 REM ============================================================
285 REM Player: load the Tron lightcycle model (sized to match the old cube)
286 REM ============================================================
287 GL.LOAD "files/models/LIGHTCYCLE.glb"
288 SHARED CUBEID, TWOP, CUBEID2
289 CUBEID=GL.MESHID
290 GL.SCALE CUBEID, 0.275, 0.275, 0.55
291 IF TWOP=0 THEN GOTO BSNoP2
292 GL.LOAD "files/models/LIGHTCYCLE.glb"
293 CUBEID2=GL.MESHID
294 GL.SCALE CUBEID2, 0.275, 0.275, 0.55
295 BSNoP2:
296 GL.BLOOM 0.6
297 GL.FPS 1 : GL.AA 1
298 END SUB
299 REM ============================================================
300 REM Move - Collision-checked player movement
301 REM ============================================================
302 SUB Move
303 SHARED PX, PZ, DX, DZ, MZ, CELL, MAP
304 M=0.35 : NX=PX+DX : NZ=PZ+DZ
305 R1=INT((NZ-M)/CELL) : R2=INT((NZ+M)/CELL)
306 C1=INT((NX-M)/CELL) : C2=INT((NX+M)/CELL)
307 IF R1<0 OR R2>=MZ OR C1<0 OR C2>=MZ THEN GOTO SlideX
308 IF MAP(R1,C1)<>0 OR MAP(R1,C2)<>0 OR MAP(R2,C1)<>0 OR MAP(R2,C2)<>0 THEN GOTO SlideX
309 PX=NX : PZ=NZ : EXIT SUB
310 SlideX:
311 NX=PX+DX : NZ=PZ
312 R1=INT((NZ-M)/CELL) : R2=INT((NZ+M)/CELL)
313 C1=INT((NX-M)/CELL) : C2=INT((NX+M)/CELL)
314 IF R1<0 OR R2>=MZ OR C1<0 OR C2>=MZ THEN GOTO SlideZ
315 IF MAP(R1,C1)<>0 OR MAP(R1,C2)<>0 OR MAP(R2,C1)<>0 OR MAP(R2,C2)<>0 THEN GOTO SlideZ
316 PX=NX : EXIT SUB
317 SlideZ:
318 NX=PX : NZ=PZ+DZ
319 R1=INT((NZ-M)/CELL) : R2=INT((NZ+M)/CELL)
320 C1=INT((NX-M)/CELL) : C2=INT((NX+M)/CELL)
321 IF R1<0 OR R2>=MZ OR C1<0 OR C2>=MZ THEN EXIT SUB
322 IF MAP(R1,C1)<>0 OR MAP(R1,C2)<>0 OR MAP(R2,C1)<>0 OR MAP(R2,C2)<>0 THEN EXIT SUB
323 PZ=NZ
324 END SUB
325 REM ============================================================
326 REM DropTrail - one ribbon segment as two instanced strips (rails + centre)
327 REM ============================================================
328 SUB DropTrail STATIC
329 SHARED PX, PZ, CUBEYAW, TRLCOUNT, TRLPCX, TRLPCZ, JUMPY, TRLPCY, RAILID, CTRID
330 BCX=PX-COS(CUBEYAW)*0.4 : BCZ=PZ-SIN(CUBEYAW)*0.4
331 DOT=(BCX-TRLPCX)*COS(CUBEYAW)+(BCZ-TRLPCZ)*SIN(CUBEYAW)
332 IF DOT<=0 THEN EXIT SUB
333 SDX=BCX-TRLPCX : SDZ=BCZ-TRLPCZ : DY=JUMPY-TRLPCY
334 TRLCOUNT=TRLCOUNT+1
335 GL.INSTANCE RAILID, TRLPCX, TRLPCY-1.10, TRLPCZ, SDX, DY, SDZ
336 GL.INSTANCE CTRID, TRLPCX, TRLPCY-1.10, TRLPCZ, SDX, DY, SDZ
337 TRLPCX=BCX : TRLPCZ=BCZ : TRLPCY=JUMPY
338 END SUB
