2610 REM Player + trail + minimap state. RIBWAL is the 1-unit grid of P1 ribbon cells (2-player uses it for AI avoidance).
2620 PX=CELL*8 : PZ=CELL*8
2630 PYAW=0 : CUBEYAW=0 : MOVING=0 : CAMMODE=0 : AUTORUN=0 : JUMPY=0 : JUMPV=0 : LIGHTON=1 : WIREMODE=0 : CAMPITCH=0 : BLOOMON=1 : FPSON=1 : TURNMODE=0 : TURNTGT=0 : AAON=1 : SPDCUR=SPEED
2640 DIM TRLID(2000)
2650 TRLCOUNT=0 : TRLTICK=0 : TRLPCX=PX-0.4 : TRLPCZ=PZ : TRLPCY=0 : DFRM=0 : DTMR=40 : IF DEMO=1 THEN AUTORUN=1
2660 DIM TRAIL(15,15)
2670 DIM RIBWAL(79,79)
2680 REM RIBWAL = 1-unit grid marking cells where P1 has laid blue ribbon. In 2-player mode P2 feels ahead with AvoidRibbon and steers around marked cells (it does not collide). Re-DIMed each run = cleared.
2710 REM Build the 3D scene, then branch into the right loop for the chosen mode.
2720 CLS : UI ON : DELAY 0
2730 CALL BuildScene
2740 CALL BuildWallGrids
2750 CALL InitMinimap
2760 MAPVIS=1
2770 CALL BuildCeiling
2780 CALL BuildRibbonTemplates
2790 IF TWOP=1 THEN CALL BuildRedRibbon
2800 MOUSE ON : LASTMX=MOUSE(1) : LASTT=TIMER : RIB0=GL.MESHID
2810 IF DEMO=1 THEN GOTO DemoLoop
2820 IF TWOP=1 THEN GOTO TwoPlayerInit
3010 REM ============================================================
3020 REM  MAIN LOOP  --  single-player gameplay (mouse-steered lightcycle)
3030 REM ============================================================
3040 MainLoop:
3050 K=INKEY
3060 REM --- Keyboard: Q/ESC=back to menu  M=map  via SWITCH ---
3070 SWITCH(K)
3080 CASE 81:
3090 CASE 113:
3100 CASE 27:
3110 GOTO GameOver
3120 BREAK
3130 CASE 77:
3140 CASE 109:
3150 CALL ToggleMap
3160 BREAK
3170 CASE 70:
3180 CASE 102:
3190 CALL ToggleFog
3200 BREAK
3210 END SWITCH
3220 NOW=TIMER : DT=(NOW-LASTT)/16 : DT=(4+DT-ABS(4-DT))/2 : LASTT=NOW : LASTYAW=CUBEYAW : IF K=84 OR K=116 THEN TURNMODE=1-TURNMODE : TURNTGT=CUBEYAW : PYAW=CUBEYAW
3230 MX=MOUSE(1) : DMX=MX-LASTMX : LASTMX=MX : MY=MOUSE(2) : DMY=MY-LASTMY : LASTMY=MY : IF MOUSE(0)<0 AND ABS(DMX)<MAXD THEN PYAW=PYAW+DMX*TSPD : IF MOUSE(0)<0 AND ABS(DMY)<MAXD THEN CAMPITCH=CAMPITCH-DMY*TSPD : IF ABS(CAMPITCH)>PMAX THEN CAMPITCH=SGN(CAMPITCH)*PMAX
3240 CALL DoTurn
3250 IF K=71 OR K=103 THEN AAON=1-AAON : GL.AA AAON
3260 IF ABS(PYAW-CUBEYAW)>D10 THEN SPDCUR=SPEED
3270 SPDCUR=SPDCUR+0.0015*DT : IF SPDCUR>0.3 THEN SPDCUR=0.3
3280 DX=0 : DZ=0 : IF K=83 OR K=115 THEN FPSON=1-FPSON : GL.FPS FPSON
3290 IF KEYDOWN(87) OR KEYDOWN(38) OR AUTORUN=1 THEN DX=COS(CUBEYAW)*SPDCUR*DT : DZ=SIN(CUBEYAW)*SPDCUR*DT
3300 IF K=65 OR K=97 THEN AUTORUN=1-AUTORUN
3310 IF DX<>0 OR DZ<>0 THEN CALL Move
3320 IF DX<>0 OR DZ<>0 THEN MOVING=1 ELSE MOVING=0
3330 TRLTICK=TRLTICK+DT
3340 IF TRLTICK>=1.5 THEN TRLTICK=TRLTICK-1.5 : CALL DropTrail
3350 IF K=67 OR K=99 THEN CAMMODE=CAMMODE+1
3360 IF CAMMODE>2 THEN CAMMODE=0
3370 CAMX=PX-COS(PYAW)*CAMDIST : CAMZ=PZ-SIN(PYAW)*CAMDIST
3380 IF CAMMODE=0 THEN GL.CAMERA CAMX,CAMHT,CAMZ : GL.LOOKAT PX,CAMDIST*CAMPITCH+0.6,PZ
3390 IF CAMMODE=1 THEN GL.CAMERA PX-COS(PYAW)*CAMDIST2,CAMHT2,PZ-SIN(PYAW)*CAMDIST2 : GL.LOOKAT PX,CAMDIST2*CAMPITCH+0.1,PZ
3400 IF CAMMODE=2 THEN GL.CAMERA PX-COS(CUBEYAW)*0.2,JUMPY-0.6,PZ-SIN(CUBEYAW)*0.2 : GL.LOOKAT PX+COS(CUBEYAW)*10,JUMPY-1.1+10*CAMPITCH,PZ+SIN(CUBEYAW)*10
3410 GL.LIGHTSOFF : IF LIGHTON=1 AND WIREMODE=0 THEN GL.RECTLIGHT PX,2.5,PZ, 8,8, 200,215,255, 30
3420 IF K=66 OR K=98 THEN BLOOMON=1-BLOOMON : IF BLOOMON=1 THEN GL.BLOOM 0.6 ELSE GL.BLOOM 0
3430 GL.TRANSLATE CUBEID, PX, JUMPY-1.1, PZ
3440 GL.ROTATE CUBEID, 0, -CUBEYAW*180/PI+CYCOFF, 0
3450 CALL DrawMinimap
3460 LOCATE 1,1 : PRINT "Speed: " ; INT(SPDCUR*1000) ; "      " : GL.CLS 2,2,8 : GL.DRAWALL
3470 REM --- Jump (SPACE): rise to ~2x bike height, then fall back to ground ---
3480 IF K=32 AND JUMPV=0 AND JUMPY=0 THEN JUMPV=JUMPV0
3490 JUMPY=JUMPY+JUMPV*DT
3500 JUMPV=JUMPV-GRAV*DT
3510 IF JUMPY<0 THEN JUMPY=0
3520 IF JUMPY=0 THEN JUMPV=0
3530 IF K=76 OR K=108 THEN LIGHTON=1-LIGHTON
3540 IF K=90 OR K=122 THEN WIREMODE=1-WIREMODE : GL.WIREALL WIREMODE
3550 SLEEP 16 : GOTO MainLoop
3610 REM Fall-through guard: nothing below this line is reached except via GOTO/GOSUB/CALL.
3620 END
4010 REM ============================================================
4020 REM  SUBROUTINES  --  shared by MAIN LOOP, DEMO LOOP and 2-PLAYER LOOP
4030 REM ============================================================
4110 REM InitMinimap - Draw arena borders into pixel buffer once
4120 SUB InitMinimap STATIC
4130 SHARED MAP, MZ, MSCL, MMX, MMY, MAPVIS
4140 MSCL=8 : MAPVIS=1
4150 MMX=WIDTH-MZ*MSCL-6 : MMY=HEIGHT-MZ*MSCL-6
4160 DELAY 0
4170 FOR MR=0 TO MZ-1
4180 FOR MC=0 TO MZ-1
4190 IF MAP(MR,MC)=1 THEN MC2=7 ELSE MC2=15
4200 FOR PR=0 TO MSCL-1
4210 FOR PC=0 TO MSCL-1
4220 PSET MMX+MC*MSCL+PC, MMY+MR*MSCL+PR, MC2
4230 NEXT PC : NEXT PR
4240 NEXT MC : NEXT MR
4250 END SUB
4310 REM DrawMinimap - Move player dot on minimap each frame
4320 SUB DrawMinimap STATIC
4330 SHARED PX, PZ, CELL, MSCL, MMX, MMY, MAP, MZ, MAPVIS
4340 IF MAPVIS=0 THEN EXIT SUB
4350 IF INITED=1 THEN GOTO CheckErase
4360 OLDMR=-1 : OLDMC=-1 : INITED=1
4370 CheckErase:
4380 IF OLDMR<0 THEN GOTO DrawDot
4390 IF MAP(OLDMR,OLDMC)=1 THEN OC=7 ELSE OC=15
4400 FOR PR=0 TO MSCL-1
4410 FOR PC=0 TO MSCL-1
4420 PSET MMX+OLDMC*MSCL+PC, MMY+OLDMR*MSCL+PR, OC
4430 NEXT PC : NEXT PR
4440 DrawDot:
4450 MR=INT(PZ/CELL) : MC=INT(PX/CELL)
4460 OLDMR=MR : OLDMC=MC
4470 PDX=MMX+MC*MSCL+INT(MSCL/2) : PDY=MMY+MR*MSCL+INT(MSCL/2)
4480 PSET PDX,PDY,14 : PSET PDX+1,PDY,14 : PSET PDX,PDY+1,14 : PSET PDX+1,PDY+1,14
4490 END SUB
4510 REM ToggleMap - Show / hide minimap overlay
4520 SUB ToggleMap STATIC
4530 SHARED MAPVIS, MZ, MSCL, MMX, MMY
4540 MAPVIS=1-MAPVIS
4550 IF MAPVIS=1 THEN CALL InitMinimap : EXIT SUB
4560 FOR CR=0 TO MZ*MSCL-1
4570 FOR CC=0 TO MZ*MSCL-1
4580 PSET MMX+CC, MMY+CR, 16
4590 NEXT CC : NEXT CR
4600 END SUB
4710 REM ToggleFog - Toggle fog on/off
4720 SUB ToggleFog STATIC
4730 SHARED FOGON
4740 FOGON=1-FOGON
4750 IF FOGON=1 THEN GL.FOG 2,2,8,15,70
4760 IF FOGON=0 THEN GL.FOGOFF
4770 END SUB
4810 REM UpdateCubeYaw - Cube facing snaps 90 deg once the mouse-look aim (PYAW) crosses 45 deg from it
4820 SUB UpdateCubeYaw STATIC
4830 SHARED PYAW, CUBEYAW, PI, PX, PZ, TRLID(), TRLCOUNT, TRLPCX, TRLPCZ, TRLTICK
4840 DIFF=PYAW-CUBEYAW : TURNED=0
4850 IF DIFF>PI*0.25 THEN TURNED=1
4860 IF DIFF<0-PI*0.25 THEN TURNED=2
4870 IF TURNED=0 THEN EXIT SUB
4880 IF TURNED=1 THEN CUBEYAW=CUBEYAW+PI*0.5
4890 IF TURNED=2 THEN CUBEYAW=CUBEYAW-PI*0.5
4900 TRLTICK=0 : PYAW=CUBEYAW
4910 IF ABS(PX-TRLPCX)<0.01 AND ABS(PZ-TRLPCZ)<0.01 THEN EXIT SUB
4920 IF TRLCOUNT>=2000 THEN EXIT SUB
4930 TRLCOUNT=TRLCOUNT+1
4940 GL.SOLID : GL.COLOUR 0,200,255 : GL.SHINE 80 : GL.EMISSIVE 0,80,120 : GL.ALPHA 1.0
4950 GL.BEGIN
4960 GL.VERTEX TRLPCX,-0.85,TRLPCZ : GL.VERTEX TRLPCX,-1.35,TRLPCZ
4970 GL.VERTEX PX,-1.35,PZ : GL.VERTEX PX,-0.85,PZ
4980 GL.FACE 1,2,3,4 : GL.FACE 4,3,2,1
4990 GL.END
5000 TRLID(TRLCOUNT)=GL.MESHID
5010 TRLPCX=PX : TRLPCZ=PZ
5020 END SUB
5110 REM BuildScene - GL init, floor, walls (no ceiling), player cube
5120 SUB BuildScene STATIC
5130 GL.INIT : GL.PERSPECTIVE 72 : GL.AMBIENT 0.5 : GL.FOG 2,2,8,15,70
5140 REM --- Floor: dark blue-black ---
5150 FL=16*5.0
5160 GL.SOLID : GL.COLOUR 0,0,0 : GL.SHINE 200 : GL.EMISSIVE 0,0,0 : GL.ALPHA 1.0
5170 GL.BEGIN
5180 GL.VERTEX 0,0,0 : GL.VERTEX FL,0,0 : GL.VERTEX FL,0,FL : GL.VERTEX 0,0,FL
5190 GL.FACE 1,2,3,4
5200 GL.END
5210 SHARED FLOORID
5220 FLOORID=GL.MESHID : GL.TRANSLATE FLOORID,0,-1.4,0
5230 REM Floor: untextured - plain black for the TRON grid look
5240 REM --- Floor grid lines: grey, one per arena cell ---
5250 GL.SOLID : GL.COLOUR 120,190,255 : GL.SHINE 10 : GL.EMISSIVE 40,100,200 : GL.ALPHA 1.0
5260 GL.BEGIN
5270 GLW=0.08 : GCELL=FL/16 : GVN=0
5280 FOR GI=0 TO 16
5290 GLP=GI*GCELL : GL.VERTEX GLP-GLW,0,0 : GL.VERTEX GLP+GLW,0,0 : GL.VERTEX GLP+GLW,0,FL : GL.VERTEX GLP-GLW,0,FL : GL.FACE GVN+1,GVN+2,GVN+3,GVN+4 : GVN=GVN+4
5300 GL.VERTEX 0,0,GLP-GLW : GL.VERTEX FL,0,GLP-GLW : GL.VERTEX FL,0,GLP+GLW : GL.VERTEX 0,0,GLP+GLW : GL.FACE GVN+1,GVN+2,GVN+3,GVN+4 : GVN=GVN+4
5310 NEXT GI
5320 GL.END
5330 GRIDID=GL.MESHID : GL.TRANSLATE GRIDID,0,-1.38,0
5340 REM --- Walls: glowing blue TRON look (3x tall) ---
5350 SHARED MAP, MZ, CELL
5360 FOR WR=0 TO MZ-1
5370 FOR WC=0 TO MZ-1
5380 IF MAP(WR,WC)=0 THEN GOTO NextWall
5390 WX1=WC*CELL : WX2=WX1+CELL : WZ1=WR*CELL : WZ2=WZ1+CELL
5400 GL.SOLID : GL.COLOUR 0,80,255 : GL.EMISSIVE 0,50,180 : GL.SHINE 60 : GL.ALPHA 1.0
5410 GL.BEGIN
5420 GL.VERTEX WX1,-1.4,WZ1 : GL.VERTEX WX2,-1.4,WZ1
5430 GL.VERTEX WX2, 7.0,WZ1 : GL.VERTEX WX1, 7.0,WZ1
5440 GL.VERTEX WX1,-1.4,WZ2 : GL.VERTEX WX2,-1.4,WZ2
5450 GL.VERTEX WX2, 7.0,WZ2 : GL.VERTEX WX1, 7.0,WZ2
5460 GL.FACE 1,2,3,4 : GL.FACE 8,7,6,5
5470 GL.FACE 5,1,4,8 : GL.FACE 2,6,7,3
5480 GL.FACE 5,6,2,1 : GL.FACE 4,3,7,8
5490 GL.END
5500 NextWall:
5510 NEXT WC : NEXT WR
5520 REM --- Player: load the Tron lightcycle model (sized to match the old cube) ---
5530 GL.LOAD "files/models/LIGHTCYCLE.glb"
5540 SHARED CUBEID, TWOP, CUBEID2
5550 CUBEID=GL.MESHID
5560 GL.SCALE CUBEID, 0.275, 0.275, 0.55
5570 IF TWOP=0 THEN GOTO BSNoP2
5580 GL.LOAD "files/models/LIGHTCYCLE.glb"
5590 CUBEID2=GL.MESHID
5600 GL.SCALE CUBEID2, 0.275, 0.275, 0.55
5610 BSNoP2:
5620 GL.BLOOM 0.6
5630 GL.FPS 1 : GL.AA 1
5640 END SUB
5710 REM Move - Collision-checked player movement
5720 SUB Move
5730 SHARED PX, PZ, DX, DZ, MZ, CELL, MAP
5740 M=0.35 : NX=PX+DX : NZ=PZ+DZ
5750 R1=INT((NZ-M)/CELL) : R2=INT((NZ+M)/CELL)
5760 C1=INT((NX-M)/CELL) : C2=INT((NX+M)/CELL)
5770 IF R1<0 OR R2>=MZ OR C1<0 OR C2>=MZ THEN GOTO SlideX
5780 IF MAP(R1,C1)<>0 OR MAP(R1,C2)<>0 OR MAP(R2,C1)<>0 OR MAP(R2,C2)<>0 THEN GOTO SlideX
5790 PX=NX : PZ=NZ : EXIT SUB
5800 SlideX:
5810 NX=PX+DX : NZ=PZ
5820 R1=INT((NZ-M)/CELL) : R2=INT((NZ+M)/CELL)
5830 C1=INT((NX-M)/CELL) : C2=INT((NX+M)/CELL)
5840 IF R1<0 OR R2>=MZ OR C1<0 OR C2>=MZ THEN GOTO SlideZ
5850 IF MAP(R1,C1)<>0 OR MAP(R1,C2)<>0 OR MAP(R2,C1)<>0 OR MAP(R2,C2)<>0 THEN GOTO SlideZ
5860 PX=NX : EXIT SUB
5870 SlideZ:
5880 NX=PX : NZ=PZ+DZ
5890 R1=INT((NZ-M)/CELL) : R2=INT((NZ+M)/CELL)
5900 C1=INT((NX-M)/CELL) : C2=INT((NX+M)/CELL)
5910 IF R1<0 OR R2>=MZ OR C1<0 OR C2>=MZ THEN EXIT SUB
5920 IF MAP(R1,C1)<>0 OR MAP(R1,C2)<>0 OR MAP(R2,C1)<>0 OR MAP(R2,C2)<>0 THEN EXIT SUB
5930 PZ=NZ
5940 END SUB
6010 REM DropTrail - one ribbon segment as two instanced strips (rails + centre)
6020 SUB DropTrail STATIC
6030 SHARED PX, PZ, CUBEYAW, TRLCOUNT, TRLPCX, TRLPCZ, JUMPY, TRLPCY, RAILID, CTRID
6040 BCX=PX-COS(CUBEYAW)*0.4 : BCZ=PZ-SIN(CUBEYAW)*0.4
6050 DOT=(BCX-TRLPCX)*COS(CUBEYAW)+(BCZ-TRLPCZ)*SIN(CUBEYAW)
6060 IF DOT<=0 THEN EXIT SUB
6070 SDX=BCX-TRLPCX : SDZ=BCZ-TRLPCZ : DY=JUMPY-TRLPCY
6080 TRLCOUNT=TRLCOUNT+1
6090 GL.INSTANCE RAILID, TRLPCX, TRLPCY-1.10, TRLPCZ, SDX, DY, SDZ
6100 GL.INSTANCE CTRID, TRLPCX, TRLPCY-1.10, TRLPCZ, SDX, DY, SDZ
6110 TRLPCX=BCX : TRLPCZ=BCZ : TRLPCY=JUMPY
6120 END SUB
6210 REM BuildWallGrids - white grid on each border wall; columns align to the floor grid
6220 SUB BuildWallGrids STATIC
6230 SHARED CELL
6240 FL=16*CELL : GW=0.08 : YB=-1.4 : YT=7.0
6250 GL.SOLID : GL.COLOUR 255,255,255 : GL.SHINE 10 : GL.EMISSIVE 120,120,120 : GL.ALPHA 1.0
6260 REM --- North wall: Z=CELL+.05, runs along X ---
6270 ZN=CELL+0.05 : GL.BEGIN : VN=0
6280 FOR I=0 TO 16
6290 XP=I*CELL : GL.VERTEX XP-GW,YB,ZN : GL.VERTEX XP+GW,YB,ZN : GL.VERTEX XP+GW,YT,ZN : GL.VERTEX XP-GW,YT,ZN : GL.FACE VN+1,VN+2,VN+3,VN+4 : VN=VN+4
6300 NEXT I
6310 FOR J=0 TO 2
6320 YP=YB+J*CELL : IF J=2 THEN YP=YT
6330 GL.VERTEX 0,YP-GW,ZN : GL.VERTEX FL,YP-GW,ZN : GL.VERTEX FL,YP+GW,ZN : GL.VERTEX 0,YP+GW,ZN : GL.FACE VN+1,VN+2,VN+3,VN+4 : VN=VN+4
6340 NEXT J
6350 GL.END
6360 REM --- South wall: Z=15*CELL-.05 ---
6370 ZN=15*CELL-0.05 : GL.BEGIN : VN=0
6380 FOR I=0 TO 16
6390 XP=I*CELL : GL.VERTEX XP-GW,YB,ZN : GL.VERTEX XP+GW,YB,ZN : GL.VERTEX XP+GW,YT,ZN : GL.VERTEX XP-GW,YT,ZN : GL.FACE VN+1,VN+2,VN+3,VN+4 : VN=VN+4
6400 NEXT I
6410 FOR J=0 TO 2
6420 YP=YB+J*CELL : IF J=2 THEN YP=YT
6430 GL.VERTEX 0,YP-GW,ZN : GL.VERTEX FL,YP-GW,ZN : GL.VERTEX FL,YP+GW,ZN : GL.VERTEX 0,YP+GW,ZN : GL.FACE VN+1,VN+2,VN+3,VN+4 : VN=VN+4
6440 NEXT J
6450 GL.END
6460 REM --- West wall: X=CELL+.05, runs along Z ---
6470 WX=CELL+0.05 : GL.BEGIN : VN=0
6480 FOR I=0 TO 16
6490 ZP=I*CELL : GL.VERTEX WX,YB,ZP-GW : GL.VERTEX WX,YB,ZP+GW : GL.VERTEX WX,YT,ZP+GW : GL.VERTEX WX,YT,ZP-GW : GL.FACE VN+1,VN+2,VN+3,VN+4 : VN=VN+4
6500 NEXT I
6510 FOR J=0 TO 2
6520 YP=YB+J*CELL : IF J=2 THEN YP=YT
6530 GL.VERTEX WX,YP-GW,0 : GL.VERTEX WX,YP-GW,FL : GL.VERTEX WX,YP+GW,FL : GL.VERTEX WX,YP+GW,0 : GL.FACE VN+1,VN+2,VN+3,VN+4 : VN=VN+4
6540 NEXT J
6550 GL.END
6560 REM --- East wall: X=15*CELL-.05 ---
6570 WX=15*CELL-0.05 : GL.BEGIN : VN=0
6580 FOR I=0 TO 16
6590 ZP=I*CELL : GL.VERTEX WX,YB,ZP-GW : GL.VERTEX WX,YB,ZP+GW : GL.VERTEX WX,YT,ZP+GW : GL.VERTEX WX,YT,ZP-GW : GL.FACE VN+1,VN+2,VN+3,VN+4 : VN=VN+4
6600 NEXT I
6610 FOR J=0 TO 2
6620 YP=YB+J*CELL : IF J=2 THEN YP=YT
6630 GL.VERTEX WX,YP-GW,0 : GL.VERTEX WX,YP-GW,FL : GL.VERTEX WX,YP+GW,FL : GL.VERTEX WX,YP+GW,0 : GL.FACE VN+1,VN+2,VN+3,VN+4 : VN=VN+4
6640 NEXT J
6650 GL.END
6660 END SUB
6710 REM BuildCeiling - 3x-scaled copy of the floor grid, double-sided, centred on arena, at y=14
6720 SUB BuildCeiling STATIC
6730 SHARED CELL
6740 FL=16*CELL : GW=0.08 : GC=FL/16
6750 GL.SOLID : GL.COLOUR 120,190,255 : GL.SHINE 10 : GL.EMISSIVE 40,100,200 : GL.ALPHA 1.0
6760 GL.BEGIN : VN=0
6770 FOR I=0 TO 16
6780 GP=I*GC : GL.VERTEX GP-GW,0,0 : GL.VERTEX GP+GW,0,0 : GL.VERTEX GP+GW,0,FL : GL.VERTEX GP-GW,0,FL : GL.FACE VN+1,VN+2,VN+3,VN+4 : GL.FACE VN+4,VN+3,VN+2,VN+1 : VN=VN+4
6790 GL.VERTEX 0,0,GP-GW : GL.VERTEX FL,0,GP-GW : GL.VERTEX FL,0,GP+GW : GL.VERTEX 0,0,GP+GW : GL.FACE VN+1,VN+2,VN+3,VN+4 : GL.FACE VN+4,VN+3,VN+2,VN+1 : VN=VN+4
6800 NEXT I
6810 GL.END
6820 CEILID=GL.MESHID : GL.SCALE CEILID,3,1,3 : GL.TRANSLATE CEILID,-FL,14,-FL
6830 END SUB
6910 REM DoTurn - turn handling. TURNMODE 0 = 3-gate mouse chase; 1 = discrete 45/90 deg turns swept fast
6920 SUB DoTurn
6930 SHARED PYAW, CUBEYAW, TURNMODE, TURNTGT, D10, D20, TSLOW, TQUICK, DT
6940 PI=4*ATN(1) : PI2=PI/2 : PI4=PI/4 : TR=PI*15/180
6950 GAP=PYAW-CUBEYAW : G=ABS(GAP)
6960 IF TURNMODE=1 THEN GOTO DTTurn
6970 TSTEP=TQUICK : IF G<D10 THEN TSTEP=0
6980 IF G>=D10 AND G<D20 THEN TSTEP=TSLOW
6990 CUBEYAW=CUBEYAW+SGN(GAP)*TSTEP*DT
7000 EXIT SUB
7010 DTTurn:
7020 IF CUBEYAW=TURNTGT AND G>=D20 THEN TURNTGT=CUBEYAW+SGN(GAP)*PI2 : PYAW=TURNTGT
7030 IF CUBEYAW=TURNTGT AND G>=D10 AND G<D20 THEN TURNTGT=CUBEYAW+SGN(GAP)*PI4 : PYAW=TURNTGT
7040 GAP2=TURNTGT-CUBEYAW : G2=ABS(GAP2)
7050 IF G2>TR*DT THEN CUBEYAW=CUBEYAW+SGN(GAP2)*TR*DT ELSE CUBEYAW=TURNTGT
7060 END SUB
8010 REM ============================================================
8020 REM  GAME OVER  --  Q/Esc from any mode lands here, then back to the start menu
8030 REM ============================================================
8040 REM GameOver - leave the arena, drop back to the start menu
8050 GameOver:
8060 CALL Quit
8070 GOTO StartMenu
8080 REM Quit - tear down GL, return to caller. Leave FULLSCREEN ON: the start menu re-renders fine and toggling it would resize/realloc the 2D gfx layer and wipe the minimap on the next play. FULLSCREEN OFF happens only on real exit (line 19).
8090 SUB Quit STATIC
8100 MOUSE OFF : UI ON
8110 GL.CLOSE
8120 CLS
8130 END SUB
9010 REM ============================================================
9020 REM  DEMO LOOP  --  autonomous lightcycle (press D at the menu). Steers to dodge walls and ribbon.
9030 REM ============================================================
9040 DemoLoop:
9050 K=INKEY
9060 IF K=81 OR K=113 OR K=27 THEN GOTO GameOver
9070 DT=1
9080 LX=PX+COS(CUBEYAW)*8 : LZ=PZ+SIN(CUBEYAW)*8 : NEARW=0
9090 IF LX<5 OR LX>75 OR LZ<5 OR LZ>75 THEN NEARW=1
9100 FLX=PX+COS(CUBEYAW-0.6)*7 : FLZ=PZ+SIN(CUBEYAW-0.6)*7
9110 IF FLX<5 OR FLX>75 OR FLZ<5 OR FLZ>75 THEN NEARW=1
9120 FRX=PX+COS(CUBEYAW+0.6)*7 : FRZ=PZ+SIN(CUBEYAW+0.6)*7
9130 IF FRX<5 OR FRX>75 OR FRZ<5 OR FRZ>75 THEN NEARW=1
9140 LRX=PX+COS(CUBEYAW)*6 : LRZ=PZ+SIN(CUBEYAW)*6 : NEARR=0
9150 RCX=INT(LRX/CELL) : RCZ=INT(LRZ/CELL)
9160 IF RCX<0 OR RCX>=MZ OR RCZ<0 OR RCZ>=MZ THEN GOTO DLNoR
9170 IF TRAIL(RCZ,RCX)<>0 THEN NEARR=1
9180 DLNoR:
9190 MCX=INT(PX/CELL) : MCZ=INT(PZ/CELL)
9200 IF MCX>=0 AND MCX<MZ AND MCZ>=0 AND MCZ<MZ THEN TRAIL(MCZ,MCX)=1
9210 IF WALLCD>0 THEN WALLCD=WALLCD-1
9220 IF RIBCD>0 THEN RIBCD=RIBCD-1
9230 DTMR=DTMR-1
9240 IF NEARW=1 AND WALLCD<=0 THEN GOTO DLWall
9250 IF NEARR=1 AND RIBCD<=0 THEN GOTO DLRib
9260 IF DTMR>0 THEN GOTO DLGO
9270 RR=INT(RND(1)*3) : TANG=0.2618 : TRATE=0.005 : IF RR=1 THEN TANG=0.7854
9280 IF RR=1 THEN TRATE=0.025
9290 IF RR=2 THEN TANG=1.5708
9300 IF RR=2 THEN TRATE=0.08
9310 IF RND(1)>0.5 THEN PYAW=CUBEYAW+TANG ELSE PYAW=CUBEYAW-TANG
9320 DTMR=45+INT(RND(1)*90)
9330 GOTO DLGO
9340 DLWall:
9350 TRATE=0.12 : WALLCD=28 : DTMR=45+INT(RND(1)*90)
9360 HLX=PX+COS(CUBEYAW-2.5)*9 : HLZ=PZ+SIN(CUBEYAW-2.5)*9 : LCLR=1
9370 IF HLX<5 OR HLX>75 OR HLZ<5 OR HLZ>75 THEN LCLR=0
9380 HRX=PX+COS(CUBEYAW+2.5)*9 : HRZ=PZ+SIN(CUBEYAW+2.5)*9 : RCLR=1
9390 IF HRX<5 OR HRX>75 OR HRZ<5 OR HRZ>75 THEN RCLR=0
9400 WS=1
9410 IF LCLR=1 THEN WS=-1
9420 IF LCLR=1 AND RCLR=1 AND RND(1)>0.5 THEN WS=1
9430 IF LCLR=0 AND RCLR=0 THEN WS=0
9440 PYAW=CUBEYAW+WS*2.5
9450 IF WS=0 THEN PYAW=CUBEYAW+3.14159
9460 GOTO DLGO
9470 DLRib:
9480 RIBCD=20
9490 LJX=PX+COS(CUBEYAW)*3 : LJZ=PZ+SIN(CUBEYAW)*3
9500 JRX=INT(LJX/CELL) : JRZ=INT(LJZ/CELL)
9510 IF JRX<0 OR JRX>=MZ OR JRZ<0 OR JRZ>=MZ THEN GOTO DLRibTurn
9520 IF JRX=MCX AND JRZ=MCZ THEN GOTO DLRibTurn
9530 IF TRAIL(JRZ,JRX)=0 THEN GOTO DLRibTurn
9540 IF JUMPY<>0 OR JUMPV<>0 THEN GOTO DLRibTurn
9550 JUMPV=JUMPV0 : RIBCD=25
9560 GOTO DLGO
9570 DLRibTurn:
9580 TRATE=0.10 : IF RND(1)>0.5 THEN PYAW=CUBEYAW+1.5708 ELSE PYAW=CUBEYAW-1.5708
9590 DTMR=45+INT(RND(1)*90)
9600 GOTO DLGO
9610 DLGO:
9620 GAP=PYAW-CUBEYAW : IF ABS(GAP)<=TRATE THEN CUBEYAW=PYAW ELSE CUBEYAW=CUBEYAW+SGN(GAP)*TRATE
9630 DX=COS(CUBEYAW)*DSPD : DZ=SIN(CUBEYAW)*DSPD
9640 CALL Move
9650 JUMPY=JUMPY+JUMPV : JUMPV=JUMPV-GRAV
9660 IF JUMPY<0 THEN JUMPY=0
9670 IF JUMPY=0 THEN JUMPV=0
9680 TRLTICK=TRLTICK+1
9690 IF TRLTICK>=1.5 THEN TRLTICK=TRLTICK-1.5 : CALL DropTrail
9700 CAMX=PX-COS(CUBEYAW)*CAMDIST : CAMZ=PZ-SIN(CUBEYAW)*CAMDIST
9710 GL.CAMERA CAMX,CAMHT,CAMZ : GL.LOOKAT PX,0.6,PZ
9720 GL.LIGHTSOFF : GL.RECTLIGHT PX,2.5,PZ, 8,8, 200,215,255, 30
9730 GL.TRANSLATE CUBEID, PX, JUMPY-1.1, PZ
9740 GL.ROTATE CUBEID, 0, -CUBEYAW*180/PI+CYCOFF, 0
9750 CALL DrawMinimap
9760 LOCATE 1,1 : PRINT "DEMO   px=" ; INT(PX*10) ; " pz=" ; INT(PZ*10) ; " yaw=" ; INT(CUBEYAW*100) ; " trl=" ; TRLCOUNT ; "    "
9770 GL.CLS 2,2,8 : GL.DRAWALL
9780 SLEEP 16 : GOTO DemoLoop
9810 REM BuildRibbonTemplates - rails as thin boxes (Z ~0.02 wide), flat translucent centre; the instanced ribbon clones these
9820 SUB BuildRibbonTemplates STATIC
9830 SHARED RAILID, CTRID
9840 GL.SOLID : GL.COLOUR 30,130,255 : GL.SHINE 90 : GL.EMISSIVE 30,120,255 : GL.ALPHA 1.0
9850 GL.BEGIN
9860 GL.VERTEX 0,0.25,-0.01 : GL.VERTEX 0,0.25,0.01 : GL.VERTEX 1,0.25,0.01 : GL.VERTEX 1,0.25,-0.01
9870 GL.VERTEX 0,0.15,-0.01 : GL.VERTEX 0,0.15,0.01 : GL.VERTEX 1,0.15,0.01 : GL.VERTEX 1,0.15,-0.01
9880 GL.VERTEX 0,-0.15,-0.01 : GL.VERTEX 0,-0.15,0.01 : GL.VERTEX 1,-0.15,0.01 : GL.VERTEX 1,-0.15,-0.01
9890 GL.VERTEX 0,-0.25,-0.01 : GL.VERTEX 0,-0.25,0.01 : GL.VERTEX 1,-0.25,0.01 : GL.VERTEX 1,-0.25,-0.01
9900 GL.FACE 1,2,3,4 : GL.FACE 4,3,2,1 : GL.FACE 5,6,7,8 : GL.FACE 8,7,6,5
9910 GL.FACE 2,3,7,6 : GL.FACE 6,7,3,2 : GL.FACE 1,4,8,5 : GL.FACE 5,8,4,1
9920 GL.FACE 3,4,8,7 : GL.FACE 7,8,4,3 : GL.FACE 1,2,6,5 : GL.FACE 5,6,2,1
9930 GL.FACE 9,10,11,12 : GL.FACE 12,11,10,9 : GL.FACE 13,14,15,16 : GL.FACE 16,15,14,13
9940 GL.FACE 10,11,15,14 : GL.FACE 14,15,11,10 : GL.FACE 9,12,16,13 : GL.FACE 13,16,12,9
9950 GL.FACE 11,12,16,15 : GL.FACE 15,16,12,11 : GL.FACE 9,10,14,13 : GL.FACE 13,14,10,9
9960 GL.END
9970 RAILID=GL.MESHID
9980 GL.COLOUR 0,90,255 : GL.EMISSIVE 0,25,100 : GL.ALPHA 0.5
9990 GL.BEGIN
10000 GL.VERTEX 0,0.15,0 : GL.VERTEX 0,-0.15,0 : GL.VERTEX 1,-0.15,0 : GL.VERTEX 1,0.15,0
10010 GL.FACE 1,2,3,4 : GL.FACE 4,3,2,1
10020 GL.END
10030 CTRID=GL.MESHID
10040 END SUB
11010 REM ============================================================
11020 REM  2-PLAYER LOOP  --  P1 = you (mouse-steered); P2 = an autonomous red bike that chases you (press 2)
11030 REM ============================================================
11040 TwoPlayerInit:
11050 PX2=PX : PZ2=PZ+6 : CUBEYAW2=0
11060 TRLPCX2=PX2-0.4 : TRLPCZ2=PZ2 : TRLPCY2=0 : STARTED=0 : PTMR=0
11070 TwoPlayerLoop:
11080 K=INKEY
11090 IF K=81 OR K=113 OR K=27 THEN GOTO GameOver
11100 IF K=77 OR K=109 THEN CALL ToggleMap
11110 IF K=70 OR K=102 THEN CALL ToggleFog
11120 NOW=TIMER : DT=(NOW-LASTT)/16 : DT=(4+DT-ABS(4-DT))/2 : LASTT=NOW : LASTYAW=CUBEYAW : IF K=84 OR K=116 THEN TURNMODE=1-TURNMODE : TURNTGT=CUBEYAW : PYAW=CUBEYAW
11130 MX=MOUSE(1) : DMX=MX-LASTMX : LASTMX=MX : MY=MOUSE(2) : DMY=MY-LASTMY : LASTMY=MY : IF MOUSE(0)<0 AND ABS(DMX)<MAXD THEN PYAW=PYAW+DMX*TSPD : IF MOUSE(0)<0 AND ABS(DMY)<MAXD THEN CAMPITCH=CAMPITCH-DMY*TSPD : IF ABS(CAMPITCH)>PMAX THEN CAMPITCH=SGN(CAMPITCH)*PMAX
11140 CALL DoTurn
11150 IF K=71 OR K=103 THEN AAON=1-AAON : GL.AA AAON
11160 IF ABS(PYAW-CUBEYAW)>D10 THEN SPDCUR=SPEED
11170 SPDCUR=SPDCUR+0.0015*DT : IF SPDCUR>0.3 THEN SPDCUR=0.3
11180 DX=0 : DZ=0 : IF K=83 OR K=115 THEN FPSON=1-FPSON : GL.FPS FPSON
11190 IF KEYDOWN(87) OR KEYDOWN(38) OR AUTORUN=1 THEN DX=COS(CUBEYAW)*SPDCUR*DT : DZ=SIN(CUBEYAW)*SPDCUR*DT
11200 IF K=65 OR K=97 THEN AUTORUN=1-AUTORUN
11210 IF STARTED=0 AND KEYDOWN(87) THEN STARTED=1 : PTMR=60
11220 IF PTMR>0 THEN PTMR=PTMR-DT
11230 IF DX<>0 OR DZ<>0 THEN CALL Move
11240 IF DX<>0 OR DZ<>0 THEN MOVING=1 ELSE MOVING=0
11250 IF STARTED=1 THEN RBI=INT(PZ-SIN(CUBEYAW)*0.4) : RBJ=INT(PX-COS(CUBEYAW)*0.4) : RBI2=INT(PZ) : RBJ2=INT(PX) : RIBWAL(RBI,RBJ)=1 : RIBWAL(RBI2,RBJ2)=1
11260 IF STARTED=0 OR PTMR>0 THEN GOTO TPSKIP
11270 TX=PX-PX2 : TZ=PZ-PZ2 : DST=SQR(TX*TX+TZ*TZ)
11280 IF DST<0.01 THEN DST=0.01
11290 CX=COS(CUBEYAW2) : CZ=SIN(CUBEYAW2)
11300 CROSS=(CX*TZ-CZ*TX)/DST : FWD=(CX*TX+CZ*TZ)/DST
11310 TRATE=0.06 : TURN=CROSS
11320 IF TURN>TRATE THEN TURN=TRATE
11330 IF TURN<0-TRATE THEN TURN=0-TRATE
11340 IF FWD<0 AND ABS(CROSS)<0.05 THEN TURN=TRATE
11350 CUBEYAW2=CUBEYAW2+TURN*DT : GOSUB AvoidRibbon
11360 DX2=COS(CUBEYAW2)*SPDCUR*0.88*DT : DZ2=SIN(CUBEYAW2)*SPDCUR*0.88*DT
11370 NX2=PX2+DX2 : NZ2=PZ2+DZ2 : MM=0.35
11380 RR1=INT((NZ2-MM)/CELL) : RR2=INT((NZ2+MM)/CELL) : CC1=INT((NX2-MM)/CELL) : CC2=INT((NX2+MM)/CELL)
11390 IF RR1<0 OR RR2>=MZ OR CC1<0 OR CC2>=MZ THEN GOTO TPSlideX
11400 IF MAP(RR1,CC1)<>0 OR MAP(RR1,CC2)<>0 OR MAP(RR2,CC1)<>0 OR MAP(RR2,CC2)<>0 THEN GOTO TPSlideX
11410 PX2=NX2 : PZ2=NZ2 : GOTO TPMoveDone
11420 TPSlideX:
11430 NX2=PX2+DX2 : NZ2=PZ2
11440 RR1=INT((NZ2-MM)/CELL) : RR2=INT((NZ2+MM)/CELL) : CC1=INT((NX2-MM)/CELL) : CC2=INT((NX2+MM)/CELL)
11450 IF RR1<0 OR RR2>=MZ OR CC1<0 OR CC2>=MZ THEN GOTO TPSlideZ
11460 IF MAP(RR1,CC1)<>0 OR MAP(RR1,CC2)<>0 OR MAP(RR2,CC1)<>0 OR MAP(RR2,CC2)<>0 THEN GOTO TPSlideZ
11470 PX2=NX2 : GOTO TPMoveDone
11480 TPSlideZ:
11490 NX2=PX2 : NZ2=PZ2+DZ2
11500 RR1=INT((NZ2-MM)/CELL) : RR2=INT((NZ2+MM)/CELL) : CC1=INT((NX2-MM)/CELL) : CC2=INT((NX2+MM)/CELL)
11510 IF RR1<0 OR RR2>=MZ OR CC1<0 OR CC2>=MZ THEN GOTO TPMoveDone
11520 IF MAP(RR1,CC1)<>0 OR MAP(RR1,CC2)<>0 OR MAP(RR2,CC1)<>0 OR MAP(RR2,CC2)<>0 THEN GOTO TPMoveDone
11530 PZ2=NZ2
11540 TPMoveDone:
11550 TPSKIP:
11560 TRLTICK=TRLTICK+DT
11570 IF TRLTICK<1.5 THEN GOTO TPNoDrop
11580 TRLTICK=TRLTICK-1.5
11590 CALL DropTrail
11600 IF STARTED=0 OR PTMR>0 THEN GOTO TPNoDrop
11610 BX2=PX2-COS(CUBEYAW2)*0.4 : BZ2=PZ2-SIN(CUBEYAW2)*0.4
11620 RDOT=(BX2-TRLPCX2)*COS(CUBEYAW2)+(BZ2-TRLPCZ2)*SIN(CUBEYAW2)
11630 IF RDOT<=0 THEN GOTO TPNoDrop
11640 RSDX=BX2-TRLPCX2 : RSDZ=BZ2-TRLPCZ2 : RDY=JUMPY-TRLPCY2
11650 GL.INSTANCE RAILID2, TRLPCX2, TRLPCY2-1.10, TRLPCZ2, RSDX, RDY, RSDZ
11660 GL.INSTANCE CTRID2, TRLPCX2, TRLPCY2-1.10, TRLPCZ2, RSDX, RDY, RSDZ
11670 TRLPCX2=BX2 : TRLPCZ2=BZ2 : TRLPCY2=JUMPY
11680 TPNoDrop:
11690 IF K=67 OR K=99 THEN CAMMODE=CAMMODE+1
11700 IF CAMMODE>2 THEN CAMMODE=0
11710 CAMX=PX-COS(PYAW)*CAMDIST : CAMZ=PZ-SIN(PYAW)*CAMDIST
11720 IF CAMMODE=0 THEN GL.CAMERA CAMX,CAMHT,CAMZ : GL.LOOKAT PX,CAMDIST*CAMPITCH+0.6,PZ
11730 IF CAMMODE=1 THEN GL.CAMERA PX-COS(PYAW)*CAMDIST2,CAMHT2,PZ-SIN(PYAW)*CAMDIST2 : GL.LOOKAT PX,CAMDIST2*CAMPITCH+0.1,PZ
11740 IF CAMMODE=2 THEN GL.CAMERA PX-COS(CUBEYAW)*0.2,JUMPY-0.6,PZ-SIN(CUBEYAW)*0.2 : GL.LOOKAT PX+COS(CUBEYAW)*10,JUMPY-1.1+10*CAMPITCH,PZ+SIN(CUBEYAW)*10
11750 GL.LIGHTSOFF : IF LIGHTON=1 AND WIREMODE=0 THEN GL.RECTLIGHT PX,2.5,PZ, 8,8, 200,215,255, 30
11760 IF K=66 OR K=98 THEN BLOOMON=1-BLOOMON : IF BLOOMON=1 THEN GL.BLOOM 0.6 ELSE GL.BLOOM 0
11770 GL.TRANSLATE CUBEID, PX, JUMPY-1.1, PZ
11780 GL.ROTATE CUBEID, 0, -CUBEYAW*180/PI+CYCOFF, 0
11790 GL.TRANSLATE CUBEID2, PX2, JUMPY-1.1, PZ2
11800 GL.ROTATE CUBEID2, 0, -CUBEYAW2*180/PI+CYCOFF, 0
11810 CALL DrawMinimap
11820 LOCATE 1,1 : PRINT "2-PLAYER  P1=" ; INT(PX*10) ; "," ; INT(PZ*10) ; "  P2(red)=" ; INT(PX2*10) ; "," ; INT(PZ2*10) ; "    " : GL.CLS 2,2,8 : GL.DRAWALL
11830 IF K=32 AND JUMPV=0 AND JUMPY=0 THEN JUMPV=JUMPV0
11840 JUMPY=JUMPY+JUMPV*DT
11850 JUMPV=JUMPV-GRAV*DT
11860 IF JUMPY<0 THEN JUMPY=0
11870 IF JUMPY=0 THEN JUMPV=0
11880 IF K=76 OR K=108 THEN LIGHTON=1-LIGHTON
11890 IF K=90 OR K=122 THEN WIREMODE=1-WIREMODE : GL.WIREALL WIREMODE
11900 SLEEP 16 : GOTO TwoPlayerLoop
12010 REM AvoidRibbon - GOSUB target (2-player only). Feels ahead of P2 for P1 blue-ribbon cells (RIBWAL). If any are near, cancels this frame chase-turn and steers P2 away so it rounds the ribbon instead of driving through it.
12020 AvoidRibbon:
12030 AFD=7 : ASIDE=0.5 : ATURN=0.10
12040 AFX=PX2+COS(CUBEYAW2)*5 : AFZ=PZ2+SIN(CUBEYAW2)*5 : AFI=INT(AFZ) : AFJ=INT(AFX) : AHF=0
12050 IF AFI>=1 AND AFI<=78 AND AFJ>=1 AND AFJ<=78 THEN IF RIBWAL(AFI,AFJ)<>0 THEN AHF=1
12060 ALX=PX2+COS(CUBEYAW2-ASIDE)*AFD : ALZ=PZ2+SIN(CUBEYAW2-ASIDE)*AFD : ALI=INT(ALZ) : ALJ=INT(ALX) : AHL=0
12070 IF ALI>=1 AND ALI<=78 AND ALJ>=1 AND ALJ<=78 THEN IF RIBWAL(ALI,ALJ)<>0 THEN AHL=1
12080 ARX=PX2+COS(CUBEYAW2+ASIDE)*AFD : ARZ=PZ2+SIN(CUBEYAW2+ASIDE)*AFD : ARI=INT(ARZ) : ARJ=INT(ARX) : AHR=0
12090 IF ARI>=1 AND ARI<=78 AND ARJ>=1 AND ARJ<=78 THEN IF RIBWAL(ARI,ARJ)<>0 THEN AHR=1
12100 IF AHF=0 AND AHL=0 AND AHR=0 THEN RETURN
12110 CUBEYAW2=CUBEYAW2-TURN*DT
12120 IF AHL=1 AND AHR=0 THEN CUBEYAW2=CUBEYAW2+ATURN*DT : RETURN
12130 IF AHR=1 AND AHL=0 THEN CUBEYAW2=CUBEYAW2-ATURN*DT : RETURN
12140 IF CROSS>=0 THEN CUBEYAW2=CUBEYAW2+ATURN*DT ELSE CUBEYAW2=CUBEYAW2-ATURN*DT
12150 RETURN
