410 REM ============================================================
411 REM DoTurn - turn handling. TURNMODE 0 = 3-gate mouse chase; 1 = discrete 45/90 deg turns swept fast
412 REM ============================================================
413 SUB DoTurn
414 SHARED PYAW, CUBEYAW, TURNMODE, TURNTGT, D10, D20, TSLOW, TQUICK, DT
415 PI=4*ATN(1) : PI2=PI/2 : PI4=PI/4 : TR=PI*15/180
416 GAP=PYAW-CUBEYAW : G=ABS(GAP)
417 IF TURNMODE=1 THEN GOTO DTTurn
418 TSTEP=TQUICK : IF G<D10 THEN TSTEP=0
419 IF G>=D10 AND G<D20 THEN TSTEP=TSLOW
420 CUBEYAW=CUBEYAW+SGN(GAP)*TSTEP*DT
421 EXIT SUB
422 DTTurn:
423 IF CUBEYAW=TURNTGT AND G>=D20 THEN TURNTGT=CUBEYAW+SGN(GAP)*PI2 : PYAW=TURNTGT
424 IF CUBEYAW=TURNTGT AND G>=D10 AND G<D20 THEN TURNTGT=CUBEYAW+SGN(GAP)*PI4 : PYAW=TURNTGT
425 GAP2=TURNTGT-CUBEYAW : G2=ABS(GAP2)
426 IF G2>TR*DT THEN CUBEYAW=CUBEYAW+SGN(GAP2)*TR*DT ELSE CUBEYAW=TURNTGT
427 END SUB
