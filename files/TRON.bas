364 NEXT I
365 FOR J=0 TO 2
366 YP=YB+J*CELL : IF J=2 THEN YP=YT
367 GL.VERTEX 0,YP-GW,ZN : GL.VERTEX FL,YP-GW,ZN : GL.VERTEX FL,YP+GW,ZN : GL.VERTEX 0,YP+GW,ZN : GL.FACE VN+1,VN+2,VN+3,VN+4 : VN=VN+4
368 NEXT J
369 GL.END
370 REM ============================================================
371 REM West wall: X=CELL+.05, runs along Z
372 REM ============================================================
373 WX=CELL+0.05 : GL.BEGIN : VN=0
374 FOR I=0 TO 16
375 ZP=I*CELL : GL.VERTEX WX,YB,ZP-GW : GL.VERTEX WX,YB,ZP+GW : GL.VERTEX WX,YT,ZP+GW : GL.VERTEX WX,YT,ZP-GW : GL.FACE VN+1,VN+2,VN+3,VN+4 : VN=VN+4
376 NEXT I
