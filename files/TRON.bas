810 REM DoTurn - turn handling. TURNMODE 0 = 3-gate mouse chase; 1 = discrete 45/90 deg turns swept fast
811 SUB DoTurn
812 SHARED PYAW, CUBEYAW, TURNMODE, TURNTGT, D10, D20, TSLOW, TQUICK, DT
813 PI=4*ATN(1) : PI2=PI/2 : PI4=PI/4 : TR=PI*15/180
814 GAP=PYAW-CUBEYAW : G=ABS(GAP)
815 IF TURNMODE=1 THEN GOTO DTTurn
816 TSTEP=TQUICK : IF G<D10 THEN TSTEP=0
817 IF G>=D10 AND G<D20 THEN TSTEP=TSLOW
818 CUBEYAW=CUBEYAW+SGN(GAP)*TSTEP*DT
819 EXIT SUB
820 DTTurn:
821 IF CUBEYAW=TURNTGT AND G>=D20 THEN TURNTGT=CUBEYAW+SGN(GAP)*PI2 : PYAW=TURNTGT
822 IF CUBEYAW=TURNTGT AND G>=D10 AND G<D20 THEN TURNTGT=CUBEYAW+SGN(GAP)*PI4 : PYAW=TURNTGT
823 GAP2=TURNTGT-CUBEYAW : G2=ABS(GAP2)
824 IF G2>TR*DT THEN CUBEYAW=CUBEYAW+SGN(GAP2)*TR*DT ELSE CUBEYAW=TURNTGT
825 END SUB
