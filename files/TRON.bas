66 DIM TRAIL(15,15)
67 DIM RIBWAL(79,79)
68 REM ============================================================
69 REM RIBWAL = 1-unit grid marking cells where P1 has laid blue ribbon. In 2-player mode P2 feels ahead with AvoidRibbon and steers around marked cells (it does not collide). Re-DIMed each run = cleared.
70 REM Build the 3D scene, then branch into the right loop for the chosen mode.
71 REM ============================================================
72 CLS : UI ON : DELAY 0
73 CALL BuildScene
74 CALL BuildWallGrids
75 CALL InitMinimap
76 MAPVIS=1
77 CALL BuildCeiling
78 CALL BuildRibbonTemplates
79 IF TWOP=1 THEN CALL BuildRedRibbon
80 MOUSE ON : LASTMX=MOUSE(1) : LASTT=TIMER : RIB0=GL.MESHID
81 IF DEMO=1 THEN GOTO DemoLoop
82 IF TWOP=1 THEN GOTO TwoPlayerInit
83 REM ============================================================
84 REM  MAIN LOOP  --  single-player gameplay (mouse-steered lightcycle)
85 REM ============================================================
86 MainLoop:
87 K=INKEY
88 REM ============================================================
89 REM Keyboard: Q/ESC=back to menu  M=map  via SWITCH
90 REM ============================================================
91 SWITCH(K)
92 CASE 81:
93 CASE 113:
94 CASE 27:
95 GOTO GameOver
96 BREAK
97 CASE 77:
98 CASE 109:
99 CALL ToggleMap
100 BREAK
101 CASE 70:
102 CASE 102:
103 CALL ToggleFog
104 BREAK
105 END SWITCH
106 NOW=TIMER : DT=(NOW-LASTT)/16 : DT=(4+DT-ABS(4-DT))/2 : LASTT=NOW : LASTYAW=CUBEYAW : IF K=84 OR K=116 THEN TURNMODE=1-TURNMODE : TURNTGT=CUBEYAW : PYAW=CUBEYAW
107 MX=MOUSE(1) : DMX=MX-LASTMX : LASTMX=MX : MY=MOUSE(2) : DMY=MY-LASTMY : LASTMY=MY : IF MOUSE(0)<0 AND ABS(DMX)<MAXD THEN PYAW=PYAW+DMX*TSPD : IF MOUSE(0)<0 AND ABS(DMY)<MAXD THEN CAMPITCH=CAMPITCH-DMY*TSPD : IF ABS(CAMPITCH)>PMAX THEN CAMPITCH=SGN(CAMPITCH)*PMAX
108 CALL DoTurn
109 IF K=71 OR K=103 THEN AAON=1-AAON : GL.AA AAON
110 IF ABS(PYAW-CUBEYAW)>D10 THEN SPDCUR=SPEED
111 SPDCUR=SPDCUR+0.0015*DT : IF SPDCUR>0.3 THEN SPDCUR=0.3
112 DX=0 : DZ=0 : IF K=83 OR K=115 THEN FPSON=1-FPSON : GL.FPS FPSON
113 IF KEYDOWN(87) OR KEYDOWN(38) OR AUTORUN=1 THEN DX=COS(CUBEYAW)*SPDCUR*DT : DZ=SIN(CUBEYAW)*SPDCUR*DT
114 IF K=65 OR K=97 THEN AUTORUN=1-AUTORUN
115 IF DX<>0 OR DZ<>0 THEN CALL Move
116 IF DX<>0 OR DZ<>0 THEN MOVING=1 ELSE MOVING=0
117 TRLTICK=TRLTICK+DT
118 IF TRLTICK>=1.5 THEN TRLTICK=TRLTICK-1.5 : CALL DropTrail
119 IF K=67 OR K=99 THEN CAMMODE=CAMMODE+1
120 IF CAMMODE>2 THEN CAMMODE=0
121 CAMX=PX-COS(PYAW)*CAMDIST : CAMZ=PZ-SIN(PYAW)*CAMDIST
122 IF CAMMODE=0 THEN GL.CAMERA CAMX,CAMHT,CAMZ : GL.LOOKAT PX,CAMDIST*CAMPITCH+0.6,PZ
123 IF CAMMODE=1 THEN GL.CAMERA PX-COS(PYAW)*CAMDIST2,CAMHT2,PZ-SIN(PYAW)*CAMDIST2 : GL.LOOKAT PX,CAMDIST2*CAMPITCH+0.1,PZ
124 IF CAMMODE=2 THEN GL.CAMERA PX-COS(CUBEYAW)*0.2,JUMPY-0.6,PZ-SIN(CUBEYAW)*0.2 : GL.LOOKAT PX+COS(CUBEYAW)*10,JUMPY-1.1+10*CAMPITCH,PZ+SIN(CUBEYAW)*10
125 GL.LIGHTSOFF : IF LIGHTON=1 AND WIREMODE=0 THEN GL.RECTLIGHT PX,2.5,PZ, 8,8, 200,215,255, 30
126 IF K=66 OR K=98 THEN BLOOMON=1-BLOOMON : IF BLOOMON=1 THEN GL.BLOOM 0.6 ELSE GL.BLOOM 0
127 GL.TRANSLATE CUBEID, PX, JUMPY-1.1, PZ
128 GL.ROTATE CUBEID, 0, -CUBEYAW*180/PI+CYCOFF, 0
129 CALL DrawMinimap
130 LOCATE 1,1 : PRINT "Speed: " ; INT(SPDCUR*1000) ; "      " : GL.CLS 2,2,8 : GL.DRAWALL
131 REM ============================================================
132 REM Jump (SPACE): rise to ~2x bike height, then fall back to ground
133 REM ============================================================
134 IF K=32 AND JUMPV=0 AND JUMPY=0 THEN JUMPV=JUMPV0
135 JUMPY=JUMPY+JUMPV*DT
136 JUMPV=JUMPV-GRAV*DT
137 IF JUMPY<0 THEN JUMPY=0
138 IF JUMPY=0 THEN JUMPV=0
139 IF K=76 OR K=108 THEN LIGHTON=1-LIGHTON
140 IF K=90 OR K=122 THEN WIREMODE=1-WIREMODE : GL.WIREALL WIREMODE
141 SLEEP 16 : GOTO MainLoop
142 REM ============================================================
143 REM Fall-through guard: nothing below this line is reached except via GOTO/GOSUB/CALL.
144 REM ============================================================
145 END
146 REM ============================================================
147 REM  SUBROUTINES  --  shared by MAIN LOOP, DEMO LOOP and 2-PLAYER LOOP
148 REM InitMinimap - Draw arena borders into pixel buffer once
149 REM ============================================================
150 SUB InitMinimap STATIC
151 SHARED MAP, MZ, MSCL, MMX, MMY, MAPVIS
152 MSCL=8 : MAPVIS=1
153 MMX=WIDTH-MZ*MSCL-6 : MMY=HEIGHT-MZ*MSCL-6
154 DELAY 0
155 FOR MR=0 TO MZ-1
156 FOR MC=0 TO MZ-1
157 IF MAP(MR,MC)=1 THEN MC2=7 ELSE MC2=15
158 FOR PR=0 TO MSCL-1
159 FOR PC=0 TO MSCL-1
160 PSET MMX+MC*MSCL+PC, MMY+MR*MSCL+PR, MC2
161 NEXT PC : NEXT PR
162 NEXT MC : NEXT MR
163 END SUB
164 REM ============================================================
165 REM DrawMinimap - Move player dot on minimap each frame
166 REM ============================================================
167 SUB DrawMinimap STATIC
168 SHARED PX, PZ, CELL, MSCL, MMX, MMY, MAP, MZ, MAPVIS
169 IF MAPVIS=0 THEN EXIT SUB
170 IF INITED=1 THEN GOTO CheckErase
171 OLDMR=-1 : OLDMC=-1 : INITED=1
172 CheckErase:
173 IF OLDMR<0 THEN GOTO DrawDot
174 IF MAP(OLDMR,OLDMC)=1 THEN OC=7 ELSE OC=15
175 FOR PR=0 TO MSCL-1
176 FOR PC=0 TO MSCL-1
177 PSET MMX+OLDMC*MSCL+PC, MMY+OLDMR*MSCL+PR, OC
178 NEXT PC : NEXT PR
179 DrawDot:
180 MR=INT(PZ/CELL) : MC=INT(PX/CELL)
181 OLDMR=MR : OLDMC=MC
182 PDX=MMX+MC*MSCL+INT(MSCL/2) : PDY=MMY+MR*MSCL+INT(MSCL/2)
183 PSET PDX,PDY,14 : PSET PDX+1,PDY,14 : PSET PDX,PDY+1,14 : PSET PDX+1,PDY+1,14
184 END SUB
185 REM ============================================================
186 REM ToggleMap - Show / hide minimap overlay
187 REM ============================================================
188 SUB ToggleMap STATIC
189 SHARED MAPVIS, MZ, MSCL, MMX, MMY
190 MAPVIS=1-MAPVIS
191 IF MAPVIS=1 THEN CALL InitMinimap : EXIT SUB
192 FOR CR=0 TO MZ*MSCL-1
193 FOR CC=0 TO MZ*MSCL-1
194 PSET MMX+CC, MMY+CR, 16
195 NEXT CC : NEXT CR
196 END SUB
197 REM ============================================================
198 REM ToggleFog - Toggle fog on/off
199 REM ============================================================
200 SUB ToggleFog STATIC
201 SHARED FOGON
202 FOGON=1-FOGON
203 IF FOGON=1 THEN GL.FOG 2,2,8,15,70
204 IF FOGON=0 THEN GL.FOGOFF
205 END SUB
206 REM ============================================================
207 REM UpdateCubeYaw - Cube facing snaps 90 deg once the mouse-look aim (PYAW) crosses 45 deg from it
208 REM ============================================================
209 SUB UpdateCubeYaw STATIC
210 SHARED PYAW, CUBEYAW, PI, PX, PZ, TRLID(), TRLCOUNT, TRLPCX, TRLPCZ, TRLTICK
211 DIFF=PYAW-CUBEYAW : TURNED=0
212 IF DIFF>PI*0.25 THEN TURNED=1
213 IF DIFF<0-PI*0.25 THEN TURNED=2
214 IF TURNED=0 THEN EXIT SUB
215 IF TURNED=1 THEN CUBEYAW=CUBEYAW+PI*0.5
216 IF TURNED=2 THEN CUBEYAW=CUBEYAW-PI*0.5
217 TRLTICK=0 : PYAW=CUBEYAW
218 IF ABS(PX-TRLPCX)<0.01 AND ABS(PZ-TRLPCZ)<0.01 THEN EXIT SUB
219 IF TRLCOUNT>=2000 THEN EXIT SUB
220 TRLCOUNT=TRLCOUNT+1
221 GL.SOLID : GL.COLOUR 0,200,255 : GL.SHINE 80 : GL.EMISSIVE 0,80,120 : GL.ALPHA 1.0
222 GL.BEGIN
223 GL.VERTEX TRLPCX,-0.85,TRLPCZ : GL.VERTEX TRLPCX,-1.35,TRLPCZ
224 GL.VERTEX PX,-1.35,PZ : GL.VERTEX PX,-0.85,PZ
225 GL.FACE 1,2,3,4 : GL.FACE 4,3,2,1
226 GL.END
227 TRLID(TRLCOUNT)=GL.MESHID
228 TRLPCX=PX : TRLPCZ=PZ
229 END SUB
230 REM ============================================================
231 REM BuildScene - GL init, floor, walls (no ceiling), player cube
232 REM ============================================================
233 SUB BuildScene STATIC
234 GL.INIT : GL.PERSPECTIVE 72 : GL.AMBIENT 0.5 : GL.FOG 2,2,8,15,70
235 REM ============================================================
236 REM Floor: dark blue-black
237 REM ============================================================
238 FL=16*5.0
239 GL.SOLID : GL.COLOUR 0,0,0 : GL.SHINE 200 : GL.EMISSIVE 0,0,0 : GL.ALPHA 1.0
240 GL.BEGIN
241 GL.VERTEX 0,0,0 : GL.VERTEX FL,0,0 : GL.VERTEX FL,0,FL : GL.VERTEX 0,0,FL
242 GL.FACE 1,2,3,4
243 GL.END
244 SHARED FLOORID
245 FLOORID=GL.MESHID : GL.TRANSLATE FLOORID,0,-1.4,0
246 REM ============================================================
247 REM Floor: untextured - plain black for the TRON grid look
248 REM Floor grid lines: grey, one per arena cell
249 REM ============================================================
250 GL.SOLID : GL.COLOUR 120,190,255 : GL.SHINE 10 : GL.EMISSIVE 40,100,200 : GL.ALPHA 1.0
251 GL.BEGIN
252 GLW=0.08 : GCELL=FL/16 : GVN=0
253 FOR GI=0 TO 16
254 GLP=GI*GCELL : GL.VERTEX GLP-GLW,0,0 : GL.VERTEX GLP+GLW,0,0 : GL.VERTEX GLP+GLW,0,FL : GL.VERTEX GLP-GLW,0,FL : GL.FACE GVN+1,GVN+2,GVN+3,GVN+4 : GVN=GVN+4
255 GL.VERTEX 0,0,GLP-GLW : GL.VERTEX FL,0,GLP-GLW : GL.VERTEX FL,0,GLP+GLW : GL.VERTEX 0,0,GLP+GLW : GL.FACE GVN+1,GVN+2,GVN+3,GVN+4 : GVN=GVN+4
256 NEXT GI
257 GL.END
258 GRIDID=GL.MESHID : GL.TRANSLATE GRIDID,0,-1.38,0
259 REM ============================================================
260 REM Walls: glowing blue TRON look (3x tall)
261 REM ============================================================
262 SHARED MAP, MZ, CELL
263 FOR WR=0 TO MZ-1
264 FOR WC=0 TO MZ-1
265 IF MAP(WR,WC)=0 THEN GOTO NextWall
266 WX1=WC*CELL : WX2=WX1+CELL : WZ1=WR*CELL : WZ2=WZ1+CELL
267 GL.SOLID : GL.COLOUR 0,80,255 : GL.EMISSIVE 0,50,180 : GL.SHINE 60 : GL.ALPHA 1.0
268 GL.BEGIN
269 GL.VERTEX WX1,-1.4,WZ1 : GL.VERTEX WX2,-1.4,WZ1
270 GL.VERTEX WX2, 7.0,WZ1 : GL.VERTEX WX1, 7.0,WZ1
271 GL.VERTEX WX1,-1.4,WZ2 : GL.VERTEX WX2,-1.4,WZ2
272 GL.VERTEX WX2, 7.0,WZ2 : GL.VERTEX WX1, 7.0,WZ2
273 GL.FACE 1,2,3,4 : GL.FACE 8,7,6,5
274 GL.FACE 5,1,4,8 : GL.FACE 2,6,7,3
275 GL.FACE 5,6,2,1 : GL.FACE 4,3,7,8
276 GL.END
277 NextWall:
278 NEXT WC : NEXT WR
279 REM ============================================================
280 REM Player: load the Tron lightcycle model (sized to match the old cube)
281 REM ============================================================
282 GL.LOAD "files/models/LIGHTCYCLE.glb"
283 SHARED CUBEID, TWOP, CUBEID2
284 CUBEID=GL.MESHID
285 GL.SCALE CUBEID, 0.275, 0.275, 0.55
286 IF TWOP=0 THEN GOTO BSNoP2
287 GL.LOAD "files/models/LIGHTCYCLE.glb"
288 CUBEID2=GL.MESHID
289 GL.SCALE CUBEID2, 0.275, 0.275, 0.55
290 BSNoP2:
291 GL.BLOOM 0.6
292 GL.FPS 1 : GL.AA 1
293 END SUB
294 REM ============================================================
295 REM Move - Collision-checked player movement
296 REM ============================================================
297 SUB Move
298 SHARED PX, PZ, DX, DZ, MZ, CELL, MAP
299 M=0.35 : NX=PX+DX : NZ=PZ+DZ
300 R1=INT((NZ-M)/CELL) : R2=INT((NZ+M)/CELL)
301 C1=INT((NX-M)/CELL) : C2=INT((NX+M)/CELL)
302 IF R1<0 OR R2>=MZ OR C1<0 OR C2>=MZ THEN GOTO SlideX
303 IF MAP(R1,C1)<>0 OR MAP(R1,C2)<>0 OR MAP(R2,C1)<>0 OR MAP(R2,C2)<>0 THEN GOTO SlideX
304 PX=NX : PZ=NZ : EXIT SUB
305 SlideX:
306 NX=PX+DX : NZ=PZ
307 R1=INT((NZ-M)/CELL) : R2=INT((NZ+M)/CELL)
308 C1=INT((NX-M)/CELL) : C2=INT((NX+M)/CELL)
309 IF R1<0 OR R2>=MZ OR C1<0 OR C2>=MZ THEN GOTO SlideZ
310 IF MAP(R1,C1)<>0 OR MAP(R1,C2)<>0 OR MAP(R2,C1)<>0 OR MAP(R2,C2)<>0 THEN GOTO SlideZ
311 PX=NX : EXIT SUB
312 SlideZ:
313 NX=PX : NZ=PZ+DZ
314 R1=INT((NZ-M)/CELL) : R2=INT((NZ+M)/CELL)
315 C1=INT((NX-M)/CELL) : C2=INT((NX+M)/CELL)
316 IF R1<0 OR R2>=MZ OR C1<0 OR C2>=MZ THEN EXIT SUB
317 IF MAP(R1,C1)<>0 OR MAP(R1,C2)<>0 OR MAP(R2,C1)<>0 OR MAP(R2,C2)<>0 THEN EXIT SUB
318 PZ=NZ
319 END SUB
320 REM ============================================================
321 REM DropTrail - one ribbon segment as two instanced strips (rails + centre)
322 REM ============================================================
323 SUB DropTrail STATIC
324 SHARED PX, PZ, CUBEYAW, TRLCOUNT, TRLPCX, TRLPCZ, JUMPY, TRLPCY, RAILID, CTRID
325 BCX=PX-COS(CUBEYAW)*0.4 : BCZ=PZ-SIN(CUBEYAW)*0.4
