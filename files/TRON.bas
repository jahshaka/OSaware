405 GL.VERTEX 0,0,GP-GW : GL.VERTEX FL,0,GP-GW : GL.VERTEX FL,0,GP+GW : GL.VERTEX 0,0,GP+GW : GL.FACE VN+1,VN+2,VN+3,VN+4 : GL.FACE VN+4,VN+3,VN+2,VN+1 : VN=VN+4
