1 REM ============================================================
2 REM  TRON  --  3D lightcycle arena  (runs on the GL3D engine)
3 REM  Start menu:  D = demo (the bike drives itself)   2 = 2-player (a red AI bike chases you)
4 REM              any other key = play   |   Q or Esc = quit
5 REM  In game:    mouse = steer    W / Up = forward    A = auto-run    Space = jump    C = camera
6 REM              M = map   L = lights   F = fog   Z = wireframe   B = bloom   G = anti-alias   S = fps   T = turn mode
7 REM              Q or Esc = back to the start menu (Q there exits the program)
8 REM  Structure (top to bottom):  START MENU & SETUP  ->  MAIN LOOP  ->  END  ->  SUBROUTINES  ->
9 REM                              GAME OVER  ->  DEMO LOOP  ->  2-PLAYER LOOP
10 REM  1-player runs MAIN LOOP; "D" jumps to DEMO LOOP; "2" jumps to 2-PLAYER LOOP. All three share the
11 REM  SUBROUTINES. Quitting any mode goes to GAME OVER, which tears GL down and returns to the start menu.
12 REM  START MENU & SETUP
13 REM Start menu: print the splash + controls, read one key, then either exit or fall through into setup.
14 REM ============================================================
15 StartMenu:
16 CLS : COLOUR 3
17 PRINT "  T R O N    -    Lightcycle Arena"
18 COLOUR 7
19 PRINT ""
20 PRINT "  Mouse: turn      W or Up: forward      Space: jump"
21 PRINT ""
22 PRINT "  A : auto-run        Z : wireframe"
23 PRINT "  C : camera          B : bloom"
24 PRINT "  M : map             G : anti-alias"
25 PRINT "  L : lights          S : fps"
26 PRINT "  F : fog"
27 COLOUR 3
28 PRINT ""
29 PRINT "     D  ......  DEMO        the bike drives itself"
30 PRINT "     2  ......  2-PLAYER    a red bike chases you"
31 PRINT "     . . .  or press any other key to PLAY"
32 PRINT ""
33 PRINT "  Q  or  Esc :  back to this menu"
34 DK=GETKEY()
35 IF DK=81 OR DK=113 OR DK=27 THEN FULLSCREEN OFF : UI ON : END
36 FULLSCREEN ON : UI OFF
37 MZ=16 : CELL=5.0 : WALLY=1.4 : SPEED=0.08 : TSPD=0.016 : GRAV=0.006 : JUMPV0=0.09
38 PI=4*ATN(1)
39 CAMDIST=7.2 : CAMHT=4.0 : CAMDIST2=3.5 : CAMHT2=1.8 : D10=PI*10/180 : D20=PI*20/180 : TSLOW=PI*2/180 : TQUICK=PI*8/180 : MAXD=100 : PMAX=PI*15/180 : DSPD=0.11
40 FOGON=1
41 ARENACX=16*5.0/2 : CYCOFF=0
42 DEMO=0 : TWOP=0 : IF DK=68 OR DK=100 THEN DEMO=1
43 IF DK=50 THEN TWOP=1
