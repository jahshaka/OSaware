443 REM ============================================================
444 REM  DEMO LOOP  --  autonomous lightcycle (press D at the menu). Steers to dodge walls and ribbon.
445 REM ============================================================
446 DemoLoop:
447 K=INKEY
448 IF K=81 OR K=113 OR K=27 THEN GOTO GameOver
449 IF K=71 OR K=103 THEN AAON=1-AAON : GL.AA AAON
450 IF K=66 OR K=98 THEN BLOOMON=1-BLOOMON : IF BLOOMON=1 THEN GL.BLOOM 0.6 ELSE GL.BLOOM 0
451 IF K=76 OR K=108 THEN LIGHTON=1-LIGHTON
452 IF K=90 OR K=122 THEN WIREMODE=1-WIREMODE : GL.WIREALL WIREMODE
453 IF K=83 OR K=115 THEN FPSON=1-FPSON : GL.FPS FPSON
454 IF K=77 OR K=109 THEN CALL ToggleMap
455 IF K=70 OR K=102 THEN CALL ToggleFog
456 DT=1
457 LX=PX+COS(CUBEYAW)*8 : LZ=PZ+SIN(CUBEYAW)*8 : NEARW=0
458 IF LX<5 OR LX>75 OR LZ<5 OR LZ>75 THEN NEARW=1
459 FLX=PX+COS(CUBEYAW-0.6)*7 : FLZ=PZ+SIN(CUBEYAW-0.6)*7
460 IF FLX<5 OR FLX>75 OR FLZ<5 OR FLZ>75 THEN NEARW=1
461 FRX=PX+COS(CUBEYAW+0.6)*7 : FRZ=PZ+SIN(CUBEYAW+0.6)*7
462 IF FRX<5 OR FRX>75 OR FRZ<5 OR FRZ>75 THEN NEARW=1
463 LRX=PX+COS(CUBEYAW)*6 : LRZ=PZ+SIN(CUBEYAW)*6 : NEARR=0
464 RCX=INT(LRX/CELL) : RCZ=INT(LRZ/CELL)
465 IF RCX<0 OR RCX>=MZ OR RCZ<0 OR RCZ>=MZ THEN GOTO DLNoR
466 IF TRAIL(RCZ,RCX)<>0 THEN NEARR=1
467 DLNoR:
468 MCX=INT(PX/CELL) : MCZ=INT(PZ/CELL)
469 IF MCX>=0 AND MCX<MZ AND MCZ>=0 AND MCZ<MZ THEN TRAIL(MCZ,MCX)=1
470 IF WALLCD>0 THEN WALLCD=WALLCD-1
471 IF RIBCD>0 THEN RIBCD=RIBCD-1
472 DTMR=DTMR-1
473 IF NEARW=1 AND WALLCD<=0 THEN GOTO DLWall
474 IF NEARR=1 AND RIBCD<=0 THEN GOTO DLRib
475 IF DTMR>0 THEN GOTO DLGO
476 RR=INT(RND(1)*3) : TANG=0.2618 : TRATE=0.005 : IF RR=1 THEN TANG=0.7854
477 IF RR=1 THEN TRATE=0.025
478 IF RR=2 THEN TANG=1.5708
479 IF RR=2 THEN TRATE=0.08
480 IF RND(1)>0.5 THEN PYAW=CUBEYAW+TANG ELSE PYAW=CUBEYAW-TANG
481 DTMR=45+INT(RND(1)*90)
482 GOTO DLGO
483 DLWall:
484 TRATE=0.12 : WALLCD=28 : DTMR=45+INT(RND(1)*90)
485 HLX=PX+COS(CUBEYAW-2.5)*9 : HLZ=PZ+SIN(CUBEYAW-2.5)*9 : LCLR=1
486 IF HLX<5 OR HLX>75 OR HLZ<5 OR HLZ>75 THEN LCLR=0
487 HRX=PX+COS(CUBEYAW+2.5)*9 : HRZ=PZ+SIN(CUBEYAW+2.5)*9 : RCLR=1
488 IF HRX<5 OR HRX>75 OR HRZ<5 OR HRZ>75 THEN RCLR=0
489 WS=1
490 IF LCLR=1 THEN WS=-1
491 IF LCLR=1 AND RCLR=1 AND RND(1)>0.5 THEN WS=1
492 IF LCLR=0 AND RCLR=0 THEN WS=0
493 PYAW=CUBEYAW+WS*2.5
494 IF WS=0 THEN PYAW=CUBEYAW+3.14159
495 GOTO DLGO
496 DLRib:
497 RIBCD=20
498 LJX=PX+COS(CUBEYAW)*3 : LJZ=PZ+SIN(CUBEYAW)*3
499 JRX=INT(LJX/CELL) : JRZ=INT(LJZ/CELL)
500 IF JRX<0 OR JRX>=MZ OR JRZ<0 OR JRZ>=MZ THEN GOTO DLRibTurn
501 IF JRX=MCX AND JRZ=MCZ THEN GOTO DLRibTurn
502 IF TRAIL(JRZ,JRX)=0 THEN GOTO DLRibTurn
503 IF JUMPY<>0 OR JUMPV<>0 THEN GOTO DLRibTurn
504 JUMPV=JUMPV0 : RIBCD=25
505 GOTO DLGO
506 DLRibTurn:
507 TRATE=0.10 : IF RND(1)>0.5 THEN PYAW=CUBEYAW+1.5708 ELSE PYAW=CUBEYAW-1.5708
508 DTMR=45+INT(RND(1)*90)
509 GOTO DLGO
510 DLGO:
511 GAP=PYAW-CUBEYAW : IF ABS(GAP)<=TRATE THEN CUBEYAW=PYAW ELSE CUBEYAW=CUBEYAW+SGN(GAP)*TRATE
512 DX=COS(CUBEYAW)*DSPD : DZ=SIN(CUBEYAW)*DSPD
513 CALL Move
514 JUMPY=JUMPY+JUMPV : JUMPV=JUMPV-GRAV
515 IF JUMPY<0 THEN JUMPY=0
516 IF JUMPY=0 THEN JUMPV=0
517 TRLTICK=TRLTICK+1
518 IF TRLTICK>=1.5 THEN TRLTICK=TRLTICK-1.5 : CALL DropTrail
519 DEMOT=DEMOT+1 : CAMA=CAMA+(CUBEYAW-CAMA)*0.12 : SWA=SIN(DEMOT*0.02)*0.175 : CYCT=CYCT+1 : IF CYCT>=180 THEN CYCT=0 : DEMOCAM=1-DEMOCAM
520 CD=7.2-DEMOCAM*3.7 : CH=4-DEMOCAM*2.2 : CLY=0.6-DEMOCAM*0.3 : GL.CAMERA PX-COS(CAMA+SWA)*CD,CH,PZ-SIN(CAMA+SWA)*CD : GL.LOOKAT PX,CLY,PZ
521 GL.LIGHTSOFF : IF LIGHTON=1 AND WIREMODE=0 THEN GL.RECTLIGHT PX,2.5,PZ, 8,8, 200,215,255, 30
522 GL.TRANSLATE CUBEID, PX, JUMPY-1.1, PZ
523 GL.ROTATE CUBEID, 0, -CUBEYAW*180/PI+CYCOFF, 0
524 CALL DrawMinimap
525 LOCATE 1,1 : PRINT "DEMO   px=" ; INT(PX*10) ; " pz=" ; INT(PZ*10) ; " yaw=" ; INT(CUBEYAW*100) ; " trl=" ; TRLCOUNT ; "    "
526 GL.CLS 2,2,8 : GL.DRAWALL
527 SLEEP 16 : GOTO DemoLoop
