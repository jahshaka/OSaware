6250 REM === 2-PLAYER loop - P1 = the regular game; P2 = an autonomous red bike that chases P1 ===
6251 TwoPlayerInit:
6252 PX2=PX : PZ2=PZ+6 : CUBEYAW2=0
6253 TRLPCX2=PX2-0.4 : TRLPCZ2=PZ2 : TRLPCY2=0 : STARTED=0 : PTMR=0
6254 TwoPlayerLoop:
6255 K=INKEY
6256 IF K=81 OR K=113 OR K=27 THEN GOTO GameOver
6257 IF K=77 OR K=109 THEN CALL ToggleMap
6258 IF K=70 OR K=102 THEN CALL ToggleFog
6259 NOW=TIMER : DT=(NOW-LASTT)/16 : DT=(4+DT-ABS(4-DT))/2 : LASTT=NOW : LASTYAW=CUBEYAW : IF K=84 OR K=116 THEN TURNMODE=1-TURNMODE : TURNTGT=CUBEYAW : PYAW=CUBEYAW
6260 MX=MOUSE(1) : DMX=MX-LASTMX : LASTMX=MX : MY=MOUSE(2) : DMY=MY-LASTMY : LASTMY=MY : IF MOUSE(0)<0 AND ABS(DMX)<MAXD THEN PYAW=PYAW+DMX*TSPD : IF MOUSE(0)<0 AND ABS(DMY)<MAXD THEN CAMPITCH=CAMPITCH-DMY*TSPD : IF ABS(CAMPITCH)>PMAX THEN CAMPITCH=SGN(CAMPITCH)*PMAX
6261 CALL DoTurn
6262 IF K=71 OR K=103 THEN AAON=1-AAON : GL.AA AAON
6263 IF ABS(PYAW-CUBEYAW)>D10 THEN SPDCUR=SPEED
6264 SPDCUR=SPDCUR+0.0015*DT : IF SPDCUR>0.3 THEN SPDCUR=0.3
6265 DX=0 : DZ=0 : IF K=83 OR K=115 THEN FPSON=1-FPSON : GL.FPS FPSON
6266 IF KEYDOWN(87) OR KEYDOWN(38) OR AUTORUN=1 THEN DX=COS(CUBEYAW)*SPDCUR*DT : DZ=SIN(CUBEYAW)*SPDCUR*DT
6267 IF K=65 OR K=97 THEN AUTORUN=1-AUTORUN
6268 IF STARTED=0 AND KEYDOWN(87) THEN STARTED=1 : PTMR=60
6269 IF PTMR>0 THEN PTMR=PTMR-DT
6270 IF DX<>0 OR DZ<>0 THEN CALL Move
6271 IF DX<>0 OR DZ<>0 THEN MOVING=1 ELSE MOVING=0
6272 REM --- P2 (autonomous) - waits ~1s after P1 first presses W, then chases P1 ---
6273 IF STARTED=0 OR PTMR>0 THEN GOTO TPSKIP
6274 TX=PX-PX2 : TZ=PZ-PZ2 : DST=SQR(TX*TX+TZ*TZ)
6275 IF DST<0.01 THEN DST=0.01
6276 CX=COS(CUBEYAW2) : CZ=SIN(CUBEYAW2)
6277 CROSS=(CX*TZ-CZ*TX)/DST : FWD=(CX*TX+CZ*TZ)/DST
6278 TRATE=0.06 : TURN=CROSS
6279 IF TURN>TRATE THEN TURN=TRATE
6280 IF TURN<0-TRATE THEN TURN=0-TRATE
6281 IF FWD<0 AND ABS(CROSS)<0.05 THEN TURN=TRATE
6282 CUBEYAW2=CUBEYAW2+TURN*DT
6283 DX2=COS(CUBEYAW2)*SPDCUR*0.83*DT : DZ2=SIN(CUBEYAW2)*SPDCUR*0.83*DT
6284 NX2=PX2+DX2 : NZ2=PZ2+DZ2 : MM=0.35
6285 RR1=INT((NZ2-MM)/CELL) : RR2=INT((NZ2+MM)/CELL) : CC1=INT((NX2-MM)/CELL) : CC2=INT((NX2+MM)/CELL)
6286 IF RR1<0 OR RR2>=MZ OR CC1<0 OR CC2>=MZ THEN GOTO TPSlideX
6287 IF MAP(RR1,CC1)<>0 OR MAP(RR1,CC2)<>0 OR MAP(RR2,CC1)<>0 OR MAP(RR2,CC2)<>0 THEN GOTO TPSlideX
6288 PX2=NX2 : PZ2=NZ2 : GOTO TPMoveDone
6289 TPSlideX:
6290 NX2=PX2+DX2 : NZ2=PZ2
6291 RR1=INT((NZ2-MM)/CELL) : RR2=INT((NZ2+MM)/CELL) : CC1=INT((NX2-MM)/CELL) : CC2=INT((NX2+MM)/CELL)
6292 IF RR1<0 OR RR2>=MZ OR CC1<0 OR CC2>=MZ THEN GOTO TPSlideZ
6293 IF MAP(RR1,CC1)<>0 OR MAP(RR1,CC2)<>0 OR MAP(RR2,CC1)<>0 OR MAP(RR2,CC2)<>0 THEN GOTO TPSlideZ
6294 PX2=NX2 : GOTO TPMoveDone
6295 TPSlideZ:
6296 NX2=PX2 : NZ2=PZ2+DZ2
6297 RR1=INT((NZ2-MM)/CELL) : RR2=INT((NZ2+MM)/CELL) : CC1=INT((NX2-MM)/CELL) : CC2=INT((NX2+MM)/CELL)
6298 IF RR1<0 OR RR2>=MZ OR CC1<0 OR CC2>=MZ THEN GOTO TPMoveDone
6299 IF MAP(RR1,CC1)<>0 OR MAP(RR1,CC2)<>0 OR MAP(RR2,CC1)<>0 OR MAP(RR2,CC2)<>0 THEN GOTO TPMoveDone
6300 PZ2=NZ2
6301 TPMoveDone:
6302 TPSKIP:
6303 TRLTICK=TRLTICK+DT
6304 IF TRLTICK<1.5 THEN GOTO TPNoDrop
6305 TRLTICK=TRLTICK-1.5
6306 CALL DropTrail
6307 IF STARTED=0 OR PTMR>0 THEN GOTO TPNoDrop
6308 BX2=PX2-COS(CUBEYAW2)*0.4 : BZ2=PZ2-SIN(CUBEYAW2)*0.4
6309 RDOT=(BX2-TRLPCX2)*COS(CUBEYAW2)+(BZ2-TRLPCZ2)*SIN(CUBEYAW2)
6310 IF RDOT<=0 THEN GOTO TPNoDrop
6311 RSDX=BX2-TRLPCX2 : RSDZ=BZ2-TRLPCZ2 : RDY=JUMPY-TRLPCY2
6312 GL.INSTANCE RAILID2, TRLPCX2, TRLPCY2-1.10, TRLPCZ2, RSDX, RDY, RSDZ
6313 GL.INSTANCE CTRID2, TRLPCX2, TRLPCY2-1.10, TRLPCZ2, RSDX, RDY, RSDZ
6314 TRLPCX2=BX2 : TRLPCZ2=BZ2 : TRLPCY2=JUMPY
6315 TPNoDrop:
6316 IF K=67 OR K=99 THEN CAMMODE=CAMMODE+1
6317 IF CAMMODE>2 THEN CAMMODE=0
6318 CAMX=PX-COS(PYAW)*CAMDIST : CAMZ=PZ-SIN(PYAW)*CAMDIST
6319 IF CAMMODE=0 THEN GL.CAMERA CAMX,CAMHT,CAMZ : GL.LOOKAT PX,CAMDIST*CAMPITCH+0.6,PZ
6320 IF CAMMODE=1 THEN GL.CAMERA PX-COS(PYAW)*CAMDIST2,CAMHT2,PZ-SIN(PYAW)*CAMDIST2 : GL.LOOKAT PX,CAMDIST2*CAMPITCH+0.1,PZ
6321 IF CAMMODE=2 THEN GL.CAMERA PX-COS(CUBEYAW)*0.2,JUMPY-0.6,PZ-SIN(CUBEYAW)*0.2 : GL.LOOKAT PX+COS(CUBEYAW)*10,JUMPY-1.1+10*CAMPITCH,PZ+SIN(CUBEYAW)*10
6322 GL.LIGHTSOFF : IF LIGHTON=1 AND WIREMODE=0 THEN GL.RECTLIGHT PX,2.5,PZ, 8,8, 200,215,255, 30
6323 IF K=66 OR K=98 THEN BLOOMON=1-BLOOMON : IF BLOOMON=1 THEN GL.BLOOM 0.6 ELSE GL.BLOOM 0
6324 GL.TRANSLATE CUBEID, PX, JUMPY-1.1, PZ
6325 GL.ROTATE CUBEID, 0, -CUBEYAW*180/PI+CYCOFF, 0
6326 GL.TRANSLATE CUBEID2, PX2, JUMPY-1.1, PZ2
6327 GL.ROTATE CUBEID2, 0, -CUBEYAW2*180/PI+CYCOFF, 0
6328 CALL DrawMinimap
6329 LOCATE 1,1 : PRINT "2-PLAYER  P1=" ; INT(PX*10) ; "," ; INT(PZ*10) ; "  P2(red)=" ; INT(PX2*10) ; "," ; INT(PZ2*10) ; "    " : GL.CLS 2,2,8 : GL.DRAWALL
6330 IF K=32 AND JUMPV=0 AND JUMPY=0 THEN JUMPV=JUMPV0
6331 JUMPY=JUMPY+JUMPV*DT
6332 JUMPV=JUMPV-GRAV*DT
6333 IF JUMPY<0 THEN JUMPY=0
6334 IF JUMPY=0 THEN JUMPV=0
6335 IF K=76 OR K=108 THEN LIGHTON=1-LIGHTON
6336 IF K=90 OR K=122 THEN WIREMODE=1-WIREMODE : GL.WIREALL WIREMODE
6337 SLEEP 16 : GOTO TwoPlayerLoop
