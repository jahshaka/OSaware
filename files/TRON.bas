6109 FRX=PX+COS(CUBEYAW+0.6)*7 : FRZ=PZ+SIN(CUBEYAW+0.6)*7
6110 IF FRX<5 OR FRX>75 OR FRZ<5 OR FRZ>75 THEN NEARW=1
6111 LRX=PX+COS(CUBEYAW)*6 : LRZ=PZ+SIN(CUBEYAW)*6 : NEARR=0
6112 RCX=INT(LRX/CELL) : RCZ=INT(LRZ/CELL)
6113 IF RCX<0 OR RCX>=MZ OR RCZ<0 OR RCZ>=MZ THEN GOTO DLNoR
