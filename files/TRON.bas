386 FOR I=0 TO 16
387 ZP=I*CELL : GL.VERTEX WX,YB,ZP-GW : GL.VERTEX WX,YB,ZP+GW : GL.VERTEX WX,YT,ZP+GW : GL.VERTEX WX,YT,ZP-GW : GL.FACE VN+1,VN+2,VN+3,VN+4 : VN=VN+4
388 NEXT I
389 FOR J=0 TO 2
390 YP=YB+J*CELL : IF J=2 THEN YP=YT
391 GL.VERTEX WX,YP-GW,0 : GL.VERTEX WX,YP-GW,FL : GL.VERTEX WX,YP+GW,FL : GL.VERTEX WX,YP+GW,0 : GL.FACE VN+1,VN+2,VN+3,VN+4 : VN=VN+4
392 NEXT J
