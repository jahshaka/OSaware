378 YP=YB+J*CELL : IF J=2 THEN YP=YT
379 GL.VERTEX WX,YP-GW,0 : GL.VERTEX WX,YP-GW,FL : GL.VERTEX WX,YP+GW,FL : GL.VERTEX WX,YP+GW,0 : GL.FACE VN+1,VN+2,VN+3,VN+4 : VN=VN+4
380 NEXT J
381 GL.END
