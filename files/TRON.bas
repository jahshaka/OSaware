542 REM ============================================================
543 REM  2-PLAYER LOOP  --  P1 = you (mouse-steered); P2 = an autonomous red bike that chases you (press 2)
544 REM ============================================================
545 TwoPlayerInit:
546 PX2=PX : PZ2=PZ+6 : CUBEYAW2=0
547 TRLPCX2=PX2-0.4 : TRLPCZ2=PZ2 : TRLPCY2=0 : STARTED=0 : PTMR=0
548 TwoPlayerLoop:
549 K=INKEY
550 IF K=81 OR K=113 OR K=27 THEN GOTO GameOver
551 IF K=77 OR K=109 THEN CALL ToggleMap
552 IF K=70 OR K=102 THEN CALL ToggleFog
553 NOW=TIMER : DT=(NOW-LASTT)/16 : DT=(4+DT-ABS(4-DT))/2 : LASTT=NOW : LASTYAW=CUBEYAW : IF K=84 OR K=116 THEN TURNMODE=1-TURNMODE : TURNTGT=CUBEYAW : PYAW=CUBEYAW
554 MX=MOUSE(1) : DMX=MX-LASTMX : LASTMX=MX : MY=MOUSE(2) : DMY=MY-LASTMY : LASTMY=MY : IF MOUSE(0)<0 AND ABS(DMX)<MAXD THEN PYAW=PYAW+DMX*TSPD : IF MOUSE(0)<0 AND ABS(DMY)<MAXD THEN CAMPITCH=CAMPITCH-DMY*TSPD : IF ABS(CAMPITCH)>PMAX THEN CAMPITCH=SGN(CAMPITCH)*PMAX
555 CALL DoTurn
556 IF K=71 OR K=103 THEN AAON=1-AAON : GL.AA AAON
557 IF ABS(PYAW-CUBEYAW)>D10 THEN SPDCUR=SPEED
558 SPDCUR=SPDCUR+0.0015*DT : IF SPDCUR>0.3 THEN SPDCUR=0.3
559 DX=0 : DZ=0 : IF K=83 OR K=115 THEN FPSON=1-FPSON : GL.FPS FPSON
560 IF KEYDOWN(87) OR KEYDOWN(38) OR AUTORUN=1 THEN DX=COS(CUBEYAW)*SPDCUR*DT : DZ=SIN(CUBEYAW)*SPDCUR*DT
561 IF K=65 OR K=97 THEN AUTORUN=1-AUTORUN
562 IF STARTED=0 AND KEYDOWN(87) THEN STARTED=1 : PTMR=60
563 IF PTMR>0 THEN PTMR=PTMR-DT
564 IF DX<>0 OR DZ<>0 THEN CALL Move
565 IF DX<>0 OR DZ<>0 THEN MOVING=1 ELSE MOVING=0
566 IF STARTED=1 THEN RBI=INT(PZ-SIN(CUBEYAW)*0.4) : RBJ=INT(PX-COS(CUBEYAW)*0.4) : RBI2=INT(PZ) : RBJ2=INT(PX) : RIBWAL(RBI,RBJ)=1 : RIBWAL(RBI2,RBJ2)=1
567 IF STARTED=0 OR PTMR>0 THEN GOTO TPSKIP
568 TX=PX-PX2 : TZ=PZ-PZ2 : DST=SQR(TX*TX+TZ*TZ)
569 IF DST<0.01 THEN DST=0.01
570 CX=COS(CUBEYAW2) : CZ=SIN(CUBEYAW2)
571 CROSS=(CX*TZ-CZ*TX)/DST : FWD=(CX*TX+CZ*TZ)/DST
572 TRATE=0.06 : TURN=CROSS
573 IF TURN>TRATE THEN TURN=TRATE
574 IF TURN<0-TRATE THEN TURN=0-TRATE
575 IF FWD<0 AND ABS(CROSS)<0.05 THEN TURN=TRATE
576 CUBEYAW2=CUBEYAW2+TURN*DT : GOSUB AvoidRibbon
577 DX2=COS(CUBEYAW2)*SPDCUR*0.88*DT : DZ2=SIN(CUBEYAW2)*SPDCUR*0.88*DT
578 NX2=PX2+DX2 : NZ2=PZ2+DZ2 : MM=0.35
579 RR1=INT((NZ2-MM)/CELL) : RR2=INT((NZ2+MM)/CELL) : CC1=INT((NX2-MM)/CELL) : CC2=INT((NX2+MM)/CELL)
580 IF RR1<0 OR RR2>=MZ OR CC1<0 OR CC2>=MZ THEN GOTO TPSlideX
581 IF MAP(RR1,CC1)<>0 OR MAP(RR1,CC2)<>0 OR MAP(RR2,CC1)<>0 OR MAP(RR2,CC2)<>0 THEN GOTO TPSlideX
582 PX2=NX2 : PZ2=NZ2 : GOTO TPMoveDone
583 TPSlideX:
584 NX2=PX2+DX2 : NZ2=PZ2
585 RR1=INT((NZ2-MM)/CELL) : RR2=INT((NZ2+MM)/CELL) : CC1=INT((NX2-MM)/CELL) : CC2=INT((NX2+MM)/CELL)
586 IF RR1<0 OR RR2>=MZ OR CC1<0 OR CC2>=MZ THEN GOTO TPSlideZ
587 IF MAP(RR1,CC1)<>0 OR MAP(RR1,CC2)<>0 OR MAP(RR2,CC1)<>0 OR MAP(RR2,CC2)<>0 THEN GOTO TPSlideZ
588 PX2=NX2 : GOTO TPMoveDone
589 TPSlideZ:
590 NX2=PX2 : NZ2=PZ2+DZ2
591 RR1=INT((NZ2-MM)/CELL) : RR2=INT((NZ2+MM)/CELL) : CC1=INT((NX2-MM)/CELL) : CC2=INT((NX2+MM)/CELL)
592 IF RR1<0 OR RR2>=MZ OR CC1<0 OR CC2>=MZ THEN GOTO TPMoveDone
593 IF MAP(RR1,CC1)<>0 OR MAP(RR1,CC2)<>0 OR MAP(RR2,CC1)<>0 OR MAP(RR2,CC2)<>0 THEN GOTO TPMoveDone
594 PZ2=NZ2
595 TPMoveDone:
596 TPSKIP:
597 TRLTICK=TRLTICK+DT
598 IF TRLTICK<1.5 THEN GOTO TPNoDrop
599 TRLTICK=TRLTICK-1.5
600 CALL DropTrail
601 IF STARTED=0 OR PTMR>0 THEN GOTO TPNoDrop
602 BX2=PX2-COS(CUBEYAW2)*0.4 : BZ2=PZ2-SIN(CUBEYAW2)*0.4
603 RDOT=(BX2-TRLPCX2)*COS(CUBEYAW2)+(BZ2-TRLPCZ2)*SIN(CUBEYAW2)
604 IF RDOT<=0 THEN GOTO TPNoDrop
605 RSDX=BX2-TRLPCX2 : RSDZ=BZ2-TRLPCZ2 : RDY=JUMPY-TRLPCY2
606 GL.INSTANCE RAILID2, TRLPCX2, TRLPCY2-1.10, TRLPCZ2, RSDX, RDY, RSDZ
607 GL.INSTANCE CTRID2, TRLPCX2, TRLPCY2-1.10, TRLPCZ2, RSDX, RDY, RSDZ
608 TRLPCX2=BX2 : TRLPCZ2=BZ2 : TRLPCY2=JUMPY
609 TPNoDrop:
610 IF K=67 OR K=99 THEN CAMMODE=CAMMODE+1
611 IF CAMMODE>2 THEN CAMMODE=0
612 CAMX=PX-COS(PYAW)*CAMDIST : CAMZ=PZ-SIN(PYAW)*CAMDIST
613 IF CAMMODE=0 THEN GL.CAMERA CAMX,CAMHT,CAMZ : GL.LOOKAT PX,CAMDIST*CAMPITCH+0.6,PZ
614 IF CAMMODE=1 THEN GL.CAMERA PX-COS(PYAW)*CAMDIST2,CAMHT2,PZ-SIN(PYAW)*CAMDIST2 : GL.LOOKAT PX,CAMDIST2*CAMPITCH+0.1,PZ
615 IF CAMMODE=2 THEN GL.CAMERA PX-COS(CUBEYAW)*0.2,JUMPY-0.6,PZ-SIN(CUBEYAW)*0.2 : GL.LOOKAT PX+COS(CUBEYAW)*10,JUMPY-1.1+10*CAMPITCH,PZ+SIN(CUBEYAW)*10
616 GL.LIGHTSOFF : IF LIGHTON=1 AND WIREMODE=0 THEN GL.RECTLIGHT PX,2.5,PZ, 8,8, 200,215,255, 30
617 IF K=66 OR K=98 THEN BLOOMON=1-BLOOMON : IF BLOOMON=1 THEN GL.BLOOM 0.6 ELSE GL.BLOOM 0
618 GL.TRANSLATE CUBEID, PX, JUMPY-1.1, PZ
619 GL.ROTATE CUBEID, 0, -CUBEYAW*180/PI+CYCOFF, 0
620 GL.TRANSLATE CUBEID2, PX2, JUMPY-1.1, PZ2
621 GL.ROTATE CUBEID2, 0, -CUBEYAW2*180/PI+CYCOFF, 0
622 CALL DrawMinimap
623 LOCATE 1,1 : PRINT "2-PLAYER  P1=" ; INT(PX*10) ; "," ; INT(PZ*10) ; "  P2(red)=" ; INT(PX2*10) ; "," ; INT(PZ2*10) ; "    " : GL.CLS 2,2,8 : GL.DRAWALL
624 IF K=32 AND JUMPV=0 AND JUMPY=0 THEN JUMPV=JUMPV0
625 JUMPY=JUMPY+JUMPV*DT
626 JUMPV=JUMPV-GRAV*DT
627 IF JUMPY<0 THEN JUMPY=0
628 IF JUMPY=0 THEN JUMPV=0
629 IF K=76 OR K=108 THEN LIGHTON=1-LIGHTON
630 IF K=90 OR K=122 THEN WIREMODE=1-WIREMODE : GL.WIREALL WIREMODE
631 SLEEP 16 : GOTO TwoPlayerLoop
632 REM ============================================================
633 REM AvoidRibbon - GOSUB target (2-player only). Feels ahead of P2 for P1 blue-ribbon cells (RIBWAL). If any are near, cancels this frame chase-turn and steers P2 away so it rounds the ribbon instead of driving through it.
634 REM ============================================================
635 AvoidRibbon:
636 AFD=7 : ASIDE=0.5 : ATURN=0.10
637 AFX=PX2+COS(CUBEYAW2)*5 : AFZ=PZ2+SIN(CUBEYAW2)*5 : AFI=INT(AFZ) : AFJ=INT(AFX) : AHF=0
638 IF AFI>=1 AND AFI<=78 AND AFJ>=1 AND AFJ<=78 THEN IF RIBWAL(AFI,AFJ)<>0 THEN AHF=1
639 ALX=PX2+COS(CUBEYAW2-ASIDE)*AFD : ALZ=PZ2+SIN(CUBEYAW2-ASIDE)*AFD : ALI=INT(ALZ) : ALJ=INT(ALX) : AHL=0
640 IF ALI>=1 AND ALI<=78 AND ALJ>=1 AND ALJ<=78 THEN IF RIBWAL(ALI,ALJ)<>0 THEN AHL=1
641 ARX=PX2+COS(CUBEYAW2+ASIDE)*AFD : ARZ=PZ2+SIN(CUBEYAW2+ASIDE)*AFD : ARI=INT(ARZ) : ARJ=INT(ARX) : AHR=0
642 IF ARI>=1 AND ARI<=78 AND ARJ>=1 AND ARJ<=78 THEN IF RIBWAL(ARI,ARJ)<>0 THEN AHR=1
643 IF AHF=0 AND AHL=0 AND AHR=0 THEN RETURN
644 CUBEYAW2=CUBEYAW2-TURN*DT
645 IF AHL=1 AND AHR=0 THEN CUBEYAW2=CUBEYAW2+ATURN*DT : RETURN
646 IF AHR=1 AND AHL=0 THEN CUBEYAW2=CUBEYAW2-ATURN*DT : RETURN
647 IF CROSS>=0 THEN CUBEYAW2=CUBEYAW2+ATURN*DT ELSE CUBEYAW2=CUBEYAW2-ATURN*DT
648 RETURN
