554 REM ============================================================
555 REM  2-PLAYER LOOP  --  P1 = you (mouse-steered); P2 = an autonomous red bike that chases you (press 2)
556 REM ============================================================
557 TwoPlayerInit:
558 PX2=PX : PZ2=PZ+6 : CUBEYAW2=0
559 TRLPCX2=PX2-0.4 : TRLPCZ2=PZ2 : TRLPCY2=0 : STARTED=0 : PTMR=0
560 TwoPlayerLoop:
561 K=INKEY
562 IF K=81 OR K=113 OR K=27 THEN GOTO GameOver
563 IF K=77 OR K=109 THEN CALL ToggleMap
564 IF K=70 OR K=102 THEN CALL ToggleFog
565 NOW=TIMER : DT=(NOW-LASTT)/16 : DT=(4+DT-ABS(4-DT))/2 : LASTT=NOW : LASTYAW=CUBEYAW : IF K=84 OR K=116 THEN TURNMODE=1-TURNMODE : TURNTGT=CUBEYAW : PYAW=CUBEYAW
566 MX=MOUSE(1) : DMX=MX-LASTMX : LASTMX=MX : MY=MOUSE(2) : DMY=MY-LASTMY : LASTMY=MY : IF MOUSE(0)<0 AND ABS(DMX)<MAXD THEN PYAW=PYAW+DMX*TSPD : IF MOUSE(0)<0 AND ABS(DMY)<MAXD THEN CAMPITCH=CAMPITCH-DMY*TSPD : IF ABS(CAMPITCH)>PMAX THEN CAMPITCH=SGN(CAMPITCH)*PMAX
567 CALL DoTurn
568 IF K=71 OR K=103 THEN AAON=1-AAON : GL.AA AAON
569 IF ABS(PYAW-CUBEYAW)>D10 THEN SPDCUR=SPEED
570 SPDCUR=SPDCUR+0.0015*DT : IF SPDCUR>0.3 THEN SPDCUR=0.3
571 DX=0 : DZ=0 : IF K=83 OR K=115 THEN FPSON=1-FPSON : GL.FPS FPSON
572 IF KEYDOWN(87) OR KEYDOWN(38) OR AUTORUN=1 THEN DX=COS(CUBEYAW)*SPDCUR*DT : DZ=SIN(CUBEYAW)*SPDCUR*DT
573 IF K=65 OR K=97 THEN AUTORUN=1-AUTORUN
574 IF STARTED=0 AND KEYDOWN(87) THEN STARTED=1 : PTMR=60
575 IF PTMR>0 THEN PTMR=PTMR-DT
576 IF DX<>0 OR DZ<>0 THEN CALL Move
577 IF DX<>0 OR DZ<>0 THEN MOVING=1 ELSE MOVING=0
578 IF STARTED=1 THEN RBI=INT(PZ-SIN(CUBEYAW)*0.4) : RBJ=INT(PX-COS(CUBEYAW)*0.4) : RBI2=INT(PZ) : RBJ2=INT(PX) : RIBWAL(RBI,RBJ)=1 : RIBWAL(RBI2,RBJ2)=1
579 IF STARTED=0 OR PTMR>0 THEN GOTO TPSKIP
580 TX=PX-PX2 : TZ=PZ-PZ2 : DST=SQR(TX*TX+TZ*TZ)
581 IF DST<0.01 THEN DST=0.01
582 CX=COS(CUBEYAW2) : CZ=SIN(CUBEYAW2)
583 CROSS=(CX*TZ-CZ*TX)/DST : FWD=(CX*TX+CZ*TZ)/DST
584 TRATE=0.06 : TURN=CROSS
585 IF TURN>TRATE THEN TURN=TRATE
586 IF TURN<0-TRATE THEN TURN=0-TRATE
587 IF FWD<0 AND ABS(CROSS)<0.05 THEN TURN=TRATE
588 CUBEYAW2=CUBEYAW2+TURN*DT : GOSUB AvoidRibbon
589 DX2=COS(CUBEYAW2)*SPDCUR*0.92*DT : DZ2=SIN(CUBEYAW2)*SPDCUR*0.92*DT
590 NX2=PX2+DX2 : NZ2=PZ2+DZ2 : MM=0.35
591 RR1=INT((NZ2-MM)/CELL) : RR2=INT((NZ2+MM)/CELL) : CC1=INT((NX2-MM)/CELL) : CC2=INT((NX2+MM)/CELL)
592 IF RR1<0 OR RR2>=MZ OR CC1<0 OR CC2>=MZ THEN GOTO TPSlideX
593 IF MAP(RR1,CC1)<>0 OR MAP(RR1,CC2)<>0 OR MAP(RR2,CC1)<>0 OR MAP(RR2,CC2)<>0 THEN GOTO TPSlideX
594 PX2=NX2 : PZ2=NZ2 : GOTO TPMoveDone
595 TPSlideX:
596 NX2=PX2+DX2 : NZ2=PZ2
597 RR1=INT((NZ2-MM)/CELL) : RR2=INT((NZ2+MM)/CELL) : CC1=INT((NX2-MM)/CELL) : CC2=INT((NX2+MM)/CELL)
598 IF RR1<0 OR RR2>=MZ OR CC1<0 OR CC2>=MZ THEN GOTO TPSlideZ
599 IF MAP(RR1,CC1)<>0 OR MAP(RR1,CC2)<>0 OR MAP(RR2,CC1)<>0 OR MAP(RR2,CC2)<>0 THEN GOTO TPSlideZ
600 PX2=NX2 : GOTO TPMoveDone
601 TPSlideZ:
602 NX2=PX2 : NZ2=PZ2+DZ2
603 RR1=INT((NZ2-MM)/CELL) : RR2=INT((NZ2+MM)/CELL) : CC1=INT((NX2-MM)/CELL) : CC2=INT((NX2+MM)/CELL)
604 IF RR1<0 OR RR2>=MZ OR CC1<0 OR CC2>=MZ THEN GOTO TPMoveDone
605 IF MAP(RR1,CC1)<>0 OR MAP(RR1,CC2)<>0 OR MAP(RR2,CC1)<>0 OR MAP(RR2,CC2)<>0 THEN GOTO TPMoveDone
606 PZ2=NZ2
607 TPMoveDone:
608 TPSKIP:
609 TRLTICK=TRLTICK+DT
610 IF TRLTICK<1.5 THEN GOTO TPNoDrop
611 TRLTICK=TRLTICK-1.5
612 CALL DropTrail
613 IF STARTED=0 OR PTMR>0 THEN GOTO TPNoDrop
614 BX2=PX2-COS(CUBEYAW2)*0.4 : BZ2=PZ2-SIN(CUBEYAW2)*0.4
615 RDOT=(BX2-TRLPCX2)*COS(CUBEYAW2)+(BZ2-TRLPCZ2)*SIN(CUBEYAW2)
616 IF RDOT<=0 THEN GOTO TPNoDrop
617 RSDX=BX2-TRLPCX2 : RSDZ=BZ2-TRLPCZ2 : RDY=JUMPY-TRLPCY2
618 GL.INSTANCE RAILID2, TRLPCX2, TRLPCY2-1.10, TRLPCZ2, RSDX, RDY, RSDZ
619 GL.INSTANCE CTRID2, TRLPCX2, TRLPCY2-1.10, TRLPCZ2, RSDX, RDY, RSDZ
620 TRLPCX2=BX2 : TRLPCZ2=BZ2 : TRLPCY2=JUMPY
621 TPNoDrop:
622 IF K=67 OR K=99 THEN CAMMODE=CAMMODE+1
623 IF CAMMODE>2 THEN CAMMODE=0
624 CAMX=PX-COS(PYAW)*CAMDIST : CAMZ=PZ-SIN(PYAW)*CAMDIST
625 IF CAMMODE=0 THEN GL.CAMERA CAMX,CAMHT,CAMZ : GL.LOOKAT PX,CAMDIST*CAMPITCH+0.6,PZ
626 IF CAMMODE=1 THEN GL.CAMERA PX-COS(PYAW)*CAMDIST2,CAMHT2,PZ-SIN(PYAW)*CAMDIST2 : GL.LOOKAT PX,CAMDIST2*CAMPITCH+0.1,PZ
627 IF CAMMODE=2 THEN GL.CAMERA PX-COS(CUBEYAW)*0.2,JUMPY-0.6,PZ-SIN(CUBEYAW)*0.2 : GL.LOOKAT PX+COS(CUBEYAW)*10,JUMPY-1.1+10*CAMPITCH,PZ+SIN(CUBEYAW)*10
628 GL.LIGHTSOFF : IF LIGHTON=1 AND WIREMODE=0 THEN GL.RECTLIGHT PX,2.5,PZ, 8,8, 200,215,255, 30
629 IF K=66 OR K=98 THEN BLOOMON=1-BLOOMON : IF BLOOMON=1 THEN GL.BLOOM 0.6 ELSE GL.BLOOM 0
630 GL.TRANSLATE CUBEID, PX, JUMPY-1.1, PZ
631 GL.ROTATE CUBEID, 0, -CUBEYAW*180/PI+CYCOFF, 0
632 GL.TRANSLATE CUBEID2, PX2, JUMPY-1.1, PZ2
633 GL.ROTATE CUBEID2, 0, -CUBEYAW2*180/PI+CYCOFF, 0
634 CALL DrawMinimap
635 LOCATE 1,1 : PRINT "2-PLAYER  P1=" ; INT(PX*10) ; "," ; INT(PZ*10) ; "  P2(red)=" ; INT(PX2*10) ; "," ; INT(PZ2*10) ; "    " : GL.CLS 2,2,8 : GL.DRAWALL
636 IF K=32 AND JUMPV=0 AND JUMPY=0 THEN JUMPV=JUMPV0
637 JUMPY=JUMPY+JUMPV*DT
638 JUMPV=JUMPV-GRAV*DT
639 IF JUMPY<0 THEN JUMPY=0
640 IF JUMPY=0 THEN JUMPV=0
641 IF K=76 OR K=108 THEN LIGHTON=1-LIGHTON
642 IF K=90 OR K=122 THEN WIREMODE=1-WIREMODE : GL.WIREALL WIREMODE
643 SLEEP 16 : GOTO TwoPlayerLoop
644 REM ============================================================
645 REM AvoidRibbon - GOSUB target (2-player only). Feels ahead of P2 for P1 blue-ribbon cells (RIBWAL). If any are near, cancels this frame chase-turn and steers P2 away so it rounds the ribbon instead of driving through it.
646 REM ============================================================
647 AvoidRibbon:
648 AFD=7 : ASIDE=0.5 : ATURN=0.10
649 AFX=PX2+COS(CUBEYAW2)*5 : AFZ=PZ2+SIN(CUBEYAW2)*5 : AFI=INT(AFZ) : AFJ=INT(AFX) : AHF=0
650 IF AFI>=1 AND AFI<=78 AND AFJ>=1 AND AFJ<=78 THEN IF RIBWAL(AFI,AFJ)<>0 THEN AHF=1
651 ALX=PX2+COS(CUBEYAW2-ASIDE)*AFD : ALZ=PZ2+SIN(CUBEYAW2-ASIDE)*AFD : ALI=INT(ALZ) : ALJ=INT(ALX) : AHL=0
652 IF ALI>=1 AND ALI<=78 AND ALJ>=1 AND ALJ<=78 THEN IF RIBWAL(ALI,ALJ)<>0 THEN AHL=1
653 ARX=PX2+COS(CUBEYAW2+ASIDE)*AFD : ARZ=PZ2+SIN(CUBEYAW2+ASIDE)*AFD : ARI=INT(ARZ) : ARJ=INT(ARX) : AHR=0
654 IF ARI>=1 AND ARI<=78 AND ARJ>=1 AND ARJ<=78 THEN IF RIBWAL(ARI,ARJ)<>0 THEN AHR=1
655 IF AHF=0 AND AHL=0 AND AHR=0 THEN RETURN
656 CUBEYAW2=CUBEYAW2-TURN*DT
657 IF AHL=1 AND AHR=0 THEN CUBEYAW2=CUBEYAW2+ATURN*DT : RETURN
658 IF AHR=1 AND AHL=0 THEN CUBEYAW2=CUBEYAW2-ATURN*DT : RETURN
659 IF CROSS>=0 THEN CUBEYAW2=CUBEYAW2+ATURN*DT ELSE CUBEYAW2=CUBEYAW2-ATURN*DT
660 RETURN
