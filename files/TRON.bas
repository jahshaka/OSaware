6115 DLNoR:
6116 MCX=INT(PX/CELL) : MCZ=INT(PZ/CELL)
6117 IF MCX>=0 AND MCX<MZ AND MCZ>=0 AND MCZ<MZ THEN TRAIL(MCZ,MCX)=1
6118 IF WALLCD>0 THEN WALLCD=WALLCD-1
6119 IF RIBCD>0 THEN RIBCD=RIBCD-1
6120 DTMR=DTMR-1
6121 IF NEARW=1 AND WALLCD<=0 THEN GOTO DLWall
6122 IF NEARR=1 AND RIBCD<=0 THEN GOTO DLRib
6123 IF DTMR>0 THEN GOTO DLGO
6124 RR=INT(RND(1)*3) : TANG=0.2618 : TRATE=0.005 : IF RR=1 THEN TANG=0.7854
6125 IF RR=1 THEN TRATE=0.025
6126 IF RR=2 THEN TANG=1.5708
6127 IF RR=2 THEN TRATE=0.08
6128 IF RND(1)>0.5 THEN PYAW=CUBEYAW+TANG ELSE PYAW=CUBEYAW-TANG
6129 DTMR=45+INT(RND(1)*90)
6130 GOTO DLGO
6131 DLWall:
6132 TRATE=0.12 : WALLCD=28 : DTMR=45+INT(RND(1)*90)
6133 HLX=PX+COS(CUBEYAW-2.5)*9 : HLZ=PZ+SIN(CUBEYAW-2.5)*9 : LCLR=1
6134 IF HLX<5 OR HLX>75 OR HLZ<5 OR HLZ>75 THEN LCLR=0
6135 HRX=PX+COS(CUBEYAW+2.5)*9 : HRZ=PZ+SIN(CUBEYAW+2.5)*9 : RCLR=1
6136 IF HRX<5 OR HRX>75 OR HRZ<5 OR HRZ>75 THEN RCLR=0
6137 WS=1
6138 IF LCLR=1 THEN WS=-1
6139 IF LCLR=1 AND RCLR=1 AND RND(1)>0.5 THEN WS=1
6140 IF LCLR=0 AND RCLR=0 THEN WS=0
6141 PYAW=CUBEYAW+WS*2.5
6142 IF WS=0 THEN PYAW=CUBEYAW+3.14159
6143 GOTO DLGO
6144 DLRib:
6145 RIBCD=20
6146 LJX=PX+COS(CUBEYAW)*3 : LJZ=PZ+SIN(CUBEYAW)*3
6147 JRX=INT(LJX/CELL) : JRZ=INT(LJZ/CELL)
