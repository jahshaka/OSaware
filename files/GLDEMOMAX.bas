0 REM *** GLDEMO3 — Advanced Three.js GL Showcase ***
1 REM *** Fog, point lights, transparency, spheres, floor ***
5 CLS : COLOUR 3
10 PRINT "GL ADVANCED DEMO"
20 PRINT "Q=quit  F=fog  L=light  M=mouse orbit"
30 SLEEP 1200
40 GL.INIT
41 LOADIMG "checkerboard", "DEMO/CHECKERBOARD.PNG"
50 GL.PERSPECTIVE 55
60 REM Camera orbit state
70 ORBIT = 0
80 CDIST = 11 : CY = 4
90 GL.CAMERA SIN(ORBIT)*CDIST, CY, -COS(ORBIT)*CDIST
100 GL.LOOKAT 0, 0, 0
110 REM === Lighting ===
120 GL.LIGHT 1, 2, -1
130 GL.AMBIENT 0.22
140 GL.POINTLIGHT 0, 5, -2, 255, 200, 120, 3, 14
150 GL.POINTLIGHT 0, 0, 4, 120, 160, 255, 3, 10
160 REM === Fog ===
170 GL.FOG 5, 5, 18, 6, 22
180 REM ==================================================
190 REM Build floor
200 REM ==================================================
210 GL.SOLID
220 GL.COLOUR 255, 255, 255
230 GL.SHINE 5 : GL.ALPHA 1.0 : GL.EMISSIVE 0, 0, 0
240 GL.BEGIN
250 GL.VERTEX -1, 0, -1 : GL.VERTEX  1, 0, -1
260 GL.VERTEX  1, 0,  1 : GL.VERTEX -1, 0,  1
270 GL.FACE 1, 2, 3, 4
280 GL.END
290 FLOOR = GL.MESHID
300 GL.TRANSLATE FLOOR, 0, -1.5, 0
310 GL.SCALE FLOOR, 12, 1, 12
320 GL.TEXTURE FLOOR, "checkerboard", 8
330 REM ==================================================
340 REM Chrome sphere
350 REM ==================================================
360 GL.SOLID
370 GL.COLOUR 210, 225, 255
380 GL.SHINE 200 : GL.ALPHA 1.0 : GL.EMISSIVE 0, 0, 0
390 GL.SPHERE 1.1, 48, 32
400 SPH = GL.MESHID
405 GL.CHROME SPH, 0.04
410 GL.TRANSLATE SPH, -3.5, 0, 0
420 REM ==================================================
430 REM Glass cube
440 REM ==================================================
450 GL.SOLIDWIRE
460 GL.COLOUR 100, 200, 255
470 GL.SHINE 140 : GL.ALPHA 0.4
480 GL.WIRECOLOR 180, 235, 255 : GL.EMISSIVE 0, 25, 50
490 GL.BEGIN
500 GL.VERTEX -1,-1,-1 : GL.VERTEX 1,-1,-1
510 GL.VERTEX 1,1,-1   : GL.VERTEX -1,1,-1
520 GL.VERTEX -1,-1,1  : GL.VERTEX 1,-1,1
530 GL.VERTEX 1,1,1    : GL.VERTEX -1,1,1
540 GL.FACE 1,2,3,4 : GL.FACE 8,7,6,5
550 GL.FACE 1,4,8,5 : GL.FACE 2,3,7,6
560 GL.FACE 4,3,7,8 : GL.FACE 1,2,6,5
570 GL.END
580 CUBE = GL.MESHID
590 REM ==================================================
600 REM Gold pyramid
610 REM ==================================================
620 GL.SOLID
630 GL.COLOUR 255, 175, 25
640 GL.SHINE 100 : GL.ALPHA 1.0 : GL.EMISSIVE 35, 15, 0
650 GL.BEGIN
660 GL.VERTEX -1,-1,-1 : GL.VERTEX 1,-1,-1
670 GL.VERTEX 1,-1,1   : GL.VERTEX -1,-1,1
680 GL.VERTEX 0, 2, 0
690 GL.FACE 1,2,3,4
700 GL.FACE 1,2,5 : GL.FACE 2,3,5
710 GL.FACE 3,4,5 : GL.FACE 4,1,5
720 GL.END
730 PYR = GL.MESHID
740 GL.TRANSLATE PYR, 3.5, -0.5, 0
750 REM ==================================================
760 REM Orbiting light sphere + red accent orb
770 REM ==================================================
780 GL.SOLID
790 GL.COLOUR 255, 220, 80
800 GL.SHINE 200 : GL.ALPHA 0.9 : GL.EMISSIVE 220, 180, 40
810 GL.SPHERE 0.18, 10, 8
820 LORB = GL.MESHID
830 GL.SOLID
840 GL.COLOUR 255, 60, 60
850 GL.SHINE 160 : GL.ALPHA 0.85 : GL.EMISSIVE 140, 15, 15
860 GL.SPHERE 0.35, 16, 12
870 REDB = GL.MESHID
880 REM ==================================================
890 REM Init state
900 REM ==================================================
910 ANG = 0 : FOGON = 1 : MOUSEMODE = 1
920 LASTMX = 0 : DRAGGING = 0
930 MOUSE ON
940 REM ==================================================
950 REM Main loop
960 REM ==================================================
970 K = INKEY
980 IF K=81 OR K=113 OR K=27 THEN GOTO 4000
990 IF K=70 OR K=102 THEN GOSUB 3000
1000 IF K=76 OR K=108 THEN GOSUB 3100
1010 IF K=77 OR K=109 THEN GOSUB 3200
1020 REM === Mouse orbit ===
1030 IF MOUSEMODE = 0 THEN GOTO 1120
1040 MB = MOUSE(0)
1050 MX = MOUSE(1)
1060 IF MB = -1 AND DRAGGING = 0 THEN DRAGGING = 1 : LASTMX = MX
1070 IF MB = 0 AND DRAGGING = 1 THEN DRAGGING = 0
1080 IF DRAGGING = 1 THEN ORBIT = ORBIT + (MX - LASTMX) * 0.012 : LASTMX = MX
1090 REM Update camera position on orbit circle
1100 GL.CAMERA SIN(ORBIT)*CDIST, CY, -COS(ORBIT)*CDIST
1110 GL.LOOKAT 0, 0, 0
1120 REM === Scene animation ===
1130 GL.CLS 5, 5, 18
1140 GL.ROTATE CUBE, ANG*0.5, ANG*1.1, ANG*0.3
1150 GL.ROTATE PYR, 0, ANG*0.8, 0
1160 SY = SIN(ANG * 0.045) * 0.65 + 0.25
1170 GL.TRANSLATE SPH, -3.5, SY, 0
1180 GL.ROTATE SPH, ANG*0.3, ANG*0.6, 0
1190 LX = SIN(ANG * 0.035) * 5
1200 LZ = COS(ANG * 0.035) * 5
1210 LY = SIN(ANG * 0.06) * 1.5 + 2
1220 GL.TRANSLATE LORB, LX, LY, LZ
1230 RX = SIN(ANG * 0.028) * 3.5
1240 RY = COS(ANG * 0.05) * 1.2 + 1.8
1250 RZ = SIN(ANG * 0.056) * 2
1260 GL.TRANSLATE REDB, RX, RY, RZ
1270 GL.DRAWALL
1280 ANG = ANG + 1.3
1290 IF ANG >= 3600 THEN ANG = ANG - 3600
1300 SLEEP 16
1310 GOTO 970
3000 REM === Toggle fog ===
3010 FOGON = 1 - FOGON
3020 IF FOGON = 1 THEN GL.FOG 5,5,18,6,22 : RETURN
3030 GL.FOGOFF
3040 RETURN
3100 REM === Add random point light ===
3110 PR = INT(RND(1)*200)+55
3120 PG = INT(RND(1)*200)+55
3130 PB = INT(RND(1)*200)+55
3140 PX = RND(1)*8-4 : PZ = RND(1)*6-3
3150 GL.POINTLIGHT PX, 2, PZ, PR, PG, PB, 4, 8
3160 RETURN
3200 REM === Toggle mouse orbit mode ===
3210 MOUSEMODE = 1 - MOUSEMODE
3220 IF MOUSEMODE = 1 THEN MOUSE ON : RETURN
3230 MOUSE OFF : DRAGGING = 0
3240 RETURN
4000 GL.FOGOFF
4010 GL.LIGHTSOFF
4020 MOUSE OFF
4030 COLOUR 3 : CLS
4040 PRINT "GL demo ended."
