10 REM ============================================================
20 REM  SKYFOXAI -- 3D flight using AIG_NAVIGATE engine helper
30 REM  A plane banks over a block arena. Mouse steers; the plane
40 REM  always flies forward. D = demo, any key = fly, Q/Esc = quit.
50 REM ============================================================
60 StartMenu:
70 CLS : COLOUR 3
80 PRINT "  S K Y F O X  A I    -    Arena Flight (engine-assisted AI)"
90 COLOUR 7
100 PRINT ""
110 PRINT "  Hold mouse+move:  fly       Shift:  up/down"
112 PRINT "  Enter:            boost     Space:  fire"
114 PRINT "  Release:          level"
120 PRINT ""
122 PRINT "  Toggles:"
130 PRINT "    M  map          F  fog"
132 PRINT "    L  lights       Z  wireframe"
134 PRINT "    B  bloom        G  anti-alias"
136 PRINT "    C  clouds       T  ground"
138 PRINT "    S  fps          V  camera"
140 PRINT "    E  debug"
150 COLOUR 3
160 PRINT ""
170 PRINT "     D  ......  DEMO        the plane flies itself"
180 PRINT "     . . .  or press any other key to FLY"
190 PRINT ""
200 PRINT "  Q  or  Esc :  quit"
210 DK=GETKEY()
220 IF DK=81 OR DK=113 OR DK=27 THEN FULLSCREEN EXIT : UI ON : END
230 FULLSCREEN ENTER : UI OFF
240 MZ=16 : CELL=40.0 : SPEED=0.6 : TSPD=0.015
250 PI=4*ATN(1)
260 PLY=34 : CAMDIST=18 : CAMHT=7 : PLYMIN=3 : PLYMAX=680 : YAWOFF=90 : CORRX=0-90 : CORRY=0 : CORRZ=0
270 TURNCHASE=0.17 : MAXPITCH=20*PI/180 : PITCHSMOOTH=0.13 : SNAP=0.2 : MAXROLL=30*PI/180 : ROLLSMOOTH=0.13 : BIAS=0.5 : ACCEL=0.03 : MAXPDOWN=30*PI/180 : MAXDCYAW=0.03 : MAXCLIMB=40*PI/180
280 FOGON=1 : LIGHTON=1 : WIREMODE=0 : BLOOMON=0 : FPSON=1 : AAON=1 : CAMMODE=0 : CLOUDON=0 : GRIDMODE=1
290 DEMO=0 : IF DK=68 OR DK=100 THEN DEMO=1
300 DTMR=40 : SPDZONE=14 : SPDFAST=0.95 : SPDEASE=0.05 : VMOVE=0.08 : BEAMLEN=2.5 : BEAMRAD=0.14 : BEAMGAP=1.8 : BEAMNOSE=3.5 : BEAMSPD=SPEED*10 : BEAMLIFE=180 : BLASTMAX=1.92 : BLASTLIFE=25 : HITR2=36 : BBMAX=11.52 : BBDROP=2.9
310 DIM BUL(19,8) : DIM BLAST(15,4) : DIM TANK(19,5)
320 GameStart:
330 REM === Plane state ===
340 PX=CELL*8 : PZ=CELL*4 : CUBEYAW=PI/2 : PYAW=PI/2 : CAMYAW=PI/2 : PITCH=0 : PPITCH=0 : ROLL=0 : PROLL=0 : SPDCUR=SPEED : TKILLS=0 : GOREASON$="  GAME ENDED" : LOCKID=0-1 : AIMODE=0 : OBOOST=1 : WAYTIME=0 : AVOIDSIDE=0 : COMMITYAW=0 : CLIMBOVER=0 : CLIMBHOLD=0 : BIASLP=0 : BRLP=PI/2 : TGT=35 : TARGETID=0-1 : TARGETTIME=0 : EBOOSTLP=1 : KILLPAUSE=0 : SHOTS=0 : DEBUG=0
350 REM === Build the scene, branch into the chosen loop ===
360 CLS : UI ON : DELAY 0
370 CALL BuildScene
380 CALL InitMinimap
390 MAPVIS=1 : CALL InitBullets
400 GL.SKY 1 : CALL InitTanks
410 MOUSE ON : LASTMX=MOUSE(1) : LASTT=TIMER : CALL InitExplos
420 IF DEMO=1 THEN MOUSE OFF : GOTO DemoLoop
430 REM ============================================================
440 REM  MAIN LOOP  --  mouse-steered flight
450 REM ============================================================
460 MainLoop:
470 K=INKEY
480 SWITCH(K)
490 CASE 81:
500 CASE 113:
510 CASE 27:
520 GOTO GameOver
530 BREAK
540 CASE 77:
550 CASE 109:
560 CALL ToggleMap
570 BREAK
580 CASE 70:
590 CASE 102:
600 CALL ToggleFog
610 BREAK
620 END SWITCH
630 NOW=TIMER : DT=(NOW-LASTT)/16 : DT=(4+DT-ABS(4-DT))/2 : LASTT=NOW : IF K=86 OR K=118 THEN CAMMODE=CAMMODE+1 : IF CAMMODE>2 THEN CAMMODE=0
640 IF K=71 OR K=103 THEN AAON=1-AAON : GL.AA AAON
650 IF K=83 OR K=115 THEN FPSON=1-FPSON : GL.RFPS FPSON
660 IF K=66 OR K=98 THEN BLOOMON=1-BLOOMON : IF BLOOMON=1 THEN GL.BLOOM 0.6 ELSE GL.BLOOM 0
670 IF K=76 OR K=108 THEN LIGHTON=1-LIGHTON
680 IF K=90 OR K=122 THEN WIREMODE=1-WIREMODE : GL.WIREALL WIREMODE
690 MX=MOUSE(1) : DMX=MX-LASTMX : LASTMX=MX : MY=MOUSE(2) : DMY=MY-LASTMY : LASTMY=MY : BTN=MOUSE(0) : SHFT=KEYDOWN(16) : MMOV=ABS(DMX) : IF ABS(DMY)>MMOV THEN MMOV=ABS(DMY)
700 IF SHFT=0 AND BTN<0 AND ABS(DMX)>5 AND ABS(DMX)<200 AND ABS(DMX)>=BIAS*ABS(DMY) THEN ADMX=DMX*(1+ABS(DMX)*ACCEL) : PYAW=PYAW+ADMX*TSPD : PROLL=PROLL+ADMX*TSPD
710 IF SHFT=0 AND BTN<0 AND ABS(DMY)>5 AND ABS(DMY)<200 AND ABS(DMY)>=BIAS*ABS(DMX) THEN PPITCH=PPITCH-DMY*TSPD*(1+ABS(DMY)*ACCEL)
720 SPDTGT=SPEED*(1+2*KEYDOWN(13)) : IF BTN<0 AND MMOV>SPDZONE AND SPDTGT<SPDFAST THEN SPDTGT=SPDFAST
730 SPDCUR=SPDCUR+(SPDTGT-SPDCUR)*SPDEASE*DT : IF SHFT=1 AND BTN<0 AND ABS(DMY)>5 AND ABS(DMY)<200 AND ABS(DMY)>=BIAS*ABS(DMX) THEN PLY=PLY-DMY*VMOVE*(1+ABS(DMY)*ACCEL)
740 IF BTN>=0 THEN PYAW=CUBEYAW
750 IF BTN>=0 OR SHFT=1 THEN PPITCH=PPITCH+(0-PPITCH)*SNAP*DT : PROLL=PROLL+(0-PROLL)*SNAP*DT
760 PPITCH=(ABS(PPITCH+MAXPDOWN)-ABS(PPITCH-MAXCLIMB)+MAXCLIMB-MAXPDOWN)/2
770 IF K=67 OR K=99 THEN CLOUDON=1-CLOUDON : IF CLOUDON=1 THEN GL.CLOUDS 1, 0.45, 85, 50 ELSE GL.CLOUDS 0
780 GAP=PYAW-CUBEYAW : GAP=GAP-2*PI*INT((GAP+PI)/(2*PI)) : DCYAW=GAP*TURNCHASE*DT : DCYAW=(ABS(DCYAW+MAXDCYAW)-ABS(DCYAW-MAXDCYAW))/2 : CUBEYAW=CUBEYAW+DCYAW : CUBEYAW=CUBEYAW-2*PI*INT((CUBEYAW+PI)/(2*PI))
790 PITCH=PITCH+(PPITCH-PITCH)*PITCHSMOOTH*DT : PROLL=(ABS(PROLL+MAXROLL)-ABS(PROLL-MAXROLL))/2 : ROLL=ROLL+(PROLL-ROLL)*ROLLSMOOTH*DT
800 CP=COS(PITCH) : PX=PX+COS(CUBEYAW)*CP*SPDCUR*DT : PZ=PZ+SIN(CUBEYAW)*CP*SPDCUR*DT : PLY=PLY+SIN(PITCH)*SPDCUR*DT : IF K=32 THEN CALL Fire
810 PLY=(ABS(PLY-PLYMIN)-ABS(PLY-PLYMAX)+PLYMIN+PLYMAX)/2 : IF TKILLS>=NT THEN GOREASON$="  VICTORY - ALL TANKS DESTROYED!" : GOTO GameOver
820 IF K=84 OR K=116 THEN GRIDMODE=1-GRIDMODE : IF GRIDMODE=1 THEN GL.TERRAIN 1,2560,120,100,24,320,320,1 ELSE GL.TERRAIN 1,2560,120,100,24,320,320,0
830 CALL FlyCamera
840 GL.LIGHTSOFF : IF LIGHTON=1 AND WIREMODE=0 THEN GL.RECTLIGHT PX,PLY+10,PZ, 16,16, 210,220,255, 16
850 GL.TRANSLATE CUBEID, PX, PLY, PZ : GL.PROBE PX, PZ : PGROUND=GL.PROBEY : CALL UpdateBullets
860 GL.ROTATE CUBEID, 0-PITCH*180/PI, 0-CUBEYAW*180/PI+YAWOFF, ROLL*180/PI : IF PLY<=PGROUND+2 THEN HUD$="*** TERRAIN HIT ***  collision detected  no damage   -  SKYFOX AI" ELSE HUD$="Hold+drag:fly  Shift:up/down  Enter:boost  T:ground  -  SKYFOX AI"
870 CALL DrawMinimap
880 LOCATE 1,1 : PRINT HUD$ : LOCATE 2,1 : PRINT "TANKS DESTROYED: "; TKILLS : GL.CLS 10,14,38 : GL.DRAWALL : IF PLY<=PGROUND+1 THEN GOREASON$="  CRASHED INTO TERRAIN" : GOTO GameOver
890 SLEEP 16 : GOTO MainLoop
900 REM === Fall-through guard ===
910 END
1000 REM ============================================================
1010 REM BuildScene - GL init, floor + grid, blocks, plane model
1020 REM ============================================================
1030 SUB BuildScene STATIC
1040 SHARED MZ, CELL
1050 GL.INIT : GL.PERSPECTIVE 70, 15000 : GL.AMBIENT 0.55 : GL.FOG 185,192,205,250,1200 : GL.LIGHT 0.4, 1, 0.3, 3.2
1060 FL=MZ*CELL
1070 REM --- terrain: noise heightmap (GL.TERRAIN) replaces the flat floor ---
1080 GL.TERRAIN 1, 2560, 120, 100, 24, 320, 320
1090 REM --- plane: the jahship craft (CORR baked into the model node) ---
1100 GL.LOAD "files/models/jahship.glb", CORRX, CORRY, CORRZ
1110 SHARED CUBEID
1120 CUBEID=GL.MESHID
1130 GL.SCALE CUBEID, 0.7, 0.7, 0.7 : GL.EMISSIVEINTENSITY CUBEID, 0
1140 IF BLOOMON=1 THEN GL.BLOOM 0.6
1150 GL.RFPS 1 : GL.AA 1
1160 END SUB
2000 REM ============================================================
2010 REM BuildCeiling - faint grid high overhead = the raised sky
2020 REM ============================================================
2030 SUB BuildCeiling STATIC
2040 SHARED MZ, CELL
2050 FL=MZ*CELL : GW=0.2 : SKYY=87
2060 GL.SOLID : GL.COLOUR 60,110,210 : GL.SHINE 6 : GL.EMISSIVE 24,52,130 : GL.ALPHA 1.0
2070 GL.BEGIN : VN=0
2080 FOR I=0 TO MZ
2090 GP=I*CELL : GL.VERTEX GP-GW,SKYY,0 : GL.VERTEX GP+GW,SKYY,0 : GL.VERTEX GP+GW,SKYY,FL : GL.VERTEX GP-GW,SKYY,FL : GL.FACE VN+1,VN+2,VN+3,VN+4 : GL.FACE VN+4,VN+3,VN+2,VN+1 : VN=VN+4
2100 GL.VERTEX 0,SKYY,GP-GW : GL.VERTEX FL,SKYY,GP-GW : GL.VERTEX FL,SKYY,GP+GW : GL.VERTEX 0,SKYY,GP+GW : GL.FACE VN+1,VN+2,VN+3,VN+4 : GL.FACE VN+4,VN+3,VN+2,VN+1 : VN=VN+4
2110 NEXT I
2120 GL.END
2130 CEILID=GL.MESHID
2140 END SUB
3000 REM ============================================================
3010 REM InitMinimap - paint the plain minimap background panel
3020 REM ============================================================
3030 SUB InitMinimap STATIC
3040 SHARED MZ, MSCL, MMX, MMY, MAPVIS
3050 MSCL=11 : MAPVIS=1 : MMX=WIDTH-MZ*MSCL-6 : MMY=HEIGHT-MZ*MSCL-6
3060 DELAY 0
3070 FOR PR=0 TO MZ*MSCL-1
3080 FOR PC=0 TO MZ*MSCL-1
3090 PSET MMX+PC, MMY+PR, 8
3100 NEXT PC : NEXT PR
3110 END SUB
3120 DemoRestart:
3130 GL.CLOSE : DEMO=1 : GOTO GameStart
4000 REM ============================================================
4010 REM ToggleMap - show / hide the minimap overlay
4020 REM ============================================================
4030 SUB ToggleMap STATIC
4040 SHARED MAPVIS, MZ, MSCL, MMX, MMY
4050 MAPVIS=1-MAPVIS
4060 IF MAPVIS=1 THEN CALL InitMinimap
4070 IF MAPVIS=1 THEN EXIT SUB
4080 FOR CR=0 TO MZ*MSCL-1
4090 FOR CC=0 TO MZ*MSCL-1
4100 PSET MMX+CC, MMY+CR, 16
4110 NEXT CC : NEXT CR
4120 END SUB
5000 REM ============================================================
5010 REM ToggleFog - fog on / off
5020 REM ============================================================
5030 SUB ToggleFog STATIC
5040 SHARED FOGON
5050 FOGON=1-FOGON
5060 IF FOGON=1 THEN GL.FOG 185,192,205,250,1200
5070 IF FOGON=0 THEN GL.FOGOFF
5080 END SUB
6000 REM ============================================================
6010 REM FlyCamera - chase / cockpit camera. The camera tracks the
6020 REM smoothed aim (CAMYAW) while the plane sits at CUBEYAW, so the
6030 REM body visibly yaws into a turn. CAMMODE 0=far 1=near 2=cockpit.
6040 REM ============================================================
6050 SUB FlyCamera
6060 SHARED PX, PZ, CUBEYAW, PYAW, CAMYAW, PLY, CAMDIST, CAMHT, PITCH, PI, CAMMODE, DT
6070 CAMYAW=CAMYAW+(PYAW-CAMYAW)*0.25*DT
6080 CD=CAMDIST : CH=CAMHT : AY=CAMYAW
6090 IF CAMMODE=1 THEN CD=CAMDIST*0.6 : CH=CAMHT*0.75
6100 IF CAMMODE=2 THEN CD=0.5 : CH=1.6 : AY=CUBEYAW
6110 GL.CAMERA PX-COS(AY)*CD, PLY+CH, PZ-SIN(AY)*CD
6120 GL.LOOKAT PX+COS(AY)*8, PLY+SIN(PITCH)*8, PZ+SIN(AY)*8
6130 GL.CAMERAROLL 0
6140 END SUB
6150 REM ============================================================
6160 REM GameOver / Quit - tear GL down, back to the start menu
6170 REM ============================================================
6180 GameOver:
6190 MOUSE OFF : UI ON : GL.CLOSE : CLS
6200 COLOUR 3 : PRINT "" : PRINT "  G A M E   O V E R" : PRINT ""
6210 COLOUR 7 : PRINT GOREASON$ : PRINT ""
6220 PRINT "  Tanks destroyed:"; TKILLS; " of "; NT : PRINT ""
6230 PRINT "  Press any key to continue..."
6240 DK=GETKEY()
6250 GOTO StartMenu
6260 DemoLoop:
6270 K=INKEY
6280 IF K=81 OR K=113 OR K=27 THEN GOTO GameOver
6290 IF K=77 OR K=109 THEN CALL ToggleMap
6300 IF K=70 OR K=102 THEN CALL ToggleFog
6310 IF K=71 OR K=103 THEN AAON=1-AAON : GL.AA AAON
6320 IF K=83 OR K=115 THEN FPSON=1-FPSON : GL.RFPS FPSON
6330 IF K=66 OR K=98 THEN BLOOMON=1-BLOOMON : IF BLOOMON=1 THEN GL.BLOOM 0.6 ELSE GL.BLOOM 0
6340 IF K=76 OR K=108 THEN LIGHTON=1-LIGHTON
6350 IF K=90 OR K=122 THEN WIREMODE=1-WIREMODE : GL.WIREALL WIREMODE
6352 IF K=86 OR K=118 THEN CAMMODE=CAMMODE+1 : IF CAMMODE>2 THEN CAMMODE=0
6354 IF K=67 OR K=99 THEN CLOUDON=1-CLOUDON : IF CLOUDON=1 THEN GL.CLOUDS 1, 0.45, 85, 50 ELSE GL.CLOUDS 0
6356 IF K=84 OR K=116 THEN GRIDMODE=1-GRIDMODE : IF GRIDMODE=1 THEN GL.TERRAIN 1,2560,120,100,24,320,320,1 ELSE GL.TERRAIN 1,2560,120,100,24,320,320,0
6358 IF K=69 OR K=101 THEN DEBUG=1-DEBUG
6360 NOW=TIMER : DT=(NOW-LASTT)/16 : DT=(4+DT-ABS(4-DT))/2 : LASTT=NOW
6370 CALL AIPilot
6375 IF PLY<=NEARH+2 AND DEBUG=1 THEN GOTO DemoCrash
6376 IF PLY<=NEARH+2 AND DEBUG=0 THEN PLY=NEARH+12 : PITCH=0.3 : PPITCH=0.3 : CLIMBHOLD=60
6380 DCX=PX-320 : DCZ=PZ-320 : DCEN=SQR(DCX*DCX+DCZ*DCZ)+0.001 : IF DCEN>1100 THEN CRS=(COS(CUBEYAW)*(0-DCZ)-SIN(CUBEYAW)*(0-DCX))/DCEN : PYAW=CUBEYAW+CRS*0.6
6390 PPITCH=(ABS(PPITCH+MAXPDOWN)-ABS(PPITCH-MAXCLIMB)+MAXCLIMB-MAXPDOWN)/2 : GAP=PYAW-CUBEYAW : GAP=GAP-2*PI*INT((GAP+PI)/(2*PI)) : PROLL=PROLL+GAP*0.3 : DCYAW=GAP*TURNCHASE*DT : DCYAW=(ABS(DCYAW+MAXDCYAW)-ABS(DCYAW-MAXDCYAW))/2 : CUBEYAW=CUBEYAW+DCYAW : CUBEYAW=CUBEYAW-2*PI*INT((CUBEYAW+PI)/(2*PI)) : PITCH=PITCH+(PPITCH-PITCH)*PITCHSMOOTH*DT : PROLL=(ABS(PROLL+MAXROLL)-ABS(PROLL-MAXROLL))/2 : ROLL=ROLL+(PROLL-ROLL)*ROLLSMOOTH*DT
6400 PX=PX+COS(CUBEYAW)*SPEED*EBOOST*DT : PZ=PZ+SIN(CUBEYAW)*SPEED*EBOOST*DT : PLY=PLY+SIN(PITCH)*SPEED*EBOOST*DT
6410 CALL FlyCamera
6420 GL.LIGHTSOFF : IF LIGHTON=1 AND WIREMODE=0 THEN GL.RECTLIGHT PX,PLY+10,PZ, 16,16, 210,220,255, 16
6422 LIGHTCNT=0
6423 FOR TKI=0 TO NT-1
6424 IF TANK(TKI,0)=1 AND LIGHTCNT<4 THEN DXT=TANK(TKI,1)-PX : DZT=TANK(TKI,3)-PZ : DD=DXT*DXT+DZT*DZT : IF DD<160000 THEN GL.POINTLIGHT TANK(TKI,1),TANK(TKI,2)+10,TANK(TKI,3),255,220,140,40,160,0 : LIGHTCNT=LIGHTCNT+1
6426 NEXT TKI
6430 GL.TRANSLATE CUBEID, PX, PLY, PZ : CALL UpdateBullets
6440 GL.ROTATE CUBEID, 0-PITCH*180/PI, 0-CUBEYAW*180/PI+YAWOFF, ROLL*180/PI
6450 CALL DrawMinimap
6460 LOCATE 1,1 : PRINT "SKYFOXAI DEMO  PHASE 3 - target+destroy   (Q) quit (E) debug  "
6461 IF DEBUG=1 THEN LOCATE 2,1 : PRINT "PLY:"; INT(PLY); " TGT:"; INT(TGT); " NEAR:"; INT(NEARH); " MID:"; INT(LH1); " FAR:"; INT(LH2); " SEV:"; INT(SEV*100); "%     "
6462 IF DEBUG=1 THEN LOCATE 3,1 : PRINT "[DBG] TGT#:"; TARGETID; " SHOTS:"; SHOTS; " LH0:"; INT(LH0); " LHW:"; INT(LHW); " CO:"; CLIMBOVER; " CH:"; CLIMBHOLD; " P:"; INT(PITCH*180/PI); " PP:"; INT(PPITCH*180/PI); " EB:"; INT(EBOOST*100)/100; "       "
6463 IF DEBUG=0 THEN LOCATE 2,1 : PRINT "                                                                          "
6464 IF DEBUG=0 THEN LOCATE 3,1 : PRINT "                                                                          "
6465 GL.CLS 10,14,38 : GL.DRAWALL
6470 SLEEP 16 : GOTO DemoLoop
6500 DemoCrash:
6510 MOUSE OFF : UI ON : GL.CLOSE : CLS
6520 COLOUR 12 : PRINT "" : PRINT "  *** DEMO CRASH - hit terrain ***" : PRINT ""
6530 COLOUR 7
6540 PRINT "  PLY (altitude):       "; INT(PLY*10)/10
6550 PRINT "  NEARH (under plane):  "; INT(NEARH*10)/10
6555 PRINT "  LH0 (30 ahead):       "; INT(LH0*10)/10
6560 PRINT "  LH1 (80 ahead):       "; INT(LH1*10)/10
6570 PRINT "  LH2 (400 ahead):      "; INT(LH2*10)/10
6580 PRINT "  LHW (waypoint dir):   "; INT(LHW*10)/10
6590 PRINT "  SEV:                  "; INT(SEV*1000)/1000
6600 PRINT "  CLIMBOVER:            "; CLIMBOVER; "    CLIMBHOLD: "; CLIMBHOLD
6610 PRINT "  PITCH (deg):          "; INT(PITCH*1800/PI)/10; "   PPITCH (deg): "; INT(PPITCH*1800/PI)/10
6620 PRINT "  EBOOST:               "; INT(EBOOST*100)/100
6630 PRINT "  TGT:                  "; INT(TGT*10)/10
6640 PRINT "" : PRINT "  Press any key to return to menu..."
6650 DK=GETKEY()
6660 GOTO StartMenu
7000 REM ============================================================
7010 REM InitBullets - build the beam pool, parked at zero scale
7020 REM ============================================================
7030 SUB InitBullets STATIC
7040 SHARED BUL, NB, BNEXT, LASTFIRE, BEAMLEN, BEAMRAD
7050 NB=20 : BNEXT=0 : LASTFIRE=0
7060 GL.SOLID : GL.COLOUR 255,235,120 : GL.EMISSIVE 255,170,40 : GL.SHINE 90 : GL.ALPHA 1.0
7070 FOR I=0 TO NB-1
7080 GL.CYLINDER BEAMRAD, BEAMLEN, 8
7090 ID=GL.MESHID : BUL(I,0)=ID : BUL(I,1)=0
7100 GL.SCALE ID, 0, 0, 0
7110 NEXT I
7120 END SUB
8000 REM ============================================================
8010 REM InitExplos - build the red explosion-sphere pool, parked
8020 REM ============================================================
8030 SUB InitExplos STATIC
8040 SHARED BLAST, NE, EXNEXT, BBNEXT, BLASTMAX, BBMAX
8050 NE=16 : EXNEXT=0 : BBNEXT=8
8060 GL.SOLID : GL.SHINE 40 : GL.ALPHA 1.0
8070 FOR J=0 TO 15
8080 IF J<8 THEN GL.COLOUR 40,90,255 : GL.EMISSIVE 25,55,210 : BLAST(J,4)=BLASTMAX
8090 IF J>=8 THEN GL.COLOUR 255,45,30 : GL.EMISSIVE 220,30,15 : BLAST(J,4)=BBMAX
8100 GL.SPHERE 1.0, 10, 8
8110 BLAST(J,0)=GL.MESHID
8120 GL.SPHERE 1.0, 10, 8
8130 BLAST(J,1)=GL.MESHID
8140 IDA=BLAST(J,0) : IDB=BLAST(J,1) : GL.SCALE IDA,0,0,0 : GL.SCALE IDB,0,0,0
8150 NEXT J
8160 END SUB
9000 REM ============================================================
9010 REM Fire - spawn two beams from the nose, left and right
9020 REM ============================================================
9030 SUB Fire STATIC
9040 SHARED BUL, NB, BNEXT, LASTFIRE, SHOTS, PX, PLY, PZ, CUBEYAW, PITCH, PI, YAWOFF, BEAMSPD, BEAMGAP, BEAMNOSE, BEAMLIFE
9050 IF TIMER-LASTFIRE<150 THEN EXIT SUB
9060 LASTFIRE=TIMER : SHOTS=SHOTS+1
9070 CP=COS(PITCH) : FX=COS(CUBEYAW)*CP : FY=SIN(PITCH) : FZ=SIN(CUBEYAW)*CP
9080 RX=0-SIN(CUBEYAW) : RZ=COS(CUBEYAW)
9090 RYDEG=0-CUBEYAW*180/PI+YAWOFF : RXDEG=0-PITCH*180/PI
9100 FOR S2=0 TO 1
9110 SD=S2*2-1 : SL=BNEXT : BNEXT=BNEXT+1 : IF BNEXT>=NB THEN BNEXT=0
9120 ID=BUL(SL,0) : BUL(SL,1)=1 : BUL(SL,8)=BEAMLIFE
9130 TX=PX+FX*BEAMNOSE+RX*BEAMGAP*SD : TY=PLY+FY*BEAMNOSE : TZ=PZ+FZ*BEAMNOSE+RZ*BEAMGAP*SD
9140 BUL(SL,2)=TX : BUL(SL,3)=TY : BUL(SL,4)=TZ
9150 BUL(SL,5)=FX*BEAMSPD : BUL(SL,6)=FY*BEAMSPD : BUL(SL,7)=FZ*BEAMSPD
9160 GL.SCALE ID,1,1,1 : GL.TRANSLATE ID,TX,TY,TZ
9170 GL.ROTATE ID,RXDEG,RYDEG,0
9180 NEXT S2
9190 END SUB
10000 REM ============================================================
10010 REM Explode - light up one blast (two red spheres) at EXSPX/Y/Z
10020 REM ============================================================
10030 SUB Explode STATIC
10040 SHARED BLAST, EXNEXT, BBNEXT, EXKIND, EXSPX, EXSPY, EXSPZ
10050 IF EXKIND=0 THEN SL=EXNEXT : EXNEXT=EXNEXT+1 : IF EXNEXT>=8 THEN EXNEXT=0
10060 IF EXKIND=1 THEN SL=BBNEXT : BBNEXT=BBNEXT+1 : IF BBNEXT>=16 THEN BBNEXT=8
10070 BLAST(SL,2)=1 : BLAST(SL,3)=0
10080 IDA=BLAST(SL,0) : IDB=BLAST(SL,1)
10090 GL.TRANSLATE IDA, EXSPX+0.6, EXSPY+0.4, EXSPZ+0.3
10100 GL.TRANSLATE IDB, EXSPX-0.6, EXSPY-0.2, EXSPZ-0.3
10110 END SUB
11000 REM ============================================================
11010 REM InitTanks - load tank.glb once, then drop 20 GPU instances
11020 REM   (GL.INSTANCE), random spots/facings, tilted to the terrain
11030 REM ============================================================
11040 SUB InitTanks STATIC
11050 SHARED TANK, NT, PI, TANKSRC
11060 NT=20 : TCX=320 : TCZ=320 : TAREA=2200 : TSCALE=0.7 : TYOFF=5.5 : TYAWADJ=0 : TPD=4 : FLATMAX=2
11070 GL.LOAD "files/models/tank.glb", 0, 0, 0
11080 TANKSRC=GL.MESHID
11090 GL.SCALE TANKSRC, TSCALE, TSCALE, TSCALE
11100 FOR I=0 TO NT-1
11110 TPICK:
11120 TX=TCX+(RND(1)-0.5)*TAREA : TZ=TCZ+(RND(1)-0.5)*TAREA
11130 GL.PROBE TX,TZ : TY=GL.PROBEY
11140 IF TY>FLATMAX THEN GOTO TPICK
11150 GL.PROBE TX+TPD,TZ : HPX=GL.PROBEY : GL.PROBE TX-TPD,TZ : HMX=GL.PROBEY
11160 GL.PROBE TX,TZ+TPD : HPZ=GL.PROBEY : GL.PROBE TX,TZ-TPD : HMZ=GL.PROBEY
11170 GX=(HPX-HMX)/(2*TPD) : GZ=(HPZ-HMZ)/(2*TPD)
11180 TYAW=RND(1)*2*PI+TYAWADJ : DX=COS(TYAW) : DZ=SIN(TYAW)
11190 SF=GX*DX+GZ*DZ : SR=GX*(0-DZ)+GZ*DX
11200 TPITCH=0-ATN(SF)*180/PI : TROLL=ATN(SR)*180/PI
11210 TANK(I,0)=1 : TANK(I,1)=TX : TANK(I,2)=TY+TYOFF : TANK(I,3)=TZ : TANK(I,4)=TYAW : TANK(I,5)=0
11220 GL.INSTANCE TANKSRC, TX, TY+TYOFF, TZ, DX, 0, DZ, TROLL, TPITCH
11230 NEXT I
11240 END SUB
12000 REM ============================================================
12010 REM DrawMinimap - plane (red) + static tanks (white) as dots
12020 REM ============================================================
12030 SUB DrawMinimap STATIC
12040 SHARED PX, PZ, CELL, MSCL, MMX, MMY, MZ, MAPVIS, TANK, NT
12050 IF MAPVIS=0 THEN EXIT SUB
12060 IF INITED=1 THEN GOTO MMErase
12070 OLDMC=-1 : INITED=1
12080 MMErase:
12090 IF OLDMC<0 THEN GOTO MMTanks
12100 FOR PR=0 TO MSCL-1
12110 FOR PC=0 TO MSCL-1
12120 PSET MMX+OLDMC*MSCL+PC, MMY+OLDMR*MSCL+PR, 8
12130 NEXT PC : NEXT PR
12140 MMTanks:
12150 FOR I=0 TO NT-1
12160 TMC=INT((TANK(I,1)/CELL+1.5*MZ)/4) : TMR=INT((TANK(I,3)/CELL+1.5*MZ)/4)
12170 TPX=MMX+TMC*MSCL+3 : TPY=MMY+TMR*MSCL+3
12180 FOR PR=0 TO 4
12190 FOR PC=0 TO 4
12200 PSET TPX+PC, TPY+PR, 15
12210 NEXT PC : NEXT PR
12220 NEXT I
12230 MC=INT((PX/CELL+1.5*MZ)/4) : MR=INT((PZ/CELL+1.5*MZ)/4)
12240 IF MC<0 OR MC>=MZ OR MR<0 OR MR>=MZ THEN EXIT SUB
12250 OLDMC=MC : OLDMR=MR
12260 FOR PR=0 TO MSCL-1
12270 FOR PC=0 TO MSCL-1
12280 PSET MMX+MC*MSCL+PC, MMY+MR*MSCL+PR, 12
12290 NEXT PC : NEXT PR
12300 END SUB
13000 REM ============================================================
13010 REM UpdateBullets - advance beams + blasts; terrain + tank hits
13020 REM ============================================================
13030 SUB UpdateBullets STATIC
13040 SHARED BUL, NB, DT, BLAST, NE, EXNEXT, BBNEXT, BLASTLIFE, PI, TANK, NT, TANKSRC, HITR2, EXKIND, TKILLS, BBDROP
13050 FOR I=0 TO NB-1
13060 IF BUL(I,1)=1 THEN BUL(I,8)=BUL(I,8)-DT : BUL(I,2)=BUL(I,2)+BUL(I,5)*DT : BUL(I,3)=BUL(I,3)+BUL(I,6)*DT : BUL(I,4)=BUL(I,4)+BUL(I,7)*DT
13070 IF BUL(I,1)=1 THEN BID=BUL(I,0) : BX=BUL(I,2) : BY=BUL(I,3) : BZ=BUL(I,4) : GL.TRANSLATE BID,BX,BY,BZ
13080 IF BUL(I,1)=1 THEN GL.PROBE BX,BZ
13090 HIT=0
13100 IF BUL(I,1)=1 AND BUL(I,8)<=0 THEN HIT=1
13110 IF BUL(I,1)=1 AND BY<=GL.PROBEY+0.3 THEN HIT=2
13120 FOR K=0 TO NT-1
13130 IF BUL(I,1)=1 AND TANK(K,0)=1 THEN DXX=BX-TANK(K,1) : DYY=BY-TANK(K,2) : DZZ=BZ-TANK(K,3) : D2=DXX*DXX+DYY*DYY+DZZ*DZZ : IF D2<HITR2 THEN HIT=3 : TANK(K,0)=0 : GL.INSTHIDE TANKSRC,K : TKILLS=TKILLS+1
13140 NEXT K
13150 IF HIT>0 THEN GL.SCALE BID,0,0,0
13160 IF HIT>0 THEN BUL(I,1)=0
13170 IF HIT>=2 THEN EXSPX=BX
13180 IF HIT>=2 THEN EXSPZ=BZ
13190 IF HIT=2 THEN EXSPY=GL.PROBEY
13200 IF HIT=3 THEN EXSPY=BY-BBDROP
13210 IF HIT>=2 THEN EXKIND=HIT-2
13220 IF HIT>=2 THEN CALL Explode
13230 NEXT I
13240 FOR J=0 TO NE-1
13250 IF BLAST(J,2)=1 THEN BLAST(J,3)=BLAST(J,3)+DT : XA=BLAST(J,0) : XB=BLAST(J,1) : FR=BLAST(J,3)/BLASTLIFE
13260 IF BLAST(J,2)=1 THEN SC=SIN(FR*PI)*BLAST(J,4) : SB=SC*0.7
13270 IF BLAST(J,2)=1 THEN GL.SCALE XA,SC,SC,SC : GL.SCALE XB,SB,SB,SB
13280 IF BLAST(J,2)=1 AND FR>=1 THEN GL.SCALE XA,0,0,0
13290 IF BLAST(J,2)=1 AND FR>=1 THEN GL.SCALE XB,0,0,0
13300 IF BLAST(J,2)=1 AND FR>=1 THEN BLAST(J,2)=0
13310 NEXT J
13320 END SUB
14000 REM ============================================================
14010 REM AIPilot - demo target-lock state machine. The "radar" knows
14020 REM   where every live tank is. Lock the nearest, hunt with
14030 REM   bearing-based steering. If we get too close (DH<80) flip
14040 REM   to ESCAPE: head 180 degrees away. Re-engage past DH>350.
14050 REM   One target at a time until killed; mountain evasion lives
14060 REM   in DemoLoop and takes precedence over both modes.
14070 REM ============================================================
14080 SUB AIPilot STATIC
14090 SHARED PX, PZ, PLY, CUBEYAW, PYAW, PPITCH, PROLL, EBOOST, EBOOSTLP, PI, WAYX, WAYZ, WAYTIME, NOW, CLIMBOVER, CLIMBHOLD, BIASLP, BRLP, TARGETID, TARGETTIME, KILLPAUSE, SHOTS, TANK, NT, MAXPITCH, MAXPDOWN, MAXCLIMB, MAXROLL, TGT, DT, LH0, LH1, LH2, LHW, NEARH, SEV, SEVF, SEVN, PITCH, BUL, NB, BNEXT, LASTFIRE, BEAMSPD, BEAMGAP, BEAMNOSE, BEAMLIFE, YAWOFF
14100 CALL TargetPick
14110 DXW=WAYX-PX : DZW=WAYZ-PZ : BR=ATN(DZW/(DXW+0.0001)) : IF DXW<0 THEN BR=BR+PI
14120 BR=BR-2*PI*INT((BR+PI)/(2*PI)) : DBR=BR-BRLP : DBR=DBR-2*PI*INT((DBR+PI)/(2*PI)) : BRLP=BRLP+DBR*0.03 : BRLP=BRLP-2*PI*INT((BRLP+PI)/(2*PI)) : PYAW=BRLP : EBOOST=1 : PPITCH=0 : PROLL=0
14122 GL.PROBE PX,PZ : NEARH=GL.PROBEY
14123 GL.SCANFWD PX,PZ,CUBEYAW,20,50 : LH0=GL.SCANY : GL.SCANFWD PX,PZ,CUBEYAW,60,120 : LH1=GL.SCANY
14124 GL.SCANFWD PX,PZ,CUBEYAW,200,500 : LH2=GL.SCANY : GL.SCANFWD PX,PZ,BRLP,150,350 : LHW=GL.SCANY
14125 AIG_NAVIGATE PX,PZ,PLY,CUBEYAW,WAYX,WAYZ,35
14130 SEV=AIG_SEV : CLIMBOVER=0
14131 IF LH1>PLY+40 OR LH2>PLY+30 OR LHW>PLY+30 THEN CLIMBOVER=1
14134 BIASLP=BIASLP*0.92+AIG_YAW*0.08 : PYAW=PYAW+BIASLP : PROLL=BIASLP*1.2
14136 PPITCH=AIG_PITCH : EBOOST=AIG_BOOST
14137 IF PPITCH>MAXCLIMB THEN PPITCH=MAXCLIMB
14138 IF PPITCH<0-MAXPDOWN THEN PPITCH=0-MAXPDOWN
14139 IF CLIMBOVER=1 OR SEV>0.5 THEN CLIMBHOLD=60
14140 IF CLIMBHOLD>0 THEN CLIMBHOLD=CLIMBHOLD-1 : PPITCH=MAXCLIMB : EBOOST=2.0
14142 IF CLIMBHOLD>0 AND PLY>NEARH+60 AND PLY>LH1+30 AND PLY>LH2+30 THEN CLIMBHOLD=0
14144 IF PLY<NEARH+8 THEN PITCH=MAXCLIMB : PPITCH=MAXCLIMB : EBOOST=2.0 : CLIMBHOLD=60
14145 IF TARGETID>=0 THEN DTX=TANK(TARGETID,1)-PX : DTZ=TANK(TARGETID,3)-PZ : IF DTX*DTX+DTZ*DTZ<40000 THEN BIASLP=BIASLP*0.7 : PYAW=BRLP
14160 CALL Destroy
14170 EBOOSTLP=EBOOSTLP*0.95+EBOOST*0.05 : EBOOST=EBOOSTLP
14250 END SUB
17000 REM ============================================================
17010 REM TargetPick - Phase 2: navigate from tank to tank
17020 REM   First target after 500 ms = closest alive tank.
17030 REM   On arrival (DH<30) = random alive tank >200 units away;
17040 REM   falls back to any alive tank if none qualifies.
17050 REM ============================================================
17060 SUB TargetPick STATIC
17070 SHARED PX, PZ, CUBEYAW, PITCH, WAYX, WAYZ, WAYTIME, NOW, TARGETID, TARGETTIME, KILLPAUSE, SHOTS, TANK, NT
17080 IF WAYTIME=0 THEN WAYTIME=NOW : WAYX=PX+COS(CUBEYAW)*3000 : WAYZ=PZ+SIN(CUBEYAW)*3000 : TARGETID=0-1
17085 IF TARGETID>=0 AND TANK(TARGETID,0)=0 AND KILLPAUSE=0 THEN KILLPAUSE=30
17086 IF TARGETID>=0 AND TANK(TARGETID,0)=0 AND PITCH<0 THEN PITCH=0
17087 IF KILLPAUSE>0 THEN WAYX=PX+COS(CUBEYAW)*1000 : WAYZ=PZ+SIN(CUBEYAW)*1000
17088 IF KILLPAUSE>0 THEN KILLPAUSE=KILLPAUSE-1
17089 IF KILLPAUSE>0 THEN EXIT SUB
17090 NEEDCLOSE=0 : NEEDRAND=0
17100 IF TARGETID=0-1 AND NOW-WAYTIME>2000 THEN NEEDCLOSE=1
17110 IF TARGETID>=0 THEN DXT=TANK(TARGETID,1)-PX : DZT=TANK(TARGETID,3)-PZ : DDT=DXT*DXT+DZT*DZT : IF DDT<900 OR TANK(TARGETID,0)=0 THEN NEEDRAND=1 : TARGETID=0-1
17120 IF TARGETID>=0 AND NOW-TARGETTIME>5000 THEN TANK(TARGETID,5)=TANK(TARGETID,5)+1 : NEEDRAND=1 : TARGETID=0-1
17125 IF TARGETID>=0 AND SHOTS>=10 THEN TANK(TARGETID,5)=TANK(TARGETID,5)+1 : NEEDRAND=1 : TARGETID=0-1
17130 IF NEEDCLOSE=1 THEN ND=99999999 : TARGETID=0-1
17140 FOR K=0 TO NT-1
17150 IF NEEDCLOSE=1 AND TANK(K,0)=1 AND TANK(K,5)<3 THEN DXT=TANK(K,1)-PX : DZT=TANK(K,3)-PZ : DD=DXT*DXT+DZT*DZT : IF DD<ND THEN ND=DD : TARGETID=K
17160 NEXT K
17170 FOR T=0 TO 19
17180 IF NEEDRAND=1 AND TARGETID=0-1 THEN R=INT(RND(1)*NT) : IF TANK(R,0)=1 AND TANK(R,5)<3 THEN DXT=TANK(R,1)-PX : DZT=TANK(R,3)-PZ : DD=DXT*DXT+DZT*DZT : IF DD>40000 THEN TARGETID=R
17190 NEXT T
17200 FOR K=0 TO NT-1
17210 IF NEEDRAND=1 AND TARGETID=0-1 AND TANK(K,0)=1 THEN TARGETID=K
17220 NEXT K
17230 IF (NEEDCLOSE=1 OR NEEDRAND=1) AND TARGETID>=0 THEN TARGETTIME=NOW : SHOTS=0
17240 IF TARGETID>=0 THEN WAYX=TANK(TARGETID,1) : WAYZ=TANK(TARGETID,3)
17250 END SUB
18000 REM ============================================================
18010 REM Destroy - Phase 3: aim + fire when close to current target
18020 REM   Skips when CLIMBHOLD>0 so the plane stays focused on
18030 REM   clearing terrain in an emergency.
18040 REM ============================================================
18050 SUB Destroy STATIC
18060 SHARED PX, PZ, PLY, CUBEYAW, PITCH, PPITCH, TANK, TARGETID, CLIMBHOLD, SEV, NEARH, PI, BUL, NB, BNEXT, LASTFIRE, SHOTS, BEAMSPD, BEAMGAP, BEAMNOSE, BEAMLIFE, YAWOFF
18070 IF TARGETID<0 THEN EXIT SUB
18080 IF TANK(TARGETID,0)=0 THEN EXIT SUB
18090 IF CLIMBHOLD>0 THEN EXIT SUB
18095 IF SEV>0.3 THEN EXIT SUB
18096 IF PLY<NEARH+15 THEN EXIT SUB
18100 DXT=TANK(TARGETID,1)-PX : DZT=TANK(TARGETID,3)-PZ : DYT=TANK(TARGETID,2)-2-PLY : DH=SQR(DXT*DXT+DZT*DZT)+0.001 : DOT=(COS(CUBEYAW)*DXT+SIN(CUBEYAW)*DZT)/DH
18105 TANKY=TANK(TARGETID,2) : BEAMY1=PLY+(TANKY-PLY)*0.35 : BEAMY2=PLY+(TANKY-PLY)*0.65 : GL.PROBE PX+DXT*0.35,PZ+DZT*0.35 : LOS1=GL.PROBEY : GL.PROBE PX+DXT*0.65,PZ+DZT*0.65 : LOS2=GL.PROBEY
18107 IF LOS1>BEAMY1+2 OR LOS2>BEAMY2+2 THEN EXIT SUB
18110 IF DH<280 AND DH>30 AND DOT>0 THEN PPITCH=ATN(DYT/DH) : IF PPITCH<0-0.3 THEN PPITCH=0-0.3
18120 IF DH<280 AND DH>25 AND DOT>0.5 THEN CALL Fire
18130 END SUB
19000 REM ============================================================
19010 REM Navigate - stub: all logic moved into AIPilot via AIG_NAVIGATE.
19020 REM Kept so legacy CALL Navigate references still resolve.
19030 REM ============================================================
19050 SUB Navigate STATIC
19180 END SUB
