0 CLS : COLOUR 3 : ? CENTER$("Lines 1")
5 DELAY 0
10 CENTERX=WIDTH/2
20 CENTERY=HEIGHT/2
25 FOR C=1 TO 16
29 SS=RND(10)+3
30 FOR I=1 TO WIDTH STEP SS
31   LINE CENTERX,CENTERY,I,0,C
32   LINE CENTERX,CENTERY,I,HEIGHT,C
33   IF INKEY>0 THEN GOTO 52
34   SLEEP 16
35 NEXT I
36 ST=RND(8)+2
37 FOR J=1 TO HEIGHT STEP ST
38   IF INKEY>0 THEN 52
39   LINE CENTERX,CENTERY,0,J,C
40   LINE CENTERX,CENTERY,WIDTH,J,C
41   SLEEP 16
44 NEXT J
45 NEXT C
47 COLOUR 3
48 PRINT LINES$(11);CENTER$("Hit any key")
49 DUM=GETKEY()
50 CLS
52 SLEEP 300
