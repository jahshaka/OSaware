115 REM --- Walker step ---
116 WYAW=WYAW+(RND(1)*2-1)*WTURN
117 NPX=PX+COS(WYAW)*WSPEED : NPZ=PZ+SIN(WYAW)*WSPEED
118 IF NPX<CELL*1.5 OR NPX>CELL*14.5 OR NPZ<CELL*1.5 OR NPZ>CELL*14.5 THEN WYAW=WYAW+PI : NPX=PX+COS(WYAW)*WSPEED : NPZ=PZ+SIN(WYAW)*WSPEED
119 PX=NPX : PZ=NPZ
120 WTICK=WTICK+1
122 IF WTICK>=4 THEN WTICK=0 : CALL DropRibbon
126 REM --- Static overhead camera + bright white light ---
127 GL.CAMERA 40,50,90 : GL.LOOKAT 40,0,40
128 GL.LIGHTSOFF : GL.POINTLIGHT ARENACX,30,ARENACX,255,255,255,8,120
133 CALL DrawMinimap
134 GL.CLS 2,2,8 : GL.DRAWALL
143 SLEEP 16 : GOTO MainLoop
200 END
305 REM InitMinimap - Draw arena borders into pixel buffer once
306 SUB InitMinimap STATIC
307 SHARED MAP, MZ, MSCL, MMX, MMY, MAPVIS
308 MSCL=8 : MAPVIS=1
310 MMX=WIDTH-MZ*MSCL-6 : MMY=HEIGHT-MZ*MSCL-6
312 DELAY 0
313 FOR MR=0 TO MZ-1
314 FOR MC=0 TO MZ-1
315 IF MAP(MR,MC)=1 THEN MC2=7 ELSE MC2=15
317 FOR PR=0 TO MSCL-1
318 FOR PC=0 TO MSCL-1
319 PSET MMX+MC*MSCL+PC, MMY+MR*MSCL+PR, MC2
320 NEXT PC : NEXT PR
322 NEXT MC : NEXT MR
342 END SUB
354 REM DrawMinimap - Move walker dot on minimap each frame
355 SUB DrawMinimap STATIC
356 SHARED PX, PZ, CELL, MSCL, MMX, MMY, MAP, MZ, MAPVIS
357 IF MAPVIS=0 THEN EXIT SUB
358 IF INITED=1 THEN GOTO CheckErase
359 OLDMR=-1 : OLDMC=-1 : INITED=1
360 CheckErase:
361 IF OLDMR<0 THEN GOTO DrawDot
362 IF MAP(OLDMR,OLDMC)=1 THEN OC=7 ELSE OC=15
363 FOR PR=0 TO MSCL-1
364 FOR PC=0 TO MSCL-1
365 PSET MMX+OLDMC*MSCL+PC, MMY+OLDMR*MSCL+PR, OC
366 NEXT PC : NEXT PR
367 DrawDot:
368 MR=INT(PZ/CELL) : MC=INT(PX/CELL)
369 OLDMR=MR : OLDMC=MC
370 PDX=MMX+MC*MSCL+INT(MSCL/2) : PDY=MMY+MR*MSCL+INT(MSCL/2)
372 PSET PDX,PDY,14 : PSET PDX+1,PDY,14 : PSET PDX,PDY+1,14 : PSET PDX+1,PDY+1,14
376 END SUB
382 REM ToggleMap - Show / hide minimap overlay
383 SUB ToggleMap STATIC
384 SHARED MAPVIS, MZ, MSCL, MMX, MMY
385 MAPVIS=1-MAPVIS
386 IF MAPVIS=1 THEN CALL InitMinimap : EXIT SUB
388 FOR CR=0 TO MZ*MSCL-1
389 FOR CC=0 TO MZ*MSCL-1
390 PSET MMX+CC, MMY+CR, 16
391 NEXT CC : NEXT CR
393 END SUB
395 REM ToggleFog - Toggle fog on/off
396 SUB ToggleFog STATIC
397 SHARED FOGON
398 FOGON=1-FOGON
399 IF FOGON=1 THEN GL.FOG 2,2,8,10,50
400 IF FOGON=0 THEN GL.FOGOFF
401 END SUB
440 REM TestRibbons - 5 different test meshes to diagnose what renders
441 SUB TestRibbons STATIC
442 GL.SOLID : GL.COLOUR 0,200,255 : GL.SHINE 80 : GL.EMISSIVE 0,80,120 : GL.ALPHA 1.0
443 REM Test 1 NW (15..25/15..25): VERTICAL QUAD ribbon (current style, double-sided)
444 GL.BEGIN
445 GL.VERTEX 15,-0.05,15 : GL.VERTEX 15,-0.55,15
446 GL.VERTEX 25,-0.55,25 : GL.VERTEX 25,-0.05,25
447 GL.FACE 1,2,3,4 : GL.FACE 4,3,2,1
448 GL.END
449 REM Test 2 NE (55..65/15..25): HORIZONTAL QUAD on floor at y=-1.3, double-sided
450 GL.BEGIN
451 GL.VERTEX 55,-1.3,15 : GL.VERTEX 65,-1.3,15
452 GL.VERTEX 65,-1.3,25 : GL.VERTEX 55,-1.3,25
453 GL.FACE 1,2,3,4 : GL.FACE 4,3,2,1
454 GL.END
455 REM Test 3 SW (20/60): GL.BOX - sanity check that GL.BOX renders at all
456 GL.BOX 3,1,3
457 T3=GL.MESHID : GL.TRANSLATE T3,20,-0.5,60
458 REM Test 4 SE (60/60): GL.SPHERE - sanity check
459 GL.SPHERE 2,16,12
460 T4=GL.MESHID : GL.TRANSLATE T4,60,-0.3,60
461 REM Test 5 center (38..42/38..42): CLOSED PRISM like MAZE3D walls (6 faces)
462 GL.BEGIN
463 GL.VERTEX 38,-0.55,38 : GL.VERTEX 42,-0.55,38
464 GL.VERTEX 42,-0.05,38 : GL.VERTEX 38,-0.05,38
465 GL.VERTEX 38,-0.55,42 : GL.VERTEX 42,-0.55,42
466 GL.VERTEX 42,-0.05,42 : GL.VERTEX 38,-0.05,42
467 GL.FACE 1,2,3,4 : GL.FACE 8,7,6,5
468 GL.FACE 5,1,4,8 : GL.FACE 2,6,7,3
469 GL.FACE 5,6,2,1 : GL.FACE 4,3,7,8
470 GL.END
471 END SUB
502 REM BuildScene - GL init, floor, walls (no cube)
503 SUB BuildScene STATIC
504 GL.INIT : GL.PERSPECTIVE 72 : GL.AMBIENT 0.35
510 REM --- Floor: dark blue-black ---
511 FL=16*5.0
512 GL.SOLID : GL.COLOUR 10,10,30 : GL.SHINE 2 : GL.EMISSIVE 0,0,0 : GL.ALPHA 1.0
513 GL.BEGIN
514 GL.VERTEX 0,0,0 : GL.VERTEX FL,0,0 : GL.VERTEX FL,0,FL : GL.VERTEX 0,0,FL
515 GL.FACE 1,2,3,4
516 GL.END
517 SHARED FLOORID
518 FLOORID=GL.MESHID : GL.TRANSLATE FLOORID,0,-1.4,0
519 GL.TEXTURE FLOORID,"checkerboard",16
530 REM --- Walls: glowing blue ---
531 SHARED MAP, MZ, CELL
532 FOR WR=0 TO MZ-1
533 FOR WC=0 TO MZ-1
534 IF MAP(WR,WC)=0 THEN GOTO NextWall
535 WX1=WC*CELL : WX2=WX1+CELL : WZ1=WR*CELL : WZ2=WZ1+CELL
537 GL.SOLID : GL.COLOUR 0,40,80 : GL.EMISSIVE 0,20,60 : GL.SHINE 60 : GL.ALPHA 1.0
538 GL.BEGIN
539 GL.VERTEX WX1,-1.4,WZ1 : GL.VERTEX WX2,-1.4,WZ1
540 GL.VERTEX WX2, 1.4,WZ1 : GL.VERTEX WX1, 1.4,WZ1
541 GL.VERTEX WX1,-1.4,WZ2 : GL.VERTEX WX2,-1.4,WZ2
542 GL.VERTEX WX2, 1.4,WZ2 : GL.VERTEX WX1, 1.4,WZ2
543 GL.FACE 1,2,3,4 : GL.FACE 8,7,6,5
544 GL.FACE 5,1,4,8 : GL.FACE 2,6,7,3
545 GL.FACE 5,6,2,1 : GL.FACE 4,3,7,8
546 GL.END
547 NextWall:
548 NEXT WC : NEXT WR
565 END SUB
700 REM DropRibbon - Append trail point, rebuild ribbon as one continuous wall (faces only, no seams)
701 SUB DropRibbon STATIC
702 SHARED PX, PZ, RPX(), RPZ(), RIBN, RIBID
703 RBMAX=40
704 IF RIBN < RBMAX THEN GOTO RBPUT
705 FOR RI=1 TO RIBN-1
706 RPX(RI)=RPX(RI+1) : RPZ(RI)=RPZ(RI+1)
707 NEXT RI
708 RIBN=RIBN-1
709 RBPUT:
710 RIBN=RIBN+1 : RPX(RIBN)=PX : RPZ(RIBN)=PZ
711 IF RIBN<2 THEN EXIT SUB
712 IF RIBID>0 THEN GL.HIDE RIBID
713 GL.SOLID : GL.COLOUR 0,200,255 : GL.SHINE 80 : GL.EMISSIVE 0,80,120 : GL.ALPHA 1.0
714 GL.BEGIN
715 FOR RI=1 TO RIBN
716 GL.VERTEX RPX(RI),-0.55,RPZ(RI)
717 GL.VERTEX RPX(RI),-0.05,RPZ(RI)
718 NEXT RI
719 FOR RI=0 TO RIBN-2
720 GL.FACE 2*RI+1,2*RI+3,2*RI+4,2*RI+2
721 NEXT RI
722 GL.END
723 RIBID=GL.MESHID
724 END SUB
6049 REM Quit - Clean exit
6050 SUB Quit STATIC
6052 MOUSE OFF : UI ON
6053 FULLSCREEN OFF
6054 GL.CLOSE
6058 CLS
6059 PRINT "TRONRIBBON ended."
6061 PRINT ""
6062 PRINT "Press any key..."
6063 SLEEP 400
6064 DUMMY=GETKEY()
6065 END
6066 END SUB
