10 REM *** PAC-MAN ***
20 REM *** WASD/arrows to move. Eat all dots. Avoid ghosts! ***
30 REM *** Q or ESC to quit. ***
40 CLS : COLOUR 3
50 PRINT "PAC-MAN"
60 PRINT "WASD or arrows to move. Eat all dots."
70 PRINT "Power pellets let you eat ghosts!"
80 PRINT "Q or ESC to quit."
90 PRINT ""
100 PRINT "Press any key to start..."
110 DUMMY=GETKEY()
120 CALL InitGame
130 CALL LoadSprites
140 CALL BuildMaze
150 CALL DrawMaze
160 CALL PlaceSprites
170 CALL DrawHud
180 REM == MAIN LOOP ==
190 TICK=0
200 IF LIVES<=0 THEN CALL GameOver(0) : END
210 IF DOTS<=0  THEN CALL GameOver(1) : END
220 CALL ReadInput
230 IF QUITF=1 THEN CLS : PRINT "Bye!" : END
240 TICK=TICK+1
250 IF TICK>=4 THEN TICK=0
260 IF TICK=0 THEN CALL MovePacman
270 CALL MoveGhosts
280 CALL UpdateVisual
290 CALL CheckGhostHit
300 CALL DrawHud
310 SLEEP 50
320 GOTO 200
330 REM ============================================================
340 REM  InitGame — constants, arrays, sprite metrics
350 REM ============================================================
360 SUB InitGame STATIC
370 SHARED CW, CH, TS, OX, OY
380 SHARED PX, PY, D, ND, SCORE, LIVES, DOTS, POWERED, QUITF
390 SHARED DXA, DYA, GXA, GYA, GDX, GDY, GCNT, GS
400 SHARED VPX, VPY, VGX, VGY
405 SHARED FACING
406 SHARED PWR_WAS, G1S$, G2S$, G3S$, BS$
407 SHARED FLIPPED
410 CW=19 : CH=15
420 TSW=INT(WIDTH/CW) : TSH=INT(HEIGHT/CH)
430 IF TSW<TSH THEN TS=TSW ELSE TS=TSH
440 IF TS<10 THEN TS=10
450 OX=INT((WIDTH-CW*TS)/2) : OY=INT((HEIGHT-CH*TS)/2)
460 SCORE=0 : LIVES=3 : POWERED=0 : D=1 : ND=1 : QUITF=0
465 FACING=1
466 PWR_WAS=0
467 FLIPPED=0
470 DIM DXA(3), DYA(3)
480 DIM GXA(4), GYA(4), GDX(4), GDY(4), GCNT(4), GS(4)
490 DXA(0)=0  : DYA(0)=-1
500 DXA(1)=1  : DYA(1)=0
510 DXA(2)=0  : DYA(2)=1
520 DXA(3)=-1 : DYA(3)=0
530 GS(2)=5 : GS(3)=7 : GS(4)=5
540 GDX(2)=1  : GDY(2)=0
550 GDX(3)=-1 : GDY(3)=0
560 GDX(4)=0  : GDY(4)=1
570 DIM VGX(4), VGY(4)
580 END SUB
610 REM ============================================================
620 REM  BuildMaze — string-encoded grid, count dots, place actors
630 REM ============================================================
640 SUB BuildMaze STATIC
650 SHARED CW, MZ$, DOTS, PX, PY, GXA, GYA
660 MZ$=""
670 MZ$=MZ$+"WWWWWWWWWWWWWWWWWWW"
680 MZ$=MZ$+"W........W........W"
690 MZ$=MZ$+"W.WW.WW..W..WW.WW.W"
700 MZ$=MZ$+"WO.W...........W.OW"
710 MZ$=MZ$+"W..W.WWWWWWWWW.W..W"
720 MZ$=MZ$+"W....W.......W....W"
730 MZ$=MZ$+"WWWW.W..WWW..W.WWWW"
740 MZ$=MZ$+"T......WWWWW......T"
750 MZ$=MZ$+"WWWW.W.......W.WWWW"
760 MZ$=MZ$+"W....W.......W....W"
770 MZ$=MZ$+"W..W.WWWWWWWWW.W..W"
780 MZ$=MZ$+"WO.W...........W.OW"
790 MZ$=MZ$+"W.WW.WW..W..WW.WW.W"
800 MZ$=MZ$+"W....P...W........W"
810 MZ$=MZ$+"WWWWWWWWWWWWWWWWWWW"
820 DOTS=0
830 FOR II=1 TO LEN(MZ$)
840   C$=MID$(MZ$,II,1)
850   IF C$="." OR C$="O" THEN DOTS=DOTS+1
860 NEXT II
870 PX=5 : PY=13
880 PI=PY*CW+PX+1
890 MZ$=MID$(MZ$,1,PI-1)+" "+MID$(MZ$,PI+1,LEN(MZ$))
900 GXA(2)=8  : GYA(2)=8
910 GXA(3)=9  : GYA(3)=8
920 GXA(4)=10 : GYA(4)=8
930 END SUB
940 REM ============================================================
950 REM  DrawMaze — full screen redraw, walls/dots/pellets
960 REM ============================================================
970 SUB DrawMaze STATIC
980 SHARED CW, CH, TS, OX, OY, MZ$
990 CLS : DELAY 0
1000 FILLRECT OX, OY, OX+CW*TS, OY+CH*TS, 16
1010 FOR MY=0 TO CH-1
1020   FOR MX=0 TO CW-1
1030     TI=MY*CW+MX+1
1040     C$=MID$(MZ$,TI,1)
1050     X=MX*TS+OX : Y=MY*TS+OY
1060     IF C$="W" THEN FILLRECT X, Y, X+TS, Y+TS, 9
1070     DS=0
1080     IF C$="." THEN DS=INT(TS/7)
1090     IF C$="." THEN FILLCIRCLE X+TS/2, Y+TS/2, DS, 7
1100     IF C$="O" THEN DS=INT(TS/3)
1110     IF C$="O" THEN FILLCIRCLE X+TS/2, Y+TS/2, DS, 1
1120   NEXT MX
1130 NEXT MY
1140 OBJECT.ON 1 : OBJECT.ON 2 : OBJECT.ON 3 : OBJECT.ON 4
1150 END SUB
1160 REM ============================================================
1170 REM  PlaceSprites — initial sprite positions after maze draw
1180 REM ============================================================
1190 SUB PlaceSprites STATIC
1200 SHARED TS, OX, OY, PX, PY, GXA, GYA, VPX, VPY, VGX, VGY
1210 VPX=PX*TS : VPY=PY*TS
1220 OBJECT.X 1, OX+VPX+(TS-32)/2
1230 OBJECT.Y 1, OY+VPY+(TS-32)/2
1240 FOR GID=2 TO 4
1250   VGX(GID)=GXA(GID)*TS
1260   VGY(GID)=GYA(GID)*TS
1270   OBJECT.X GID, OX+VGX(GID)+(TS-32)/2
1280   OBJECT.Y GID, OY+VGY(GID)+(TS-32)/2
1290 NEXT GID
1300 END SUB
1310 REM ============================================================
1320 REM  DrawHud — top status line
1330 REM ============================================================
1340 SUB DrawHud STATIC
1350 SHARED SCORE, LIVES, DOTS, POWERED
1360 LOCATE 0,0
1370 IF POWERED>0 THEN PRINT "SCORE:";SCORE;"  LIVES:";LIVES;"  DOTS:";DOTS;"  POWER!  "; ELSE PRINT "SCORE:";SCORE;"  LIVES:";LIVES;"  DOTS:";DOTS;"         ";
1380 END SUB
1390 REM ============================================================
1400 REM  ReadInput — buffer next direction in ND, set QUITF on quit
1410 REM ============================================================
1420 SUB ReadInput STATIC
1430 SHARED ND, QUITF
1440 K=INKEY
1450 SWITCH(K)
1452 CASE 87,119,38:
1454 ND=0 : BREAK
1456 CASE 68,100,39:
1458 ND=1 : BREAK
1460 CASE 83,115,40:
1462 ND=2 : BREAK
1464 CASE 65,97,37:
1466 ND=3 : BREAK
1468 CASE 81,113,27:
1470 QUITF=1 : BREAK
1472 END SWITCH
1500 END SUB
1510 REM ============================================================
1520 REM  MovePacman — buffered turn, move, dots, pellets, tunnels
1530 REM ============================================================
1540 SUB MovePacman STATIC
1550 SHARED CW, CH, TS, OX, OY, PX, PY, D, ND, MZ$, SCORE, DOTS, POWERED, DXA, DYA
1560 REM -- Try buffered direction first; if blocked, fall back to D
1570 TX=PX+DXA(ND) : TY=PY+DYA(ND)
1580 CANTURN=0
1590 IF TX<0 OR TX>=CW OR TY<0 OR TY>=CH THEN GOTO 1620
1600 TI=TY*CW+TX+1
1610 IF MID$(MZ$,TI,1)<>"W" THEN CANTURN=1
1620 IF CANTURN=1 THEN D=ND
1630 NX=PX+DXA(D) : NY=PY+DYA(D)
1640 REM -- Tunnel wraparound on tunnel cells
1650 IF NX<0 THEN NX=CW-1
1660 IF NX>=CW THEN NX=0
1670 IF NY<0 OR NY>=CH THEN EXIT SUB
1680 TI=NY*CW+NX+1 : C$=MID$(MZ$,TI,1)
1690 IF C$="W" THEN EXIT SUB
1700 PX=NX : PY=NY
1710 ATE=0
1720 IF C$="." THEN ATE=1
1730 IF C$="." THEN SCORE=SCORE+10
1740 IF C$="O" THEN ATE=1
1750 IF C$="O" THEN SCORE=SCORE+50
1760 IF C$="O" THEN POWERED=120
1770 IF ATE=1 THEN MZ$=LEFT$(MZ$,TI-1)+" "+MID$(MZ$,TI+1)
1780 IF ATE=1 THEN DOTS=DOTS-1
1790 IF ATE=1 THEN FILLRECT OX+PX*TS, OY+PY*TS, OX+PX*TS+TS, OY+PY*TS+TS, 16
1800 REM visual updated in UpdateVisual
1810 END SUB
1820 REM ============================================================
1830 REM  MoveGhosts — chase or flee, valid-direction check
1840 REM ============================================================
1850 SUB MoveGhosts STATIC
1860 SHARED CW, CH, TS, OX, OY, PX, PY, MZ$, POWERED, GXA, GYA, GDX, GDY, GCNT, GS, DXA, DYA
1870 FOR GID=2 TO 4
1880   GCNT(GID)=GCNT(GID)+1
1890   RDY=0
1900   IF GCNT(GID)>=GS(GID) THEN RDY=1
1910   IF RDY=1 THEN GCNT(GID)=0
1920   NX=GXA(GID)
1930   NY=GYA(GID)
1940   IF RDY=0 THEN GOTO 2200
1950   BX=PX-NX
1960   BY=PY-NY
1970   IF POWERED>0 THEN BX=-BX
1980   IF POWERED>0 THEN BY=-BY
1990   AX=ABS(BX)
2000   AY=ABS(BY)
2010   IF AX>=AY THEN GDX(GID)=SGN(BX)
2020   IF AX>=AY THEN GDY(GID)=0
2030   IF AX<AY THEN GDX(GID)=0
2040   IF AX<AY THEN GDY(GID)=SGN(BY)
2050   IF INT(RND(1)*10)=0 THEN GDX(GID)=-GDX(GID)
2060   IF INT(RND(1)*10)=0 THEN GDY(GID)=-GDY(GID)
2070   TX=NX+GDX(GID)
2080   TY=NY+GDY(GID)
2090   OK=1
2100   IF TX<1 THEN OK=0
2110   IF TX>CW-2 THEN OK=0
2120   IF TY<1 THEN OK=0
2130   IF TY>CH-2 THEN OK=0
2140   WI=TY*CW+TX+1
2150   WC$=" "
2160   IF OK=1 THEN WC$=MID$(MZ$,WI,1)
2170   IF WC$="W" THEN OK=0
2171   IF OK=0 THEN ODX=GDX(GID)
2172   IF OK=0 THEN ODY=GDY(GID)
2173   IF OK=0 AND ODX<>0 AND BY<>0 THEN GDX(GID)=0
2174   IF OK=0 AND ODX<>0 AND BY<>0 THEN GDY(GID)=SGN(BY)
2176   IF OK=0 AND ODY<>0 AND BX<>0 THEN GDY(GID)=0
2177   IF OK=0 AND ODY<>0 AND BX<>0 THEN GDX(GID)=SGN(BX)
2178   IF OK=0 THEN TX=GXA(GID)+GDX(GID)
2179   IF OK=0 THEN TY=GYA(GID)+GDY(GID)
2181   IF OK=0 THEN OK=1
2182   IF OK=1 AND TX<1 THEN OK=0
2183   IF OK=1 AND TX>CW-2 THEN OK=0
2184   IF OK=1 AND TY<1 THEN OK=0
2185   IF OK=1 AND TY>CH-2 THEN OK=0
2186   WC$=" "
2187   IF OK=1 THEN WI=TY*CW+TX+1
2188   IF OK=1 THEN WC$=MID$(MZ$,WI,1)
2189   IF WC$="W" THEN OK=0
2195   IF OK=1 THEN NX=TX
2196   IF OK=1 THEN NY=TY
2200   GXA(GID)=NX
2210   GYA(GID)=NY
2220 NEXT GID
2230 IF POWERED>0 THEN POWERED=POWERED-1
2240 END SUB
2250 REM ============================================================
2260 REM  CheckGhostHit — collision; eat ghost if powered, else die
2270 REM ============================================================
2280 SUB CheckGhostHit STATIC
2290 SHARED TS, OX, OY, PX, PY, LIVES, SCORE, POWERED, GXA, GYA, VPX, VPY
2300 FOR GID=2 TO 4
2310   IF GXA(GID)<>PX OR GYA(GID)<>PY THEN GOTO 2470
2320   IF POWERED=0 THEN GOTO 2370
2330   SCORE=SCORE+200
2340   GXA(GID)=9
2350   GYA(GID)=8
2360   GOTO 2470
2370   LIVES=LIVES-1
2380   CALL DrawHud
2390   SLEEP 500
2400   PX=5 : PY=13
2410   VPX=PX*TS : VPY=PY*TS
2420   GXA(2)=8 : GYA(2)=8
2430   GXA(3)=9 : GYA(3)=8
2440   GXA(4)=10 : GYA(4)=8
2450   CALL PlaceSprites
2460   EXIT SUB
2470 NEXT GID
2480 END SUB
2490 REM ============================================================
2500 REM  UpdateVisual — interpolate VPX/VPY toward tile positions
2510 REM ============================================================
2520 SUB UpdateVisual STATIC
2530 SHARED TS, OX, OY, PX, PY, GXA, GYA, VPX, VPY, VGX, VGY, D, FACING
2531 SHARED POWERED, PWR_WAS, G1S$, G2S$, G3S$, BS$
2532 SHARED FLIPPED
2540 STP=INT(TS/4)
2550 IF STP<1 THEN STP=1
2560 TGX=PX*TS
2570 TGY=PY*TS
2580 DX=TGX-VPX
2590 DY=TGY-VPY
2600 IF ABS(DX)>TS*2 THEN VPX=TGX
2610 IF ABS(DY)>TS*2 THEN VPY=TGY
2620 DX=TGX-VPX
2630 DY=TGY-VPY
2640 IF ABS(DX)<=STP THEN VPX=TGX
2650 IF ABS(DX)>STP THEN VPX=VPX+SGN(DX)*STP
2660 IF ABS(DY)<=STP THEN VPY=TGY
2670 IF ABS(DY)>STP THEN VPY=VPY+SGN(DY)*STP
2680 OBJECT.X 1, OX+VPX+(TS-32)/2
2690 OBJECT.Y 1, OY+VPY+(TS-32)/2
2700 FOR GID=2 TO 4
2710   TGX=GXA(GID)*TS
2720   TGY=GYA(GID)*TS
2730   DX=TGX-VGX(GID)
2740   DY=TGY-VGY(GID)
2750   IF ABS(DX)>TS*2 THEN VGX(GID)=TGX
2760   IF ABS(DY)>TS*2 THEN VGY(GID)=TGY
2770   DX=TGX-VGX(GID)
2780   DY=TGY-VGY(GID)
2790   IF ABS(DX)<=STP THEN VGX(GID)=TGX
2800   IF ABS(DX)>STP THEN VGX(GID)=VGX(GID)+SGN(DX)*STP
2810   IF ABS(DY)<=STP THEN VGY(GID)=TGY
2820   IF ABS(DY)>STP THEN VGY(GID)=VGY(GID)+SGN(DY)*STP
2830   OBJECT.X GID, OX+VGX(GID)+(TS-32)/2
2840   OBJECT.Y GID, OY+VGY(GID)+(TS-32)/2
2850 NEXT GID
2860 IF D=FACING THEN GOTO 2888
2862 SWITCH(D)
2864 CASE 0:
2866 OBJECT.ROTATE 1, -90 : BREAK
2868 CASE 1:
2870 OBJECT.ROTATE 1, 0 : BREAK
2872 CASE 2:
2874 OBJECT.ROTATE 1, 90 : BREAK
2876 CASE 3:
2878 OBJECT.ROTATE 1, 0
2880 IF FLIPPED=0 THEN OBJECT.FLIP 1, 0 : FLIPPED=1
2882 BREAK
2884 END SWITCH
2888 IF D<>FACING AND D<>3 AND FLIPPED=1 THEN OBJECT.FLIP 1, 0 : FLIPPED=0
2891 IF D<>FACING THEN FACING=D
2892 IF POWERED>0 AND PWR_WAS=0 THEN OBJECT.SHAPE 2, BS$ : OBJECT.SHAPE 3, BS$ : OBJECT.SHAPE 4, BS$ : PWR_WAS=1
2896 IF POWERED=0 AND PWR_WAS=1 THEN OBJECT.SHAPE 2, G1S$ : OBJECT.SHAPE 3, G2S$ : OBJECT.SHAPE 4, G3S$ : PWR_WAS=0
2900 END SUB
2910 REM ============================================================
2920 REM  GameOver — display final result. WON=1 win, WON=0 lose
2930 REM ============================================================
2940 SUB GameOver(WON) STATIC
2950 SHARED SCORE
2960 CLS
2970 IF WON=1 THEN COLOUR 3 : PRINT "YOU WIN! Score:";SCORE ELSE COLOUR 2 : PRINT "GAME OVER! Score:";SCORE
2980 END SUB
