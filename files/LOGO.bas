0 REM ** LOGO Turtle Graphics for OSAWARE v7 **
1 REM ** FD BK LT RT PU PD CS HOME COLOUR REPEAT DEFINE **
10 CLS : COLOUR 0,3,16
11 PRINT CENTER$("* * *  LOGO  * * *") : COLOUR 0,16,
12 PRINT "" : PRINT CENTER$("Turtle Graphics — OSAWARE v7")
13 PRINT ""
14 PRINT "  Turtle:   FD n  BK n  LT deg  RT deg  PU  PD  CS  HOME"
15 PRINT "  Classic:  UP n  DOWN n  LEFT n  RIGHT n  PEN UP/DOWN  CLOSE"
16 PRINT "  Style:    COLOUR n  (1-15)"
17 PRINT "  Repeat:   REPEAT n [FD 50 RT 90 FD 50 RT 90]"
18 PRINT "  Define:   DEFINE box   ...commands...   END"
19 PRINT "" : PRINT CENTER$("Press any key to start")
20 DUMMY = GETKEY()
50 TX = WIDTH/2 : TY = HEIGHT/2 : TH = 0
51 PEN = 1 : TC = 3 : FG = 3 : BG = 16
52 SX = TX : SY = TY
53 DEF = 0 : FUNC = 0 : DIM FUNCS$(64) : DIM FUNCP$(64) : CF = 0 : TF$ = ""
54 COLOUR ,,16 : CLS : PRINT LINES$(ROWS-1)
55 GOSUB 9000
100 IF DEF=1 THEN COLOUR 5 : PRINT "(def ";TF$;") "; ELSE COLOUR 2
101 INPUT "> "; A$
102 A$ = UPPER$(A$) : IF A$ = "" THEN GOTO 100
103 IF A$ = "QUIT" OR A$ = "EXIT" THEN RUN MENU
104 GOSUB 8000
105 GOTO 100
2000 PI = 3.14159265 : RAD = (TH-90)*PI/180
2001 NX = TX + ARG*COS(RAD) : NY = TY + ARG*SIN(RAD)
2002 IF PEN=1 THEN COLOUR TC : LINE TX,TY,NX,NY
2003 TX = NX : TY = NY : GOSUB 9000 : RETURN
2100 PI = 3.14159265 : RAD = (TH-90)*PI/180
2101 NX = TX - ARG*COS(RAD) : NY = TY - ARG*SIN(RAD)
2102 IF PEN=1 THEN COLOUR TC : LINE TX,TY,NX,NY
2103 TX = NX : TY = NY : GOSUB 9000 : RETURN
3000 IF PEN=1 THEN COLOUR TC : LINE TX,TY,NX,NY
3001 TX = NX : TY = NY : GOSUB 9000 : RETURN
4000 COLOUR ,,16 : CLS : PRINT LINES$(ROWS-1)
4001 TX = WIDTH/2 : TY = HEIGHT/2 : TH = 0 : SX = TX : SY = TY
4002 GOSUB 9000 : RETURN
5000 COLOUR TC : LINE TX,TY,SX,SY : TX=SX : TY=SY : GOSUB 9000 : RETURN
6000 B1=INSTR(ARG$,"[") : B2=INSTR(ARG$,"]")
6001 IF B1=0 OR B2=0 THEN PRINT "REPEAT: use [ ] eg: REPEAT 4 [FD 50 RT 90]" : RETURN
6002 REPS=VAL(ARG$) : RC$=MID$(ARG$,B1+1,B2-B1-1)
6003 FOR RI=1 TO REPS : GOSUB 6100 : NEXT RI : RETURN
6100 RP = 1
6101 IF RP > LEN(RC$) THEN RETURN
6102 IF MID$(RC$,RP,1) = " " THEN RP=RP+1 : GOTO 6101
6103 RE = RP
6104 FOR RJ=RP TO LEN(RC$) : IF MID$(RC$,RJ,1)<>" " THEN RE=RJ ELSE RJ=LEN(RC$)+1 : NEXT RJ
6105 T1$ = MID$(RC$,RP,RE-RP+1) : RP = RE+2
6106 T2$ = "" : T2=0
6107 IF RP>LEN(RC$) THEN GOTO 6112
6108 IF MID$(RC$,RP,1) < "0" OR MID$(RC$,RP,1) > "9" THEN GOTO 6112
6109 RE2=RP : FOR RK=RP TO LEN(RC$) : IF MID$(RC$,RK,1)<>" " THEN RE2=RK ELSE RK=LEN(RC$)+1 : NEXT RK
6110 T2$=MID$(RC$,RP,RE2-RP+1) : T2=VAL(T2$) : RP=RE2+2
6112 A$=T1$+" "+T2$ : GOSUB 8000
6113 GOTO 6101
7000 TF$=UPPER$(ARG$) : IF TF$="" THEN PRINT "DEFINE needs a name" : RETURN
7001 CF=FUNC+1 : FOR F=1 TO FUNC : IF FUNCS$(F)=TF$ THEN CF=F : NEXT F
7002 FUNCP$(CF)="" : DEF=1 : PRINT "Recording '";TF$;"' — type END when done"
7003 RETURN
7100 IF DEF=0 THEN RETURN
7101 FUNCS$(CF)=TF$ : FUNC=CF : DEF=0
7102 PRINT "'";TF$;"' defined. ";FUNC;" procedure(s) total." : RETURN
7200 SAVED$ = RC$
7201 RC$ = FUNCP$(FF)
7202 REM Replace | separators with spaces for tokeniser
7203 FOR RI=1 TO LEN(RC$) : IF MID$(RC$,RI,1)="|" THEN RC$=LEFT$(RC$,RI-1)+" "+MID$(RC$,RI+1) : NEXT RI
7204 GOSUB 6100
7205 RC$ = SAVED$ : RETURN
8000 CMD$ = A$ : ARG = 0 : ARG$ = ""
8001 FOR I = 1 TO LEN(A$)
8002   IF MID$(A$,I,1) = " " THEN CMD$ = LEFT$(A$,I-1) : ARG$ = MID$(A$,I+1) : ARG = VAL(ARG$) : I = LEN(A$)+1
8003 NEXT I
8010 IF CMD$ = "FD" OR CMD$ = "FORWARD" THEN GOSUB 2000 : RETURN
8011 IF CMD$ = "BK" OR CMD$ = "BACK" THEN GOSUB 2100 : RETURN
8012 IF CMD$ = "RT" THEN TH=(TH+ARG) MOD 360 : GOSUB 9000 : RETURN
8013 IF CMD$ = "LT" THEN TH=(TH-ARG+3600) MOD 360 : GOSUB 9000 : RETURN
8014 IF CMD$ = "UP"    OR CMD$ = "U" THEN NX=TX : NY=TY-ARG : GOSUB 3000 : RETURN
8015 IF CMD$ = "DOWN"  OR CMD$ = "D" THEN NX=TX : NY=TY+ARG : GOSUB 3000 : RETURN
8016 IF CMD$ = "LEFT"  OR CMD$ = "L" THEN NX=TX-ARG : NY=TY : GOSUB 3000 : RETURN
8017 IF CMD$ = "RIGHT" OR CMD$ = "R" THEN NX=TX+ARG : NY=TY : GOSUB 3000 : RETURN
8020 IF CMD$ = "PU" OR CMD$ = "PENUP"   THEN PEN=0 : RETURN
8021 IF CMD$ = "PD" OR CMD$ = "PENDOWN" THEN PEN=1 : SX=TX : SY=TY : RETURN
8022 IF CMD$ = "PEN" AND ARG$ = "UP"   THEN PEN=0 : RETURN
8023 IF CMD$ = "PEN" AND ARG$ = "DOWN" THEN PEN=1 : SX=TX : SY=TY : RETURN
8025 IF CMD$ = "CS" OR CMD$ = "CLEARSCREEN" THEN GOSUB 4000 : RETURN
8026 IF CMD$ = "HOME" THEN TX=WIDTH/2 : TY=HEIGHT/2 : TH=0 : GOSUB 9000 : RETURN
8027 IF LEFT$(CMD$,2) = "CL" AND LEFT$(CMD$,3) <> "COL" THEN GOSUB 5000 : RETURN
8030 IF CMD$ = "COLOUR" OR CMD$ = "COLOR" THEN TC=ARG : FG=TC : GOSUB 9000 : RETURN
8035 IF CMD$ = "REPEAT" THEN GOSUB 6000 : RETURN
8040 IF CMD$ = "DEFINE" OR CMD$ = "DEF" THEN GOSUB 7000 : RETURN
8041 IF CMD$ = "END" THEN GOSUB 7100 : RETURN
8045 FOR F = 1 TO FUNC
8046   IF FUNCS$(F) = CMD$ THEN FF=F : GOSUB 7200 : F=FUNC+1
8047 NEXT F
8050 IF DEF=1 AND CMD$<>"DEFINE" AND CMD$<>"DEF" THEN FUNCP$(CF)=FUNCP$(CF)+"|"+CMD$+" "+ARG$
8099 RETURN
9000 COLOUR TC : CIRCLE TX,TY,2 : RETURN
