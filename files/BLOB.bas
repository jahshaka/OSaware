0 REM *** BLOB / OBJECT DEMO v1.0 ***
1 REM *** Bouncing coloured blobs  ***
2 REM *** (c) 2026 Exedos          ***
5 CLS
10 COLOUR 3 : PRINT "BLOB DEMO — OBJECT system"
20 PRINT "" : PRINT "Coloured blobs will bounce around the screen."
30 PRINT "Press any key to start, Q to quit."
40 DUMMY=GETKEY()
50 CLS : DELAY 0
100 REM === Define blob shapes (8x8 pixels each) ===
110 REM Red circle-ish blob
120 R$="8,8,"
130 R$=R$+"000000FF000000FF0000000000000000"
140 R$=R$+"FF0000FF0000FF0000FF000000000000"
150 R$=R$+"FF0000FF0000FF0000FF0000FF000000"
160 R$=R$+"FF0000FF0000FF0000FF0000FF000000"
170 R$=R$+"FF0000FF0000FF0000FF0000FF000000"
180 R$=R$+"FF0000FF0000FF0000FF000000000000"
190 R$=R$+"000000FF000000FF0000000000000000"
200 R$=R$+"000000000000000000000000FF000000"
210 REM Simpler solid 8x8 squares
220 RED$  ="8,8,"
230 GRN$  ="8,8,"
240 BLU$  ="8,8,"
250 YEL$  ="8,8,"
300 REM === Create 4 objects ===
310 OBJECT.SHAPE 1, RED$
320 OBJECT.SHAPE 2, GRN$
330 OBJECT.SHAPE 3, BLU$
340 OBJECT.SHAPE 4, YEL$
400 REM === Set positions ===
410 OBJECT.X 1, 50  : OBJECT.Y 1, 50
420 OBJECT.X 2, 150 : OBJECT.Y 2, 80
430 OBJECT.X 3, 100 : OBJECT.Y 3, 150
440 OBJECT.X 4, 200 : OBJECT.Y 4, 120
500 REM === Set velocities (pixels/sec) ===
510 OBJECT.VX 1, 80  : OBJECT.VY 1, 60
520 OBJECT.VX 2, -70 : OBJECT.VY 2, 90
530 OBJECT.VX 3, 100 : OBJECT.VY 3, -50
540 OBJECT.VX 4, -60 : OBJECT.VY 4, -80
600 REM === Enable collision detection ===
610 COLLISION ON
620 ON COLLISION GOSUB 2000
700 REM === Show all objects and start animation ===
710 OBJECT.ON
720 OBJECT.START
800 REM === Main loop: Q to quit ===
810 K=INKEY
820 IF K=81 OR K=113 OR K=27 THEN GOTO 900
830 SLEEP 50
840 GOTO 810
900 OBJECT.OFF
910 OBJECT.CLOSE
920 COLLISION OFF
930 COLOUR 3 : CLS : PRINT "BLOB demo ended."
940 END
2000 REM === COLLISION handler ===
2010 I=COLLISION(0)
2020 IF I=0 THEN RETURN
2030 J=COLLISION(I)
2040 IF J=-1 OR J=-3 THEN OBJECT.VY I,-OBJECT.VY(I)
2050 IF J=-2 OR J=-4 THEN OBJECT.VX I,-OBJECT.VX(I)
2060 OBJECT.START I
