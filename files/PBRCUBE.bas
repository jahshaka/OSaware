0 REM *****************************************************
1 REM ** PBRCUBE — PBR Textured Spinning Cube            **
2 REM ** 1=Stone 2=Silver 3=Lava 4=Plaster               **
3 REM *****************************************************
10 CLS : COLOUR 3
20 PRINT "PBR CUBE DEMO"
30 PRINT ""
40 PRINT "Choose material:"
50 PRINT "  1 = Stone   (roughness + AO + normal)"
60 PRINT "  2 = Silver  (metalness + envmap)"
70 PRINT "  3 = Lava    (emissive + roughness + AO)"
80 PRINT "  4 = Plaster (roughness + AO + height)"
90 PRINT "  Q = Quit"
100 PRINT ""
110 INPUT "Choice (1-4): "; CH$
120 IF UPPER$(CH$)="Q" THEN GOTO 990
130 MAT=VAL(CH$)
140 IF MAT<1 OR MAT>4 THEN GOTO 10
200 CLS
210 IF MAT=1 THEN PRINT "Stone   — SPACE=menu  Q=quit"
220 IF MAT=2 THEN PRINT "Silver  — SPACE=menu  Q=quit"
230 IF MAT=3 THEN PRINT "Lava    — SPACE=menu  Q=quit"
240 IF MAT=4 THEN PRINT "Plaster — SPACE=menu  Q=quit"
250 SLEEP 600
300 GL.INIT
310 GL.PERSPECTIVE 60
320 GL.CAMERA 0, 0, -4
330 GL.LOOKAT 0, 0, 0
340 IF MAT=1 THEN GL.AMBIENT 0.3
341 IF MAT=1 THEN GL.LIGHT 0.5, 1, -1
342 IF MAT=2 THEN GL.AMBIENT 0.7
343 IF MAT=2 THEN GL.LIGHT 1, 1, -1
344 IF MAT=2 THEN GL.POINTLIGHT  4,  4, -3, 255, 245, 220, 2, 80
345 IF MAT=2 THEN GL.POINTLIGHT -4, -2,  3, 200, 220, 255, 2, 80
346 IF MAT=2 THEN GL.POINTLIGHT  0,  4,  4, 255, 255, 255, 2, 80
347 IF MAT=2 THEN GL.POINTLIGHT  4, -4,  0, 255, 230, 200, 2, 80
348 IF MAT=3 THEN GL.AMBIENT 0.15
349 IF MAT=3 THEN GL.LIGHT 0.3, 0.5, -1
350 IF MAT=4 THEN GL.AMBIENT 0.5
351 IF MAT=4 THEN GL.LIGHT 0.8, 1, -0.5
352 IF MAT=4 THEN GL.POINTLIGHT -3,  2, -2, 255, 250, 240, 3, 40
353 IF MAT=4 THEN GL.POINTLIGHT  3, -2,  2, 240, 245, 255, 2, 40
400 GL.BEGIN
410 GL.VERTEX -1, -1, -1
420 GL.VERTEX  1, -1, -1
430 GL.VERTEX  1,  1, -1
440 GL.VERTEX -1,  1, -1
450 GL.VERTEX -1, -1,  1
460 GL.VERTEX  1, -1,  1
470 GL.VERTEX  1,  1,  1
480 GL.VERTEX -1,  1,  1
490 GL.FACE 1,2,3,4
500 GL.FACE 5,6,7,8
510 GL.FACE 1,4,8,5
520 GL.FACE 2,3,7,6
530 GL.FACE 4,3,7,8
540 GL.FACE 1,2,6,5
550 GL.END
560 CUBE=GL.MESHID
570 GL.SOLID
580 IF MAT=1 THEN GL.TEXTURE   CUBE, "STONE2/BASE.JPG", 1
590 IF MAT=1 THEN GL.NORMALMAP CUBE, "STONE2/NORMAL.JPG"
600 IF MAT=1 THEN GL.ROUGHMAP  CUBE, "STONE2/ROUGH.PNG"
610 IF MAT=1 THEN GL.AOMAP     CUBE, "STONE2/AO.PNG"
620 IF MAT=2 THEN GL.TEXTURE   CUBE, "SILVER/BASE.PNG", 1
630 IF MAT=2 THEN GL.NORMALMAP CUBE, "SILVER/NORMAL.JPG"
640 IF MAT=2 THEN GL.METALMAP  CUBE, "SILVER/METAL.PNG"
650 IF MAT=3 THEN GL.TEXTURE      CUBE, "LAVA/BASE.JPG", 1
660 IF MAT=3 THEN GL.NORMALMAP    CUBE, "LAVA/NORMAL.JPG"
670 IF MAT=3 THEN GL.ROUGHMAP     CUBE, "LAVA/ROUGH.JPG"
680 IF MAT=3 THEN GL.AOMAP        CUBE, "LAVA/AO.JPG"
690 IF MAT=3 THEN GL.EMISSIVEMAP  CUBE, "LAVA/EMISSIVE.JPG"
700 IF MAT=4 THEN GL.TEXTURE    CUBE, "PLASTER/BASE.JPG", 1
710 IF MAT=4 THEN GL.NORMALMAP  CUBE, "PLASTER/NORMAL.JPG"
720 IF MAT=4 THEN GL.ROUGHMAP   CUBE, "PLASTER/ROUGH.JPG"
730 IF MAT=4 THEN GL.AOMAP      CUBE, "PLASTER/AO.JPG"
740 REM HEIGHTMAP disabled on box geometry — uses normal map for surface detail
750 GL.CLS 0, 0, 25
760 GL.DRAW CUBE
770 IF MAT=2 THEN GL.ENVMAP             CUBE, 128
780 IF MAT=2 THEN GL.ROUGHNESS          CUBE, 0.1
790 IF MAT=2 THEN GL.METALNESS          CUBE, 0.85
800 IF MAT=3 THEN GL.EMISSIVEINTENSITY  CUBE, 3.0
810 RX=0 : RY=0
820 K=INKEY
830 IF K=81 OR K=113 OR K=27 THEN GOTO 990
840 IF K=32 THEN GOTO 900
850 GL.CLS 0, 0, 25
860 GL.COLOUR 255, 255, 255
870 GL.ROTATE CUBE, RX, RY, 0
880 GL.DRAW CUBE
890 RX=RX+1 : RY=RY+1.5
892 IF RX>=360 THEN RX=RX-360
894 IF RY>=360 THEN RY=RY-360
896 SLEEP 16
898 GOTO 820
900 GL.CLOSE
910 CLS
920 GOTO 10
990 COLOUR 3 : CLS : PRINT "PBR demo ended."
