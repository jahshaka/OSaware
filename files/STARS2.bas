1 REM ** Twinkling Stars 2                            **
2 REM ** (w) Jahshaka, 2025 Some Rights Reserved **
3 REM ** Last change: Sun Dec 11 18:28:37 CET 2005    **
4 REM **************************************************
6 GOSUB 500
7 INPUT "Number of stars? ";THRESH
8 MAX=THRESH+1
9 GOSUB 500
100 DIM STARX(MAX), STARY(MAX)
101 COUNT=0
110 COUNT=COUNT+1
115 IF INKEY>0 THEN 600
120 STARX(COUNT)=RND(WIDTH):STARY(COUNT)=RND(HEIGHT):COLOUR RND(16),,:POINT STARX(COUNT),STARY(COUNT)
132 IF COUNT>THRESH THEN 300 ELSE GOTO 330
135 IF COUNT=MAX THEN 101
200 GOTO 110
300 COLOUR 16,,:CIRCLE STARX(COUNT-THRESH),STARY(COUNT-THRESH),2:GOTO 110
330 TC=MAX-THRESH+COUNT
332 IF STARY(TC)>0 THEN 335 ELSE 135
335 COLOUR 16,,:CIRCLE STARX(TC),STARY(TC),2:GOTO 135
500 COLOUR 0,16,16:CLS:? CENTER$("Twinkling Stars 2"):?""
501 RETURN
