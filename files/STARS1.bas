0 REM ** Twinkling Stars 1 **
1 REM ** (w) Jahshaka, 2025 **
5 CLS : COLOUR 3 : ? CENTER$("Twinkling Stars 1")
6 DELAY 0
100 DIM STARX(25), STARY(25)
101 COUNT=0
110 COUNT=COUNT+1
115 IF INKEY>0 THEN GOTO 400
120 STARX(COUNT)=RND(WIDTH-4)+2
125 STARY(COUNT)=RND(HEIGHT-4)+2
129 COL=RND(15)+1
130 PSET STARX(COUNT), STARY(COUNT), COL
132 SLEEP 80
133 IF COUNT>10 THEN 300 ELSE GOTO 330
135 IF COUNT=25 THEN 101
200 GOTO 110
300 PSET STARX(COUNT-10), STARY(COUNT-10), 16
320 GOTO 110
330 TC=15+COUNT
335 IF TC<=25 THEN PSET STARX(TC), STARY(TC), 16
345 GOTO 135
400 SLEEP 300
