10 CLS
20 COLOUR 3 : PRINT "SWITCH demo"
30 PRINT "============"
40 PRINT ""
50 FOR X=0 TO 12
60 PRINT "X=";X;" -> ";
70 SWITCH(X)
80 CASE 1:
90 PRINT "one"
100 BREAK
110 CASE 2:
120 CASE 3:
130 PRINT "two or three"
140 BREAK
150 CASE 4 TO 6:
160 PRINT "four to six"
170 BREAK
180 CASE IS > 10:
190 PRINT "greater than ten"
200 BREAK
210 DEFAULT:
220 PRINT "other"
230 BREAK
240 END SWITCH
250 NEXT X
260 PRINT ""
270 COLOUR 3 : PRINT "Done!"
