10 REM  ***  SNAKE CUBE  ***
20 CMINIT
30 DIM B$(24) : REM ===== BODY NAMES =====
40 B$(1)="A"  : B$(2)="B"  : B$(3)="C"  : B$(4)="D"
50 B$(5)="E"  : B$(6)="F"  : B$(7)="G"  : B$(8)="H"
60 B$(9)="I"  : B$(10)="J" : B$(11)="K" : B$(12)="L"
70 B$(13)="M" : B$(14)="N" : B$(15)="O" : B$(16)="P"
80 B$(17)="Q" : B$(18)="R" : B$(19)="S" : B$(20)="T"
90 B$(21)="U" : B$(22)="V" : B$(23)="W" : B$(24)="X"
100 CPOS(1)=200 : CPOS(2)=200 : CPOS(3)=200
110 TH=1.0 : DPCAM CPOS,TH
120 PRWEDG B$(1), 10.0, 10.0, 10.0
130 FOR I=2 TO 24 : COPY B$(1),B$(I) : NEXT
140 FOR I=1 TO 23 : LMTREE B$(I),B$(I+1) : NEXT
150 REM
160 ANG(1)=180
170 FOR I=24 TO 2 STEP -1
180 J=I/2 : J=I-2*J
190 IF J<>0 THEN 220
200 C(1)=5.0 : C(2)=0.0 : GOTO 230
220 C(1)=0.0 : C(2)=5.0
230 PGROT B$(I),,ANG,C,1
240 NEXT I
250 CLS : HEDISP B$(1),1
260 CENY(3)=5 : CENX(3)=-5
270 ANGX(3)=90 : ANGY(2)=90
280 PRINT "WHICH BODY DO YOU WANT TO ROTATE ?"
290 PRINT "IF END, INPUT (0)"
300 INPUT "PLEASE INPUT A NUMBER FROM 0 TO 23"; N
310 IF N=0 THEN END
320 PRINT "ROTATION ANGLE ?"
330 PRINT "  IF  90 DEGREES, INPUT (0)"
340 PRINT "  IF 180        , INPUT (1)"
350 PRINT "  IF 270        , INPUT (2)"
360 INPUT M
370 N=N+1
380 L=N/2 : L=N-L*2
390 ON L+1 GOSUB 450,460
400 IF M=2 THEN M=1 : GOTO 390
410 IF M=1 THEN M=0 : GOTO 390
420 CLS : HEDISP B$(1),1
430 GOTO 280
440 REM
450 PGROT B$(N),B$(N),ANGY,CENY,1 : RETURN
460 PGROT B$(N),B$(N),ANGX,CENX,1 : RETURN
