0 REM *****************************************************
1 REM ** TODO  —  Task List Manager for OSAWARE  v1.0   **
2 REM ** (c) 2026 Exedos. All rights reserved.          **
3 REM *****************************************************
10 MAX=20
15 DIM T$(20)
16 DIM D(20)
17 COUNT=0
100 GOTO 500
499 END
500 REM ============ MAIN LOOP ============
510 GOSUB 3000
520 COLOUR 14 : PRINT TAB$(2);">  ";
530 COLOUR 3 : INPUT CMD$
540 CMD$=UPPER$(CMD$)
550 IF CMD$="A" THEN GOSUB 1000
560 IF CMD$="C" THEN GOSUB 1300
570 IF CMD$="Q" THEN GOTO 900
580 IF LEFT$(CMD$,1)="D" THEN N=VAL(MID$(CMD$,2,3)) : GOSUB 1500
590 IF LEFT$(CMD$,1)="X" THEN N=VAL(MID$(CMD$,2,3)) : GOSUB 1200
595 IF LEFT$(CMD$,1)="E" THEN N=VAL(MID$(CMD$,2,3)) : GOSUB 1600
600 GOTO 500
900 COLOUR 3 : CLS : PRINT CENTER$("Goodbye! Stay productive.") : END
1000 REM ===== ADD item =====
1005 IF COUNT>=MAX THEN COLOUR 2 : PRINT TAB$(2);"List full!" : RETURN
1010 COLOUR 14 : PRINT TAB$(2);"New task: ";
1020 COLOUR 3 : INPUT ITEM$
1030 IF ITEM$="" THEN RETURN
1040 COUNT=COUNT+1
1050 T$(COUNT)=ITEM$
1060 D(COUNT)=0
1070 RETURN
1200 REM ===== DELETE item =====
1205 IF N<1 OR N>COUNT THEN COLOUR 2 : PRINT TAB$(2);"Invalid number." : RETURN
1210 FOR II=N TO COUNT-1
1220   T$(II)=T$(II+1)
1230   D(II)=D(II+1)
1240 NEXT II
1250 T$(COUNT)="" : D(COUNT)=0 : COUNT=COUNT-1
1260 RETURN
1300 REM ===== CLEAR done =====
1310 CHANGED=0 : II=1
1320 IF II>COUNT THEN GOTO 1390
1325 IF D(II)=0 THEN II=II+1 : GOTO 1320
1350 FOR JJ=II TO COUNT-1
1355   T$(JJ)=T$(JJ+1)
1360   D(JJ)=D(JJ+1)
1370 NEXT JJ
1380 T$(COUNT)="" : D(COUNT)=0 : COUNT=COUNT-1 : CHANGED=1
1390 IF CHANGED=1 THEN CHANGED=0 : GOTO 1310
1395 RETURN
1500 REM ===== TOGGLE done =====
1505 IF N<1 OR N>COUNT THEN COLOUR 2 : PRINT TAB$(2);"Invalid number." : RETURN
1510 IF D(N)=0 THEN D(N)=1 : RETURN
1520 D(N)=0
1530 RETURN
1600 REM ===== EDIT item =====
1605 IF N<1 OR N>COUNT THEN COLOUR 2 : PRINT TAB$(2);"Invalid number." : RETURN
1610 COLOUR 14 : PRINT TAB$(2);"Edit (blank=keep): ";
1620 COLOUR 3 : INPUT NEWT$
1630 IF NEWT$="" THEN RETURN
1640 T$(N)=NEWT$ : D(N)=0
1650 RETURN
3000 REM ===== DRAW SCREEN =====
3005 CLS
3010 COLOUR 0,3, : PRINT CENTER$("** TODO LIST **") : COLOUR 0,16,
3015 PENDING=0 : DONECOUNT=0
3016 FOR II=1 TO COUNT
3017   IF D(II)=0 THEN PENDING=PENDING+1 ELSE DONECOUNT=DONECOUNT+1
3020 NEXT II
3025 COLOUR 7 : PRINT TAB$(2);COUNT;" item";
3026 IF COUNT<>1 THEN PRINT "s";
3027 PRINT "  [";PENDING;" pending / ";DONECOUNT;" done]"
3030 PRINT TAB$(2);"----------------------------------"
3040 IF COUNT=0 THEN COLOUR 7 : PRINT "" : PRINT TAB$(6);"Nothing here yet." : PRINT TAB$(6);"Press A to add!" : PRINT "" : GOTO 3200
3045 PRINT ""
3050 FOR II=1 TO COUNT
3055   NSTR$=STR$(II) : IF LEN(NSTR$)=1 THEN NSTR$=" "+NSTR$
3057   DVAL=D(II)
3060   LSTR$="[ ] "+NSTR$+" "+T$(II)
3062   IF DVAL=1 THEN LSTR$="[x] "+NSTR$+" "+T$(II)
3064   IF DVAL=0 THEN COLOUR 3 ELSE COLOUR 7
3066   PRINT TAB$(2);LSTR$
3075 NEXT II
3080 PRINT ""
3200 COLOUR 7 : PRINT TAB$(2);"----------------------------------"
3210 COLOUR 3 : PRINT TAB$(2);" A"; : COLOUR 7 : PRINT "dd"
3212 COLOUR 3 : PRINT TAB$(2);" D"; : COLOUR 7 : PRINT "2  mark #2 done/undo"
3214 COLOUR 3 : PRINT TAB$(2);" E"; : COLOUR 7 : PRINT "2  edit task #2"
3216 COLOUR 3 : PRINT TAB$(2);" X"; : COLOUR 7 : PRINT "2  delete #2"
3218 COLOUR 3 : PRINT TAB$(2);" C"; : COLOUR 7 : PRINT "lear done"
3220 COLOUR 3 : PRINT TAB$(2);" Q"; : COLOUR 7 : PRINT "uit"
