1 REM *** GRAPHICS TEST SUITE ***
2 REM *** Tests PSET CIRCLE LINE RECT PAINT PRESET ***
5 CLS : COLOUR 3
10 PRINT "GRAPHICS TEST SUITE"
20 PRINT "==================="
30 PRINT ""
100 REM --- TEST 1: PSET pixels ---
110 PRINT "1. PSET - 16 colour grid..."
120 FOR I=0 TO 15
130   FOR J=0 TO 15
140     PSET I*10+10, J*10+10, I+1
150   NEXT J
160 NEXT I
170 COLOUR 3 : PRINT "   done."
180 SLEEP 500
200 REM --- TEST 2: CIRCLE (outline, with colour param) ---
210 COLOUR 3 : PRINT "2. CIRCLE - concentric rings..."
220 FOR I=1 TO 8
230   CIRCLE 400, 150, I*15, I*2
240 NEXT I
250 COLOUR 3 : PRINT "   done."
260 SLEEP 500
300 REM --- TEST 3: LINE (with colour param) ---
310 COLOUR 3 : PRINT "3. LINE - starburst..."
320 FOR I=1 TO 16
330   LINE 300,300, 300+COS(I*0.4)*100, 300+SIN(I*0.4)*100, I
340 NEXT I
350 COLOUR 3 : PRINT "   done."
360 SLEEP 500
400 REM --- TEST 4: RECT (with colour param) ---
410 COLOUR 3 : PRINT "4. RECT - nested boxes..."
420 FOR I=1 TO 8
430   RECT 480+I*5, 80+I*5, 580-I*5, 180-I*5, I
440 NEXT I
450 COLOUR 3 : PRINT "   done."
460 SLEEP 500
500 REM --- TEST 5: PAINT flood fill ---
510 COLOUR 3 : PRINT "5. PAINT - flood fill..."
520 CIRCLE 150, 400, 50, 7
530 PAINT 150, 400, 5, 7
540 COLOUR 3 : PRINT "   done."
550 SLEEP 500
600 REM --- TEST 6: PRESET ---
610 COLOUR 3 : PRINT "6. PRESET - erase pixels..."
620 FOR I=0 TO 150
630   PSET 380+I, 400, 14
640 NEXT I
650 FOR I=20 TO 130
660   PRESET 380+I, 400
670 NEXT I
680 COLOUR 3 : PRINT "   done."
700 COLOUR 3
710 PRINT ""
720 PRINT "ALL TESTS COMPLETE !"
